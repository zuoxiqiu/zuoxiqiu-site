---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getExcerpt } from '../utils/content';

const ideas = (await getCollection('ideas')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const mvps = (await getCollection('mvp')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const thinking = (await getCollection('thinking')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const formatDate = (date: Date) => date.toISOString().slice(0, 10).replaceAll('-', '.');

const allPosts = [
  ...thinking.map((post) => ({ ...post, type: 'thinking', typeLabel: '思考' })),
  ...ideas.map((post) => ({ ...post, type: 'ideas', typeLabel: '想法' })),
  ...mvps.map((post) => ({ ...post, type: 'mvp', typeLabel: '实验' })),
]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const collections = [
  { href: '/thinking', label: '思考', count: thinking.length },
  { href: '/ideas', label: '想法', count: ideas.length },
  { href: '/mvp', label: '实验', count: mvps.length },
];

const latestPost = allPosts[0];
---

<Layout
  title="昨夕秋"
  description="昨夕秋的数字花园，记录思考、想法与实验。"
>
  <div class="home-root">
    <section class="page-wrap home-intro" aria-labelledby="home-title">
      <div class="home-hero-grid">
        <div class="home-heading">
          <p class="home-eyebrow">Zuo Xiqiu / Digital notes</p>
          <h1 id="home-title"><span>昨夕秋</span></h1>
          <p class="home-statement">记录看见、理解与改变。</p>
        </div>

        {latestPost && (
          <a href={`/${latestPost.type}/${latestPost.id}`} class="latest-entry">
            <div class="latest-meta">
              <span>最新文章</span>
              <time datetime={latestPost.data.date.toISOString()}>
                {formatDate(latestPost.data.date)}
              </time>
            </div>
            <h2>{latestPost.data.title}</h2>
            <p>{getExcerpt(latestPost.body, 68)}</p>
            <span class="latest-action">阅读全文 <b aria-hidden="true">↗</b></span>
          </a>
        )}
      </div>

      <div class="home-intro-footer">
        <nav class="home-collections" aria-label="内容分类">
          {collections.map((item, index) => (
            <a href={item.href}>
              <span class="collection-index">0{index + 1}</span>
              <strong>{item.label}</strong>
              <span class="collection-count">{String(item.count).padStart(2, '0')}</span>
            </a>
          ))}
        </nav>
      </div>
    </section>

    <section class="page-wrap home-recent reveal" aria-labelledby="recent-title">
      <header class="recent-heading">
        <div>
          <p class="home-eyebrow">Recently published</p>
          <h2 id="recent-title">最近</h2>
        </div>
        <p>{String(allPosts.length).padStart(2, '0')} entries</p>
      </header>

      <ol class="entry-list">
        {allPosts.map((post, index) => (
          <li style={`--row: ${index}`}>
            <a href={`/${post.type}/${post.id}`} class="entry-row">
              <span class="entry-number">{String(index + 1).padStart(2, '0')}</span>
              <span class="entry-type">{post.typeLabel}</span>
              <h3>{post.data.title}</h3>
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              <span class="entry-arrow" aria-hidden="true">↗</span>
            </a>
          </li>
        ))}
      </ol>
    </section>
  </div>
</Layout>

<style>
  .home-root {
    --home-line: rgba(24, 20, 17, 0.14);
  }

  .home-intro {
    position: relative;
    padding-top: clamp(4.5rem, 8vw, 7rem);
    padding-bottom: clamp(2.8rem, 5vw, 4rem);
    border-bottom: 1px solid var(--home-line);
  }

  .home-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(22rem, 0.72fr);
    gap: clamp(3rem, 8vw, 8rem);
    align-items: end;
    min-height: clamp(27rem, 58vh, 40rem);
  }

  .home-heading {
    display: grid;
    gap: clamp(1.1rem, 2vw, 1.7rem);
  }

  .home-eyebrow {
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--soft);
  }

  .home-heading .home-eyebrow {
    opacity: 0;
    animation: home-fade-in 700ms 80ms var(--ease-out) forwards;
  }

  .home-heading h1 {
    overflow: hidden;
    margin: 0;
    font-size: clamp(5.8rem, 12.5vw, 9.7rem);
    line-height: 0.84;
    letter-spacing: 0.02em;
  }

  .home-heading h1 span {
    display: block;
    transform: translateY(108%);
    animation: home-title-in 850ms 40ms var(--ease-out) forwards;
  }

  .home-statement {
    max-width: none;
    font-family: var(--display);
    font-size: clamp(1.55rem, 2.4vw, 2rem);
    line-height: 1.2;
    letter-spacing: -0.025em;
    white-space: nowrap;
    opacity: 0;
    animation: home-fade-in 700ms 280ms var(--ease-out) forwards;
  }

  .latest-entry {
    display: grid;
    gap: 1.25rem;
    min-height: 20rem;
    padding: 0.5rem 0 0.5rem clamp(1.8rem, 4vw, 3.2rem);
    border-left: 1px solid var(--home-line);
    opacity: 0;
    animation: home-fade-in 750ms 300ms var(--ease-out) forwards;
  }

  .latest-meta {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-family: var(--mono);
    font-size: 0.76rem;
    letter-spacing: 0.08em;
    color: var(--soft);
  }

  .latest-entry h2 {
    align-self: end;
    font-size: clamp(2.8rem, 5vw, 4.6rem);
    line-height: 0.96;
    transition: transform 500ms var(--ease-out);
  }

  .latest-entry > p {
    max-width: 31rem;
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--muted);
  }

  .latest-action {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--home-line);
    font-size: 0.95rem;
  }

  .latest-action b {
    font-size: 1.1rem;
    font-weight: 400;
    transition: transform 500ms var(--ease-out);
  }

  .latest-entry:hover h2 {
    transform: translateX(0.35rem);
  }

  .latest-entry:hover .latest-action b {
    transform: translate(0.2rem, -0.2rem);
  }

  .home-intro-footer {
    margin-top: clamp(4rem, 8vw, 7rem);
  }

  .home-collections {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid var(--home-line);
    opacity: 0;
    animation: home-fade-in 700ms 460ms var(--ease-out) forwards;
  }

  .home-collections a {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.8rem;
    align-items: baseline;
    padding: 1.25rem 1.1rem 1.15rem;
    border-bottom: 1px solid var(--home-line);
    transition:
      color 500ms var(--ease-out),
      background-color 500ms var(--ease-out),
      padding 500ms var(--ease-out);
  }

  .home-collections a + a {
    border-left: 1px solid var(--home-line);
  }

  .home-collections a:hover {
    padding-inline: 1.35rem 0.85rem;
    color: var(--forest);
    background: rgba(255, 255, 255, 0.24);
  }

  .collection-index,
  .collection-count {
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--soft);
  }

  .home-collections strong {
    font-family: var(--display);
    font-size: 1.45rem;
    font-weight: 600;
  }

  .home-recent {
    padding-top: clamp(6rem, 11vw, 10rem);
    padding-bottom: clamp(6rem, 11vw, 10rem);
  }

  .recent-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }

  .recent-heading > div {
    display: grid;
    gap: 0.8rem;
  }

  .recent-heading h2 {
    font-size: clamp(3.8rem, 8vw, 7rem);
    line-height: 0.82;
  }

  .recent-heading > p {
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--soft);
  }

  .entry-list {
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--home-line);
    list-style: none;
  }

  .entry-list li {
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 750ms var(--ease-out),
      transform 750ms var(--ease-out);
    transition-delay: calc(var(--row) * 65ms + 120ms);
  }

  .home-recent.is-visible .entry-list li {
    opacity: 1;
    transform: translateY(0);
  }

  .entry-row {
    display: grid;
    grid-template-columns: 2.8rem 5.2rem minmax(0, 1fr) auto 1.5rem;
    gap: 1rem;
    align-items: center;
    min-height: 7rem;
    border-bottom: 1px solid var(--home-line);
    transition:
      background-color 500ms var(--ease-out),
      padding 500ms var(--ease-out);
  }

  .entry-row:hover {
    padding-inline: 0.8rem;
    background: rgba(255, 255, 255, 0.26);
  }

  .entry-number,
  .entry-type,
  .entry-row time {
    font-family: var(--mono);
    font-size: 0.76rem;
    letter-spacing: 0.07em;
    color: var(--soft);
  }

  .entry-type {
    color: var(--forest-soft);
  }

  .entry-row h3 {
    overflow: hidden;
    font-size: clamp(1.65rem, 2.8vw, 2.3rem);
    line-height: 1.08;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: transform 500ms var(--ease-out);
  }

  .entry-row:hover h3 {
    transform: translateX(0.35rem);
  }

  .entry-arrow {
    font-size: 1.05rem;
    color: var(--soft);
    transition:
      color 500ms var(--ease-out),
      transform 500ms var(--ease-out);
  }

  .entry-row:hover .entry-arrow {
    color: var(--ink);
    transform: translate(0.15rem, -0.15rem);
  }

  @keyframes home-title-in {
    to {
      transform: translateY(0);
    }
  }

  @keyframes home-fade-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 860px) {
    .home-hero-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
      min-height: auto;
    }

    .home-statement {
      max-width: none;
    }

    .latest-entry {
      min-height: 17rem;
      padding: 2.5rem 0 0;
      border-top: 1px solid var(--home-line);
      border-left: 0;
    }

    .entry-row {
      grid-template-columns: 2rem 3.5rem minmax(0, 1fr) 1.2rem;
    }

    .entry-row time {
      display: none;
    }
  }

  @media (max-width: 620px) {
    .home-intro {
      padding-top: 4rem;
    }

    .home-heading h1 {
      font-size: 22vw;
      line-height: 0.84;
      letter-spacing: 0.02em;
    }

    .home-collections {
      grid-template-columns: 1fr;
    }

    .home-collections a + a {
      border-left: 0;
    }

    .latest-entry h2 {
      font-size: 3.2rem;
    }

    .latest-entry > p {
      font-size: 1rem;
    }

    .recent-heading {
      align-items: start;
    }

    .entry-row {
      grid-template-columns: 1.8rem minmax(0, 1fr) 1rem;
      gap: 0.8rem;
      min-height: 6.2rem;
    }

    .entry-type {
      display: none;
    }

    .entry-row h3 {
      font-size: 1.45rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-heading .home-eyebrow,
    .home-heading h1 span,
    .home-statement,
    .latest-entry,
    .home-collections,
    .entry-list li {
      opacity: 1;
      transform: none;
      animation: none;
      transition: none;
    }
  }
</style>
