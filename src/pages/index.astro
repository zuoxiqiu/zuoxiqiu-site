---
import Layout from '../layouts/Layout.astro';
---

<Layout title="昨夕秋">
  <!-- 极简现代风格首页 -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-gray-950">
    
    <!-- 微妙渐变背景 -->
    <div class="absolute inset-0 bg-gradient-to-br from-gray-900 via-gray-950 to-black"></div>
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-blue-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-purple-500/10 rounded-full blur-3xl"></div>
    
    <!-- 网格纹理 -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 50px 50px;"></div>
    
    <div class="relative z-10 max-w-4xl mx-auto text-center px-6">
      <!-- Logo -->
      <div class="mb-6 opacity-80">
        <span class="text-6xl">🦞</span>
      </div>
      
      <!-- 主标题 - 简洁白色 -->
      <h1 class="text-6xl md:text-8xl font-light text-white mb-6 tracking-tight">
        昨夕秋
      </h1>
      
      <!-- 副标题 -->
      <p class="text-lg md:text-xl text-gray-400 mb-4 max-w-xl mx-auto font-light">
        捕捉昨日的灵感，沉淀今日的思考
      </p>
      
      <p class="text-sm text-gray-500 mb-16 max-w-md mx-auto">
        数字花园 · 想法记录 · 实验验证
      </p>
      
      <!-- 极简按钮 -->
      <div class="flex gap-4 justify-center">
        <a href="/ideas" class="group px-8 py-4 bg-white text-gray-900 rounded-full font-medium transition-all duration-300 hover:bg-gray-100 hover:scale-105">
          <span class="flex items-center gap-2">
            <span>💡</span>
            <span>浏览想法</span>
          </span>
        </a>
        
        <a href="/mvp" class="group px-8 py-4 border border-gray-700 text-gray-300 rounded-full font-medium transition-all duration-300 hover:border-gray-500 hover:text-white hover:scale-105">
          <span class="flex items-center gap-2">
            <span>🧪</span>
            <span>查看实验</span>
          </span>
        </a>
      </div>
    </div>
    
    <!-- 底部装饰线 -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2">
      <div class="w-px h-16 bg-gradient-to-b from-transparent via-gray-600 to-transparent"></div>
    </div>
  </section>

  <!-- 三个板块 -->
  <section class="py-24 px-6 bg-gray-950 border-t border-gray-900">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-3 gap-8">
        
        <div class="group p-8 border border-gray-800 rounded-2xl transition-all duration-300 hover:border-gray-600 hover:bg-gray-900/50">
          <div class="text-3xl mb-4 text-gray-400 group-hover:text-white transition-colors">💡</div>
          <h3 class="text-lg font-medium text-white mb-2">突发奇想</h3>
          <p class="text-sm text-gray-500 leading-relaxed">随手记录灵感瞬间，不筛选不加工</p>
        </div>
        
        <div class="group p-8 border border-gray-800 rounded-2xl transition-all duration-300 hover:border-gray-600 hover:bg-gray-900/50">
          <div class="text-3xl mb-4 text-gray-400 group-hover:text-white transition-colors">🧪</div>
          <h3 class="text-lg font-medium text-white mb-2">MVP实验</h3>
          <p class="text-sm text-gray-500 leading-relaxed">验证想法可行性，快速迭代</p>
        </div>
        
        <div class="group p-8 border border-gray-800 rounded-2xl transition-all duration-300 hover:border-gray-600 hover:bg-gray-900/50">
          <div class="text-3xl mb-4 text-gray-400 group-hover:text-white transition-colors">📝</div>
          <h3 class="text-lg font-medium text-white mb-2">知识沉淀</h3>
          <p class="text-sm text-gray-500 leading-relaxed">日积月累形成知识资产</p>
        </div>
        
      </div>
    </div>
  </section>

  <!-- 理念 -->
  <section class="py-24 px-6 bg-gray-950 border-t border-gray-900">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-gray-400 mb-4 text-lg">
        <span class="text-white">昨</span>日的思考，<span class="text-white">夕</span>阳的沉淀，<span class="text-white">秋</span>收的积累
      </p>
      <p class="text-gray-500 text-sm">
        不追求完美，只求真实
      </p>
    </div>
  </section>

  <!-- Footer CTA -->
  <section class="py-16 px-6 bg-gray-950 border-t border-gray-900">
    <div class="max-w-xl mx-auto text-center">
      <a href="/ideas" class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors text-sm">
        <span>开始阅读</span>
        <span>→</span>
      </a>
    </div>
  </section>
</Layout>
