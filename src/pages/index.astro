---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const ideas = await getCollection('ideas');
const mvp = await getCollection('mvp');

const allPosts = [
  ...ideas.map(p => ({ ...p, type: 'ideas' })),
  ...mvp.map(p => ({ ...p, type: 'mvp' }))
].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 6);
---

<Layout title="昨夕秋">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-title-wrap">
      <h1 class="hero-title">昨夕秋</h1>
      <p class="hero-subtitle">捕捉昨日的灵感，沉淀今日的思考</p>
      <p class="hero-pinyin">ZUO XI QIU</p>
    </div>
    <div class="scroll-hint">
      <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
    </div>
  </section>

  <!-- About -->
  <section class="about">
    <div class="section-label">About</div>
    <div class="about-text">
      <p>这是一个<em>随手记录灵感</em>的地方。</p>
      <p>想法、实验、知识——所有都在这里沉淀，等待被验证或遗忘。</p>
      <p>没有固定方向，只有持续产出。</p>
    </div>
  </section>

  <!-- Divider -->
  <div class="divider">
    <div class="divider-dot"></div>
  </div>

  <!-- Writings -->
  <section class="writings">
    <div class="section-label">Writings</div>
    <div class="writing-list">
      {allPosts.map((post) => (
        <a href={`/${post.type}/${post.id}`} class="writing-item">
          <div class="writing-date">{post.data.date.toISOString().slice(0, 10)} · {post.type === 'ideas' ? '想法' : '实验'}</div>
          <div class="writing-title">{post.data.title}</div>
          {post.data.description && (
            <div class="writing-excerpt">{post.data.description}</div>
          )}
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    min-height: calc(100vh - 80px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 2rem;
    position: relative;
  }

  .hero-title-wrap {
    text-align: center;
    opacity: 0;
    animation: fadeUp 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.3s forwards;
  }

  .hero-title {
    font-size: clamp(4rem, 12vw, 9rem);
    font-weight: 200;
    letter-spacing: 0.3em;
    margin-right: -0.3em;
    color: var(--ink);
    position: relative;
  }

  .hero-title::after {
    content: '';
    position: absolute;
    bottom: -0.4em;
    left: 50%;
    transform: translateX(-50%);
    width: 2em;
    height: 1px;
    background: var(--accent);
    opacity: 0;
    animation: fadeIn 0.8s ease 1.4s forwards;
  }

  .hero-subtitle {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(0.8rem, 1.5vw, 1rem);
    font-weight: 300;
    font-style: italic;
    letter-spacing: 0.35em;
    margin-right: -0.35em;
    color: var(--muted);
    margin-top: 3rem;
    opacity: 0;
    animation: fadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) 0.8s forwards;
  }

  .hero-pinyin {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    font-weight: 300;
    letter-spacing: 0.5em;
    margin-right: -0.5em;
    color: var(--faint);
    margin-top: 1.2rem;
    opacity: 0;
    animation: fadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) 1s forwards;
  }

  .scroll-hint {
    position: absolute;
    bottom: 3rem;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0;
    animation: fadeIn 1s ease 2s forwards, float 3s ease-in-out 2s infinite;
  }

  .scroll-hint svg {
    width: 20px;
    height: 20px;
    stroke: var(--faint);
    stroke-width: 1.5;
    fill: none;
  }

  /* About */
  .about {
    max-width: 680px;
    margin: 0 auto;
    padding: 8rem 2rem 10rem;
  }

  .about-text em {
    font-style: normal;
    color: var(--accent);
  }

  .about-text p + p {
    margin-top: 1.8rem;
  }

  /* Writings */
  .writings {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 2rem 10rem;
  }

  /* Scroll reveal - optional enhancement */
  .section-label.visible,
  .about-text.visible {
    animation: fadeUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .writing-item.visible {
    animation: fadeUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        (entry.target as HTMLElement).style.animationDelay = `${i * 0.1}s`;
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.writing-item, .section-label, .about-text').forEach(el => {
    observer.observe(el);
  });
</script>
