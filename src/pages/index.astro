---
import Layout from '../layouts/Layout.astro';
---

<Layout title="首页">
  <!-- Hero Section -->
  <section class="relative py-20 px-4" style="background: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(0,0,0,.02) 10px, rgba(0,0,0,.02) 20px);">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Logo with doodle -->
      <div class="mb-8 relative inline-block">
        <span class="text-8xl animate-bounce" style="animation-duration: 2.5s; text-shadow: 3px 3px 0 #000;">🦞</span>
        <div class="absolute -top-2 -right-4 text-2xl" style="transform: rotate(15deg);">✨</div>
      </div>
      
      <!-- Title -->
      <h1 class="font-handwriting text-5xl md:text-7xl mb-6 text-pencil leading-tight">
        小小的想法
        <br>
        <span class="text-marker-blue" style="text-shadow: 2px 2px 0 #000;">改变世界</span>
      </h1>
      
      <!-- Subtitle -->
      <p class="text-xl md:text-2xl text-gray-700 mb-12 font-sketch max-w-2xl mx-auto leading-relaxed">
        世界总需要更多 <span class="text-marker-pink font-bold">好奇心</span> 的人
        <span class="doodle-star" style="color: #ecc94b;"></span>
      </p>
      
      <!-- CTA Buttons -->
      <div class="flex gap-4 justify-center flex-wrap">
        <a href="/ideas" 
           class="btn-sketch bg-marker-blue text-white no-underline">
          <span>📝 想法流</span>
        </a>
        <a href="/mvp" 
           class="btn-sketch bg-marker-green text-white no-underline">
          <span>🧪 实验场</span>
        </a>
        <a href="/about" 
           class="btn-sketch bg-marker-pink text-white no-underline">
          <span>👋 关于</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Three Cards Section -->
  <section class="py-16 px-4 bg-paper" style="background-image: radial-gradient(#e2e8f0 1px, transparent 1px);">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-handwriting font-bold text-center text-pencil mb-12">
        这里是做什么的？
      </h2>
      
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Card 1 -->
        <div class="hand-border bg-paper p-6 relative overflow-hidden" style="transform: rotate(-1deg);">
          <div class="absolute top-0 right-0 w-8 h-8 bg-marker-blue opacity-20" style="clip-path: polygon(100% 0, 0 0, 100% 100%);"></div>
          <div class="text-5xl mb-4">💡</div>
          <h3 class="text-2xl font-handwriting font-bold text-pencil mb-3">突发奇想</h3>
          <p class="text-gray-600 font-sketch text-lg leading-relaxed mb-4">
            随手记录每一个灵感瞬间。不筛选，不加工，让想法自由流动。
          </p>
          <div class="mt-auto">
            <span class="inline-block px-3 py-1 bg-marker-blue text-white text-sm font-handwriting rounded-full">
              Raw Ideas
            </span>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="hand-border bg-paper p-6 relative overflow-hidden" style="transform: rotate(1deg); margin-top: 1rem;">
          <div class="absolute top-0 right-0 w-8 h-8 bg-marker-green opacity-20" style="clip-path: polygon(100% 0, 0 0, 100% 100%);"></div>
          <div class="text-5xl mb-4">🧪</div>
          <h3 class="text-2xl font-handwriting font-bold text-pencil mb-3">MVP实验</h3>
          <p class="text-gray-600 font-sketch text-lg leading-relaxed mb-4">
            把想法变成最小可行产品。记录过程，收集反馈，快速迭代。
          </p>
          <div class="mt-auto">
            <span class="inline-block px-3 py-1 bg-marker-green text-white text-sm font-handwriting rounded-full">
              Validate
            </span>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="hand-border bg-paper p-6 relative overflow-hidden" style="transform: rotate(-1deg);">
          <div class="absolute top-0 right-0 w-8 h-8 bg-marker-pink opacity-20" style="clip-path: polygon(100% 0, 0 0, 100% 100%);"></div>
          <div class="text-5xl mb-4">📝</div>
          <h3 class="text-2xl font-handwriting font-bold text-pencil mb-3">知识沉淀</h3>
          <p class="text-gray-600 font-sketch text-lg leading-relaxed mb-4">
            日积月累，零散的想法汇聚成庞大的个人知识资产。
          </p>
          <div class="mt-auto">
            <span class="inline-block px-3 py-1 bg-marker-pink text-white text-sm font-handwriting rounded-full">
              Knowledge
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy Section -->
  <section class="py-20 px-4" style="background: linear-gradient(180deg, #f7f3e8 0%, #fdfbf7 100%);">
    <div class="max-w-3xl mx-auto">
      <div class="sticky-note max-w-lg mx-auto">
        <h2 class="text-2xl font-handwriting font-bold text-pencil mb-4 flex items-center gap-2">
          <span>📌</span> 为什么做这个网站？
        </h2>
        <p class="text-gray-700 font-sketch text-lg leading-loose mb-4">
          这是一个 <strong class="text-marker-blue">数字花园</strong> —— 一个用来种想法、养实验、收知识的地方。
        </p>
        <p class="text-gray-700 font-sketch text-lg leading-loose">
          不追求完美，只求真实。每一个粗糙的想法，都可能长出意想不到的花。
        </p>
        <div class="mt-6 flex justify-end">
          <span class="text-2xl font-handwriting text-gray-400">— zuoxiqiu</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Flow Section -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-handwriting font-bold text-center text-pencil mb-12">
        想法怎么变成结果？
      </h2>
      
      <!-- Step 1 -->
      <div class="flex items-start gap-6 mb-12" style="margin-left: 2rem;">
        <div class="w-20 h-20 bg-gradient-to-br from-yellow-300 to-orange-400 rounded-3xl flex items-center justify-center text-4xl shadow-hand-drawn flex-shrink-0">
          💡
        </div>
        <div class="bg-paper p-6 rounded-2xl shadow-sm border-2 border-gray-200 flex-1" style="border-color: #cbd5e0;">
          <h3 class="text-2xl font-handwriting font-bold text-pencil mb-2">突发奇想</h3>
          <p class="text-gray-600 font-sketch text-lg">
            随手记录，不筛选，不加工。任何微小的灵感都值得被记住。
          </p>
        </div>
      </div>

      <!-- Arrow -->
      <div class="flex justify-center my-8">
        <div class="text-4xl text-gray-300 font-handwriting transform rotate-12">➜</div>
      </div>

      <!-- Step 2 -->
      <div class="flex items-start gap-6 mb-12" style="margin-left: 2rem;">
        <div class="w-20 h-20 bg-gradient-to-br from-blue-400 to-blue-600 rounded-3xl flex items-center justify-center text-4xl shadow-hand-drawn flex-shrink-0">
          🧪
        </div>
        <div class="bg-paper p-6 rounded-2xl shadow-sm border-2 border-gray-200 flex-1" style="border-color: #cbd5e0;">
          <h3 class="text-2xl font-handwriting font-bold text-pencil mb-2">MVP实验</h3>
          <p class="text-gray-600 font-sketch text-lg">
            用最小的成本验证想法。记录过程，收集反馈，快速迭代。
          </p>
        </div>
      </div>

      <!-- Arrow -->
      <div class="flex justify-center my-8">
        <div class="text-4xl text-gray-300 font-handwriting transform rotate-12">➜</div>
      </div>

      <!-- Step 3 -->
      <div class="flex items-start gap-6" style="margin-left: 2rem;">
        <div class="w-20 h-20 bg-gradient-to-br from-green-400 to-green-600 rounded-3xl flex items-center justify-center text-4xl shadow-hand-drawn flex-shrink-0">
          ✅
        </div>
        <div class="bg-paper p-6 rounded-2xl shadow-sm border-2 border-gray-200 flex-1" style="border-color: #cbd5e0;">
          <h3 class="text-2xl font-handwriting font-bold text-pencil mb-2">已实现 / 已放弃</h3>
          <p class="text-gray-600 font-sketch text-lg">
            形成真正的项目，或者标记为"此路不通"——都是宝贵的资产。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4 bg-paper" style="background-image: radial-gradient(#e2e8f0 1px, transparent 1px);">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl font-handwriting font-bold text-pencil mb-6">
        想看看我最近在想什么？
      </h2>
      <p class="text-lg text-gray-600 font-sketch mb-10 leading-relaxed">
        这里记录了我所有的想法、实验和学习。有的已经落地，有的还在酝酿。
      </p>
      <a href="/ideas" class="btn-sketch bg-gradient-to-r from-marker-blue to-marker-pink text-white no-underline inline-block">
        <span class="text-2xl">📖 开始阅读</span>
      </a>
    </div>
  </section>
</Layout>
