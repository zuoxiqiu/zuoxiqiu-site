---
import Layout from '../layouts/Layout.astro';
---

<Layout title="昨夕秋">
  <!-- 深色主题动态首页 -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);">
    
    <!-- 动态背景粒子 -->
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute w-2 h-2 bg-red-400 rounded-full opacity-30 animate-pulse" style="left: 10%; top: 20%; animation-delay: 0s;"></div>
      <div class="absolute w-3 h-3 bg-yellow-400 rounded-full opacity-20 animate-pulse" style="left: 30%; top: 60%; animation-delay: 1s;"></div>
      <div class="absolute w-2 h-2 bg-blue-400 rounded-full opacity-30 animate-pulse" style="left: 70%; top: 30%; animation-delay: 2s;"></div>
      <div class="absolute w-4 h-4 bg-pink-400 rounded-full opacity-20 animate-pulse" style="left: 80%; top: 70%; animation-delay: 0.5s;"></div>
      <div class="absolute w-2 h-2 bg-green-400 rounded-full opacity-30 animate-pulse" style="left: 50%; top: 80%; animation-delay: 1.5s;"></div>
    </div>
    
    <!-- 渐变光晕 -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full opacity-20" style="background: radial-gradient(circle, #ff6b6b 0%, transparent 70%); filter: blur(80px);"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 rounded-full opacity-20" style="background: radial-gradient(circle, #48dbfb 0%, transparent 70%); filter: blur(80px);"></div>
    
    <div class="relative z-10 max-w-4xl mx-auto text-center px-4">
      <!-- 浮动 Logo -->
      <div class="mb-8" style="animation: float 6s ease-in-out infinite;">
        <span class="text-8xl">🦞</span>
      </div>
      
      <!-- 渐变动画标题 -->
      <h1 class="text-5xl md:text-7xl font-bold mb-6 tracking-tight">
        <span class="bg-gradient-to-r from-red-400 via-yellow-400 to-blue-400 bg-clip-text text-transparent" style="animation: gradient 4s ease infinite;">昨夕秋</span>
      </h1>
      
      <!-- 副标题 -->
      <p class="text-xl md:text-2xl text-gray-300 mb-4 max-w-2xl mx-auto leading-relaxed">
        捕捉昨日的灵感，沉淀今日的思考
      </p>
      
      <p class="text-lg text-gray-400 mb-12 max-w-xl mx-auto">
        一个记录想法、验证实验、积累知识的数字花园
      </p>
      
      <!-- 流动感按钮 -->
      <div class="flex gap-6 justify-center flex-wrap">
        <a href="/ideas" class="group relative px-10 py-5 text-white rounded-full font-semibold text-lg overflow-hidden transition-all duration-300 hover:scale-105" style="background: linear-gradient(90deg, #ff6b6b, #feca57); box-shadow: 0 0 30px rgba(255,107,107,0.4);">
          <span class="relative z-10 flex items-center gap-2">
            <span class="group-hover:animate-bounce">💡</span>
            <span>浏览想法</span>
          </span>
          <div class="absolute inset-0 bg-white opacity-0 group-hover:opacity-20 transition-opacity duration-300"></div>
        </a>
        
        <a href="/mvp" class="group relative px-10 py-5 text-white rounded-full font-semibold text-lg overflow-hidden transition-all duration-300 hover:scale-105" style="background: linear-gradient(90deg, #48dbfb, #ff9ff3); box-shadow: 0 0 30px rgba(72,219,251,0.4);">
          <span class="relative z-10 flex items-center gap-2">
            <span class="group-hover:animate-bounce">🧪</span>
            <span>查看实验</span>
          </span>
          <div class="absolute inset-0 bg-white opacity-0 group-hover:opacity-20 transition-opacity duration-300"></div>
        </a>
      </div>
    </div>
    
    <style>
      @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-20px); }
      }
      @keyframes gradient {
        0%, 100% { filter: hue-rotate(0deg); }
        50% { filter: hue-rotate(30deg); }
      }
    </style>
  </section>

  <!-- 三个卡片 -->
  <section class="py-20 px-4" style="background: linear-gradient(180deg, #0f3460 0%, #16213e 100%);">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-3 gap-8">
        
        <div class="group bg-white/10 backdrop-blur-sm p-8 rounded-2xl border border-white/20 hover:border-red-400/50 transition-all duration-300 hover:-translate-y-2 cursor-pointer">
          <div class="text-5xl mb-6 group-hover:scale-110 transition-transform">💡</div>
          <h3 class="text-2xl font-bold text-white mb-4">突发奇想</h3>
          <p class="text-gray-300 leading-relaxed">随手记录每一个灵感瞬间，不筛选，不加工，让想法自由流动</p>
        </div>
        
        <div class="group bg-white/10 backdrop-blur-sm p-8 rounded-2xl border border-white/20 hover:border-blue-400/50 transition-all duration-300 hover:-translate-y-2 cursor-pointer">
          <div class="text-5xl mb-6 group-hover:scale-110 transition-transform">🧪</div>
          <h3 class="text-2xl font-bold text-white mb-4">MVP实验</h3>
          <p class="text-gray-300 leading-relaxed">把想法变成最小可行产品，验证可行性，快速迭代</p>
        </div>
        
        <div class="group bg-white/10 backdrop-blur-sm p-8 rounded-2xl border border-white/20 hover:border-pink-400/50 transition-all duration-300 hover:-translate-y-2 cursor-pointer">
          <div class="text-5xl mb-6 group-hover:scale-110 transition-transform">📝</div>
          <h3 class="text-2xl font-bold text-white mb-4">知识沉淀</h3>
          <p class="text-gray-300 leading-relaxed">日积月累，零散的想法汇聚成庞大的个人知识资产</p>
        </div>
        
      </div>
    </div>
  </section>

  <!-- 理念介绍 -->
  <section class="py-20 px-4" style="background: #16213e;">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-white mb-6">为什么叫昨夕秋？</h2>
      <p class="text-gray-300 mb-6 leading-relaxed">
        <strong class="text-red-400">昨</strong>日的思考，<strong class="text-yellow-400">夕</strong>阳的沉淀，<strong class="text-blue-400">秋</strong>收的积累。
      </p>
      <p class="text-gray-400 leading-relaxed">
        这是一个数字花园——用来种想法、养实验、收知识的地方。不追求完美，只求真实。
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-4" style="background: linear-gradient(135deg, #16213e 0%, #1a1a2e 100%);">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-white mb-6">想看看我最近在想什么？</h2>
      <a href="/ideas" class="inline-block px-10 py-5 text-white rounded-full font-semibold text-lg transition-all duration-300 hover:scale-105" style="background: linear-gradient(90deg, #ff6b6b, #feca57, #48dbfb); background-size: 200% auto; animation: gradient 3s ease infinite;">
        📖 开始阅读
      </a>
    </div>
    <style>
      @keyframes gradient {
        0% { background-position: 0% center; }
        100% { background-position: 200% center; }
      }
    </style>
  </section>
</Layout>
