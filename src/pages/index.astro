---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const ideas = (await getCollection('ideas')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const mvps = (await getCollection('mvp')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const thinking = (await getCollection('thinking')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const formatDate = (date: Date) => date.toISOString().slice(0, 10).replaceAll('-', '.');

const allPosts = [
  ...thinking.map((post) => ({ ...post, type: 'thinking', typeLabel: '思考' })),
  ...ideas.map((post) => ({ ...post, type: 'ideas', typeLabel: '想法' })),
  ...mvps.map((post) => ({ ...post, type: 'mvp', typeLabel: '实验' })),
]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const collections = [
  { href: '/thinking', label: '思考', count: thinking.length },
  { href: '/ideas', label: '想法', count: ideas.length },
  { href: '/mvp', label: '实验', count: mvps.length },
];
---

<Layout
  title="昨夕秋"
  description="昨夕秋的数字花园，记录思考、想法与实验。"
>
  <div class="home-root">
    <section class="page-wrap home-intro" aria-labelledby="home-title">
      <div class="home-heading">
        <p class="home-eyebrow">Zuo Xiqiu / Digital notes</p>
        <h1 id="home-title"><span>昨夕秋</span></h1>
      </div>

      <div class="home-intro-footer">
        <p class="home-statement">记录看见、理解与改变。</p>

        <nav class="home-collections" aria-label="内容分类">
          {collections.map((item, index) => (
            <a href={item.href}>
              <span class="collection-index">0{index + 1}</span>
              <strong>{item.label}</strong>
              <span class="collection-count">{String(item.count).padStart(2, '0')}</span>
            </a>
          ))}
        </nav>
      </div>
    </section>

    <section class="page-wrap home-recent reveal" aria-labelledby="recent-title">
      <header class="recent-heading">
        <div>
          <p class="home-eyebrow">Recently published</p>
          <h2 id="recent-title">最近</h2>
        </div>
        <p>{String(allPosts.length).padStart(2, '0')} entries</p>
      </header>

      <ol class="entry-list">
        {allPosts.map((post, index) => (
          <li style={`--row: ${index}`}>
            <a href={`/${post.type}/${post.id}`} class="entry-row">
              <span class="entry-number">{String(index + 1).padStart(2, '0')}</span>
              <span class="entry-type">{post.typeLabel}</span>
              <h3>{post.data.title}</h3>
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              <span class="entry-arrow" aria-hidden="true">↗</span>
            </a>
          </li>
        ))}
      </ol>
    </section>
  </div>
</Layout>

<style>
  .home-root {
    --home-line: rgba(24, 20, 17, 0.14);
  }

  .home-intro {
    position: relative;
    display: flex;
    min-height: min(78rem, calc(100svh - 5.5rem));
    flex-direction: column;
    justify-content: space-between;
    padding-top: clamp(5rem, 10vh, 8.5rem);
    padding-bottom: clamp(2.5rem, 5vh, 4rem);
    border-bottom: 1px solid var(--home-line);
  }

  .home-heading {
    display: grid;
    gap: clamp(1rem, 2vw, 1.8rem);
  }

  .home-eyebrow {
    font-family: var(--mono);
    font-size: 0.66rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--soft);
  }

  .home-heading .home-eyebrow {
    opacity: 0;
    animation: home-fade-in 900ms 120ms var(--ease-out) forwards;
  }

  .home-heading h1 {
    overflow: hidden;
    margin: 0;
    font-size: clamp(6.6rem, 17.5vw, 13rem);
    line-height: 0.78;
    letter-spacing: 0.035em;
  }

  .home-heading h1 span {
    display: block;
    transform: translateY(108%);
    animation: home-title-in 1.15s 80ms var(--ease-out) forwards;
  }

  .home-intro-footer {
    display: grid;
    grid-template-columns: minmax(14rem, 0.72fr) minmax(28rem, 1.28fr);
    gap: clamp(2rem, 6vw, 7rem);
    align-items: end;
  }

  .home-statement {
    max-width: 16ch;
    font-family: var(--display);
    font-size: clamp(1.7rem, 3vw, 2.5rem);
    line-height: 1.2;
    letter-spacing: -0.025em;
    opacity: 0;
    animation: home-fade-in 900ms 420ms var(--ease-out) forwards;
  }

  .home-collections {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid var(--home-line);
    opacity: 0;
    animation: home-fade-in 900ms 560ms var(--ease-out) forwards;
  }

  .home-collections a {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.65rem;
    align-items: baseline;
    padding: 1rem 0.95rem 0.9rem;
    border-bottom: 1px solid var(--home-line);
    transition:
      color 500ms var(--ease-out),
      background-color 500ms var(--ease-out),
      padding 500ms var(--ease-out);
  }

  .home-collections a + a {
    border-left: 1px solid var(--home-line);
  }

  .home-collections a:hover {
    padding-inline: 1.15rem 0.75rem;
    color: var(--forest);
    background: rgba(255, 255, 255, 0.24);
  }

  .collection-index,
  .collection-count {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    color: var(--soft);
  }

  .home-collections strong {
    font-family: var(--display);
    font-size: 1.2rem;
    font-weight: 600;
  }

  .home-recent {
    padding-top: clamp(6rem, 11vw, 10rem);
    padding-bottom: clamp(6rem, 11vw, 10rem);
  }

  .recent-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }

  .recent-heading > div {
    display: grid;
    gap: 0.8rem;
  }

  .recent-heading h2 {
    font-size: clamp(3.8rem, 8vw, 7rem);
    line-height: 0.82;
  }

  .recent-heading > p {
    font-family: var(--mono);
    font-size: 0.64rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--soft);
  }

  .entry-list {
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--home-line);
    list-style: none;
  }

  .entry-list li {
    opacity: 0;
    transform: translateY(14px);
    transition:
      opacity 750ms var(--ease-out),
      transform 750ms var(--ease-out);
    transition-delay: calc(var(--row) * 65ms + 120ms);
  }

  .home-recent.is-visible .entry-list li {
    opacity: 1;
    transform: translateY(0);
  }

  .entry-row {
    display: grid;
    grid-template-columns: 2.5rem 4.5rem minmax(0, 1fr) auto 1.5rem;
    gap: 1rem;
    align-items: center;
    min-height: 6.4rem;
    border-bottom: 1px solid var(--home-line);
    transition:
      background-color 500ms var(--ease-out),
      padding 500ms var(--ease-out);
  }

  .entry-row:hover {
    padding-inline: 0.8rem;
    background: rgba(255, 255, 255, 0.26);
  }

  .entry-number,
  .entry-type,
  .entry-row time {
    font-family: var(--mono);
    font-size: 0.64rem;
    letter-spacing: 0.1em;
    color: var(--soft);
  }

  .entry-type {
    color: var(--forest-soft);
  }

  .entry-row h3 {
    overflow: hidden;
    font-size: clamp(1.45rem, 2.8vw, 2.25rem);
    line-height: 1.08;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: transform 500ms var(--ease-out);
  }

  .entry-row:hover h3 {
    transform: translateX(0.35rem);
  }

  .entry-arrow {
    font-size: 1.05rem;
    color: var(--soft);
    transition:
      color 500ms var(--ease-out),
      transform 500ms var(--ease-out);
  }

  .entry-row:hover .entry-arrow {
    color: var(--ink);
    transform: translate(0.15rem, -0.15rem);
  }

  @keyframes home-title-in {
    to {
      transform: translateY(0);
    }
  }

  @keyframes home-fade-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 860px) {
    .home-intro {
      min-height: calc(100svh - 3rem);
    }

    .home-intro-footer {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .home-statement {
      max-width: none;
    }

    .entry-row {
      grid-template-columns: 2rem 3.5rem minmax(0, 1fr) 1.2rem;
    }

    .entry-row time {
      display: none;
    }
  }

  @media (max-width: 620px) {
    .home-intro {
      min-height: 78svh;
      padding-top: 4.5rem;
    }

    .home-heading h1 {
      font-size: 22vw;
      line-height: 0.84;
      letter-spacing: 0.02em;
    }

    .home-collections {
      grid-template-columns: 1fr;
    }

    .home-collections a + a {
      border-left: 0;
    }

    .recent-heading {
      align-items: start;
    }

    .entry-row {
      grid-template-columns: 1.8rem minmax(0, 1fr) 1rem;
      gap: 0.8rem;
      min-height: 5.6rem;
    }

    .entry-type {
      display: none;
    }

    .entry-row h3 {
      font-size: 1.45rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-heading .home-eyebrow,
    .home-heading h1 span,
    .home-statement,
    .home-collections,
    .entry-list li {
      opacity: 1;
      transform: none;
      animation: none;
      transition: none;
    }
  }
</style>
