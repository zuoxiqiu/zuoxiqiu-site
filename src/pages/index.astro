---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getExcerpt } from '../utils/content';

const ideas = (await getCollection('ideas')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const mvps = (await getCollection('mvp')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const thinking = (await getCollection('thinking')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const formatDate = (date: Date) => date.toISOString().slice(0, 10).replaceAll('-', '.');

const allPosts = [
  ...thinking.map((post) => ({ ...post, type: 'thinking', typeLabel: '思考' })),
  ...ideas.map((post) => ({ ...post, type: 'ideas', typeLabel: '想法' })),
  ...mvps.map((post) => ({ ...post, type: 'mvp', typeLabel: '实验' })),
]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 7);

const latestPost = allPosts[0];
const recentPosts = allPosts.slice(1);
const collections = [
  { href: '/thinking', label: '思考', english: 'Thinking', count: thinking.length },
  { href: '/ideas', label: '想法', english: 'Ideas', count: ideas.length },
  { href: '/mvp', label: '实验', english: 'Experiments', count: mvps.length },
];
---

<Layout title="昨夕秋" description="昨夕秋的数字花园，记录思考、想法与实验。">
  <div class="opening-sequence" aria-hidden="true">
    <div class="opening-meta">
      <span>Zuoxi Qiu</span>
      <span>Digital garden · 2026</span>
    </div>
    <div class="opening-center">
      <span class="opening-number">01</span>
      <p>昨夕秋</p>
      <i></i>
    </div>
    <div class="opening-foot">
      <span>Thinking</span>
      <span>Ideas</span>
      <span>Experiments</span>
    </div>
  </div>

  <div class="scroll-meter" aria-hidden="true">
    <span class="scroll-meter-label">Scroll</span>
    <i><b></b></i>
    <span class="scroll-meter-value">00</span>
  </div>

  <div class="editorial-home">
    <section class="page-wrap editorial-hero" aria-labelledby="latest-title">
      <header class="issue-line">
        <span>昨夕秋 · 数字花园</span>
        <span>Vol. 01</span>
        <span>{latestPost ? formatDate(latestPost.data.date) : '2026'}</span>
      </header>

      {latestPost && (
        <div class="feature-grid">
          <div class="feature-index" aria-hidden="true">
            <span>01</span>
            <i></i>
          </div>

          <a href={`/${latestPost.type}/${latestPost.id}`} class="feature-story">
            <div class="feature-label">
              <span>最新文章</span>
              <span>{latestPost.typeLabel}</span>
            </div>
            <h1 id="latest-title">{latestPost.data.title}</h1>
            <div class="feature-link">
              <span>阅读文章</span>
              <span aria-hidden="true">↗</span>
            </div>
          </a>

          <aside class="feature-deck">
            <p>{latestPost.data.summary ?? getExcerpt(latestPost.body, 92)}</p>
            <div class="feature-signature">
              <span>Latest note</span>
              <time datetime={latestPost.data.date.toISOString()}>
                {formatDate(latestPost.data.date)}
              </time>
            </div>
          </aside>
        </div>
      )}

      <nav class="section-index" aria-label="内容分类">
        {collections.map((item, index) => (
          <a href={item.href}>
            <span class="section-number">0{index + 1}</span>
            <span class="section-name">
              <strong>{item.label}</strong>
              <small>{item.english}</small>
            </span>
            <span class="section-count">{String(item.count).padStart(2, '0')}</span>
          </a>
        ))}
      </nav>
    </section>

    <section class="page-wrap archive-section reveal" aria-labelledby="archive-title">
      <header class="archive-header">
        <div>
          <span>02</span>
          <p>Archive / 最近发布</p>
        </div>
        <h2 id="archive-title">最近</h2>
      </header>

      <ol class="archive-list">
        {recentPosts.map((post, index) => (
          <li style={`--row: ${index}; --row-start: ${index % 2 === 0 ? '18px' : '-18px'}`}>
            <a href={`/${post.type}/${post.id}`}>
              <span class="archive-number">{String(index + 2).padStart(2, '0')}</span>
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              <h3>{post.data.title}</h3>
              <span class="archive-type">{post.typeLabel}</span>
              <span class="archive-arrow" aria-hidden="true">↗</span>
            </a>
          </li>
        ))}
      </ol>
    </section>
  </div>
</Layout>

<style>
  .editorial-home {
    --editorial-line: rgba(24, 20, 17, 0.2);
    --editorial-accent: #bd3f1f;
    --title-shift: 0px;
    --index-shift: 0px;
    --deck-shift: 0px;
    --wheel-pull: 0px;
  }

  .opening-sequence {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: clamp(1.5rem, 3vw, 2.75rem);
    color: #f8f4eb;
    background: #191612;
    pointer-events: none;
    transform-origin: top;
    animation: opening-exit 850ms 1250ms cubic-bezier(0.76, 0, 0.24, 1) forwards;
  }

  .opening-meta,
  .opening-foot {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    font-family: var(--mono);
    font-size: clamp(0.68rem, 1vw, 0.78rem);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0;
    animation: opening-fade 600ms 100ms var(--ease-out) forwards;
  }

  .opening-center {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .opening-center p {
    font-family: var(--display);
    font-size: clamp(5.8rem, 17vw, 15rem);
    line-height: 1.08;
    letter-spacing: -0.06em;
    opacity: 0;
    transform: translateY(28px);
    animation: opening-title 800ms 260ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .opening-number {
    position: absolute;
    top: 11%;
    left: 0;
    font-family: var(--display);
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 1;
    color: #d44b2a;
    opacity: 0;
    animation: opening-fade 500ms 420ms var(--ease-out) forwards;
  }

  .opening-center i {
    position: absolute;
    right: 0;
    bottom: 13%;
    width: min(24vw, 18rem);
    height: 2px;
    background: #d44b2a;
    transform: scaleX(0);
    transform-origin: right;
    animation: opening-rule 750ms 470ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .opening-foot {
    justify-content: flex-start;
  }

  .opening-foot span + span::before {
    content: '/';
    margin-right: 2rem;
    color: #d44b2a;
  }

  .scroll-meter {
    position: fixed;
    top: 50%;
    right: max(0.7rem, calc((100vw - var(--content-max)) / 2 - 2.1rem));
    z-index: 45;
    display: grid;
    justify-items: center;
    gap: 0.75rem;
    color: var(--soft);
    transform: translateY(-50%);
    opacity: 0;
    animation: meter-in 700ms 1900ms var(--ease-out) forwards;
  }

  .scroll-meter-label,
  .scroll-meter-value {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .scroll-meter-label {
    writing-mode: vertical-rl;
  }

  .scroll-meter > i {
    position: relative;
    display: block;
    width: 1px;
    height: min(26vh, 13rem);
    overflow: hidden;
    background: rgba(24, 20, 17, 0.15);
  }

  .scroll-meter b {
    position: absolute;
    inset: 0;
    display: block;
    background: var(--editorial-accent);
    transform: scaleY(var(--scroll-progress, 0));
    transform-origin: top;
    transition: transform 80ms linear;
  }

  .editorial-hero {
    padding-top: clamp(2.8rem, 5vw, 4.5rem);
  }

  .issue-line {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 2rem;
    padding: 0 0 1rem;
    border-bottom: 2px solid var(--ink);
    font-size: 0.84rem;
    letter-spacing: 0.06em;
    opacity: 0;
    transform: translateY(12px);
    animation: editorial-in 700ms 1580ms var(--ease-out) forwards;
  }

  .issue-line span:nth-child(2),
  .issue-line span:nth-child(3) {
    font-family: var(--mono);
    color: var(--muted);
  }

  .feature-grid {
    display: grid;
    grid-template-columns: minmax(7rem, 0.17fr) minmax(0, 0.55fr) minmax(17rem, 0.28fr);
    min-height: clamp(30rem, 63vh, 46rem);
    border-bottom: 1px solid var(--editorial-line);
  }

  .feature-index {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(2rem, 4vw, 3.5rem) 1.5rem clamp(2rem, 4vw, 3rem) 0;
    border-right: 1px solid var(--editorial-line);
    color: var(--editorial-accent);
    opacity: 0;
    animation: editorial-in 650ms 1660ms var(--ease-out) forwards;
  }

  .feature-index span {
    font-family: var(--display);
    font-size: clamp(4rem, 7vw, 6.5rem);
    line-height: 1;
    transform: translate3d(0, var(--index-shift), 0);
    transition: transform 120ms linear;
  }

  .feature-index i {
    width: 0.85rem;
    height: 0.85rem;
    background: currentColor;
    transform: translate3d(0, var(--wheel-pull), 0);
    transition: transform 80ms linear;
  }

  .feature-story {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
    padding: clamp(2rem, 4vw, 3.5rem);
    border-right: 1px solid var(--editorial-line);
    opacity: 0;
    animation: editorial-in 700ms 1740ms var(--ease-out) forwards;
  }

  .feature-label,
  .feature-signature {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.9rem;
    color: var(--muted);
  }

  .feature-label span:first-child {
    color: var(--editorial-accent);
  }

  .feature-story h1 {
    margin: auto 0;
    font-size: clamp(5rem, 11vw, 9rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    overflow: visible;
    transform: translate3d(var(--title-shift), var(--wheel-pull), 0);
    transition:
      color 400ms var(--ease-out),
      transform 100ms linear;
  }

  .feature-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    border-top: 1px solid var(--editorial-line);
    font-size: 1.05rem;
  }

  .feature-story:hover h1 {
    color: var(--editorial-accent);
  }

  .feature-deck {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 3rem;
    padding: clamp(2rem, 4vw, 3.5rem) 0 clamp(2rem, 4vw, 3rem) clamp(2rem, 4vw, 3rem);
    opacity: 0;
    animation: editorial-in 700ms 1820ms var(--ease-out) forwards;
  }

  .feature-deck > p {
    margin-top: auto;
    font-size: clamp(1.08rem, 1.5vw, 1.3rem);
    line-height: 1.85;
    color: var(--muted);
    transform: translate3d(0, var(--deck-shift), 0);
    transition: transform 120ms linear;
  }

  .feature-signature {
    padding-top: 1rem;
    border-top: 1px solid var(--editorial-line);
    font-family: var(--mono);
    font-size: 0.78rem;
  }

  .section-index {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-bottom: 2px solid var(--ink);
  }

  .section-index a {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    align-items: center;
    min-height: 7.5rem;
    padding: 1.2rem 1.4rem;
    transition:
      color 400ms var(--ease-out),
      background-color 400ms var(--ease-out),
      transform 500ms var(--ease-out);
  }

  .section-index a + a {
    border-left: 1px solid var(--editorial-line);
  }

  .section-index a:hover {
    color: #fffaf3;
    background: var(--ink);
    transform: translateY(-0.25rem);
  }

  .section-number,
  .section-count {
    font-family: var(--mono);
    font-size: 0.82rem;
    color: var(--soft);
  }

  .section-name {
    display: grid;
    gap: 0.15rem;
  }

  .section-name strong {
    font-family: var(--display);
    font-size: 1.65rem;
    line-height: 1;
  }

  .section-name small {
    font-size: 0.78rem;
    color: var(--soft);
  }

  .archive-section {
    padding-top: clamp(7rem, 12vw, 11rem);
    padding-bottom: clamp(7rem, 12vw, 11rem);
  }

  .archive-header {
    display: grid;
    grid-template-columns: minmax(10rem, 0.28fr) 1fr;
    align-items: end;
    gap: 2rem;
    padding-bottom: clamp(2rem, 4vw, 3rem);
    border-bottom: 2px solid var(--ink);
  }

  .archive-header > div {
    display: grid;
    gap: 0.7rem;
  }

  .archive-header span {
    font-family: var(--display);
    font-size: 3.6rem;
    line-height: 1;
    color: var(--editorial-accent);
  }

  .archive-header p {
    font-size: 0.88rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .archive-header h2 {
    font-size: clamp(4.8rem, 9vw, 7.8rem);
    line-height: 0.95;
  }

  .archive-list {
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .archive-list li {
    opacity: 0;
    transform: translate3d(var(--row-start), 18px, 0);
    transition:
      opacity 700ms var(--ease-out),
      transform 700ms var(--ease-out);
    transition-delay: calc(var(--row) * 55ms + 100ms);
  }

  .archive-section.is-visible .archive-list li {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .archive-list a {
    display: grid;
    grid-template-columns: 3rem 7.2rem minmax(0, 1fr) 3.5rem 1.5rem;
    gap: 1rem;
    align-items: center;
    min-height: 7.3rem;
    border-bottom: 1px solid var(--editorial-line);
    transition:
      color 400ms var(--ease-out),
      padding 400ms var(--ease-out);
  }

  .archive-list a:hover {
    padding-inline: 0.8rem;
    color: var(--editorial-accent);
  }

  .archive-number,
  .archive-list time,
  .archive-type {
    font-size: 0.84rem;
    color: var(--soft);
  }

  .archive-list time {
    font-family: var(--mono);
  }

  .archive-list h3 {
    overflow: hidden;
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    line-height: 1.1;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .archive-arrow {
    font-size: 1.1rem;
  }

  @keyframes editorial-in {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes opening-fade {
    to {
      opacity: 1;
    }
  }

  @keyframes opening-title {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes opening-rule {
    to {
      transform: scaleX(1);
    }
  }

  @keyframes opening-exit {
    0% {
      clip-path: inset(0 0 0 0);
    }
    99% {
      clip-path: inset(0 0 100% 0);
    }
    100% {
      visibility: hidden;
      clip-path: inset(0 0 100% 0);
    }
  }

  @keyframes meter-in {
    to {
      opacity: 1;
    }
  }

  @media (max-width: 900px) {
    .scroll-meter {
      display: none;
    }

    .feature-grid {
      grid-template-columns: 6rem minmax(0, 1fr);
      min-height: auto;
    }

    .feature-index {
      grid-row: span 2;
    }

    .feature-story {
      min-height: 27rem;
      border-right: 0;
    }

    .feature-deck {
      grid-column: 2;
      padding: 2rem 0 2.5rem 2.5rem;
      border-top: 1px solid var(--editorial-line);
    }

    .section-index a {
      min-height: 6.8rem;
    }

    .archive-list a {
      grid-template-columns: 2.5rem minmax(0, 1fr) 3rem 1.2rem;
    }

    .archive-list time {
      display: none;
    }
  }

  @media (max-width: 620px) {
    .opening-sequence {
      padding: 1.4rem 1.2rem;
    }

    .opening-center {
      align-items: flex-start;
      padding-top: 25vh;
    }

    .opening-center p {
      font-size: clamp(5.4rem, 28vw, 7rem);
    }

    .opening-number {
      top: 10%;
    }

    .opening-center i {
      bottom: 18%;
      width: 32vw;
    }

    .opening-meta span:last-child {
      display: none;
    }

    .opening-foot {
      gap: 0.8rem;
    }

    .opening-foot span + span::before {
      margin-right: 0.8rem;
    }

    .issue-line {
      grid-template-columns: 1fr auto;
      font-size: 0.78rem;
    }

    .issue-line span:nth-child(2) {
      display: none;
    }

    .feature-grid {
      grid-template-columns: 1fr;
    }

    .feature-index {
      grid-row: auto;
      flex-direction: row;
      align-items: center;
      padding: 1.6rem 0;
      border-right: 0;
      border-bottom: 1px solid var(--editorial-line);
    }

    .feature-index span {
      font-size: 3.5rem;
    }

    .feature-story {
      min-height: 24rem;
      padding: 2.2rem 0;
      border-bottom: 1px solid var(--editorial-line);
    }

    .feature-story h1 {
      font-size: clamp(5rem, 26vw, 6.4rem);
    }

    .feature-deck {
      grid-column: 1;
      padding: 2rem 0 2.4rem;
      border-top: 0;
    }

    .section-index {
      grid-template-columns: 1fr;
    }

    .section-index a + a {
      border-top: 1px solid var(--editorial-line);
      border-left: 0;
    }

    .section-index a {
      min-height: 6.2rem;
      padding-inline: 0;
    }

    .archive-header {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .archive-header h2 {
      font-size: 5.2rem;
    }

    .archive-list a {
      grid-template-columns: 2.2rem minmax(0, 1fr) 1.2rem;
      min-height: 6.5rem;
    }

    .archive-type {
      display: none;
    }

    .archive-list h3 {
      font-size: 1.65rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .opening-sequence,
    .scroll-meter {
      display: none;
    }

    .issue-line,
    .feature-index,
    .feature-story,
    .feature-deck,
    .archive-list li {
      opacity: 1;
      transform: none;
      animation: none;
      transition: none;
    }

    .feature-index span,
    .feature-index i,
    .feature-story h1,
    .feature-deck > p {
      transform: none;
      transition: none;
    }
  }
</style>

<script is:inline>
  (() => {
    const home = document.querySelector('.editorial-home');
    const hero = document.querySelector('.editorial-hero');
    const meter = document.querySelector('.scroll-meter');
    const meterValue = document.querySelector('.scroll-meter-value');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!home || !hero || reduceMotion) return;

    let frame = 0;
    let wheelFrame = 0;
    let wheelPull = 0;

    const renderScroll = () => {
      const maxScroll = Math.max(document.documentElement.scrollHeight - window.innerHeight, 1);
      const pageProgress = Math.min(Math.max(window.scrollY / maxScroll, 0), 1);
      const heroProgress = Math.min(Math.max(window.scrollY / Math.max(hero.offsetHeight, 1), 0), 1);

      document.documentElement.style.setProperty('--scroll-progress', pageProgress.toFixed(4));
      home.style.setProperty('--title-shift', `${(heroProgress * 30).toFixed(2)}px`);
      home.style.setProperty('--index-shift', `${(heroProgress * -24).toFixed(2)}px`);
      home.style.setProperty('--deck-shift', `${(heroProgress * -18).toFixed(2)}px`);

      if (meterValue) meterValue.textContent = String(Math.round(pageProgress * 100)).padStart(2, '0');
      if (meter) meter.classList.toggle('is-active', pageProgress > 0.01);
      frame = 0;
    };

    const requestScrollRender = () => {
      if (!frame) frame = requestAnimationFrame(renderScroll);
    };

    const settleWheel = () => {
      wheelPull *= 0.78;
      home.style.setProperty('--wheel-pull', `${wheelPull.toFixed(2)}px`);

      if (Math.abs(wheelPull) > 0.08) {
        wheelFrame = requestAnimationFrame(settleWheel);
      } else {
        wheelPull = 0;
        home.style.setProperty('--wheel-pull', '0px');
        wheelFrame = 0;
      }
    };

    window.addEventListener('scroll', requestScrollRender, { passive: true });
    window.addEventListener(
      'wheel',
      (event) => {
        wheelPull = Math.max(-9, Math.min(9, event.deltaY * 0.045));
        if (!wheelFrame) wheelFrame = requestAnimationFrame(settleWheel);
      },
      { passive: true }
    );
    window.addEventListener('resize', requestScrollRender, { passive: true });

    renderScroll();
  })();
</script>
