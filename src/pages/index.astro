---
import Layout from '../layouts/Layout.astro';
---

<Layout title="昨夕秋">
  <!-- 深蓝高级风 -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden" style="background: #0a1628;">
    
    <!-- 微妙光晕 -->
    <div class="absolute top-1/3 left-1/3 w-[600px] h-[600px] rounded-full opacity-30" style="background: radial-gradient(circle, #1e3a5f 0%, transparent 70%); filter: blur(100px);"></div>
    <div class="absolute bottom-1/3 right-1/3 w-[500px] h-[500px] rounded-full opacity-20" style="background: radial-gradient(circle, #2d5a87 0%, transparent 70%); filter: blur(120px);"></div>
    
    <div class="relative z-10 max-w-4xl mx-auto text-center px-6">
      <!-- Logo -->
      <div class="mb-8">
        <span class="text-5xl">🦞</span>
      </div>
      
      <!-- 主标题 -->
      <h1 class="text-7xl md:text-9xl font-light text-white mb-8 tracking-tight" style="font-family: 'SF Pro Display', -apple-system, sans-serif; letter-spacing: 0.05em;">
        昨夕秋
      </h1>
      
      <!-- 副标题 -->
      <p class="text-base text-slate-400 mb-16 tracking-wide" style="font-family: 'SF Pro Text', -apple-system, sans-serif;">
        捕捉昨日的灵感，沉淀今日的思考
      </p>
      
      <!-- 按钮 -->
      <div class="flex gap-4 justify-center">
        <a href="/ideas" class="px-8 py-3 bg-white text-slate-900 text-sm font-medium rounded-full transition-all hover:bg-slate-100">
          浏览想法
        </a>
        <a href="/mvp" class="px-8 py-3 border border-slate-600 text-slate-300 text-sm font-medium rounded-full transition-all hover:border-slate-400 hover:text-white">
          查看实验
        </a>
      </div>
    </div>
  </section>

  <!-- 三个板块 -->
  <section class="py-24 px-6" style="background: #0d1d33;">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-3 gap-6">
        
        <div class="p-8 rounded-2xl transition-all" style="background: rgba(30, 58, 95, 0.3); border: 1px solid rgba(100, 130, 170, 0.2);">
          <div class="text-2xl mb-4">💡</div>
          <h3 class="text-white text-base font-medium mb-2">突发奇想</h3>
          <p class="text-slate-400 text-sm">随手记录灵感瞬间</p>
        </div>
        
        <div class="p-8 rounded-2xl transition-all" style="background: rgba(30, 58, 95, 0.3); border: 1px solid rgba(100, 130, 170, 0.2);">
          <div class="text-2xl mb-4">🧪</div>
          <h3 class="text-white text-base font-medium mb-2">MVP实验</h3>
          <p class="text-slate-400 text-sm">验证想法可行性</p>
        </div>
        
        <div class="p-8 rounded-2xl transition-all" style="background: rgba(30, 58, 95, 0.3); border: 1px solid rgba(100, 130, 170, 0.2);">
          <div class="text-2xl mb-4">📝</div>
          <h3 class="text-white text-base font-medium mb-2">知识沉淀</h3>
          <p class="text-slate-400 text-sm">日积月累成资产</p>
        </div>
        
      </div>
    </div>
  </section>

  <!-- Footer -->
  <section class="py-16 px-6 text-center" style="background: #0a1628; border-top: 1px solid rgba(100, 130, 170, 0.1);">
    <p class="text-slate-500 text-xs tracking-widest">昨 · 夕 · 秋</p>
  </section>
</Layout>
