---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const ideas = await getCollection('ideas');
  return ideas.map((idea) => ({
    params: { slug: idea.id.replace(/.md$/, '') },
    props: { idea },
  }));
}

const { idea } = Astro.props;
const { Content } = await render(idea);

const statusLabels: Record<string, string> = {
  raw: '💡 突发奇想',
  thinking: '🤔 在思考',
  testing: '🧪 验证中',
  done: '✅ 已实现',
  abandoned: '❌ 已放弃',
};
---

<Layout title={idea.data.title}>
  <article class="article-wrap">
    <div class="article-meta">
      <div class="article-tags">
        {idea.data.tags.map((tag: string) => (
          <span class="tag">#{tag}</span>
        ))}
      </div>
      <div class="article-status">{statusLabels[idea.data.status]}</div>
    </div>

    <h1 class="article-title">{idea.data.title}</h1>

    <time class="article-date">{idea.data.date.toISOString().slice(0, 10)}</time>

    <div class="divider"><div class="divider-dot"></div></div>

    <div class="prose article-content">
      <Content />
    </div>

    <div class="article-back">
      <a href="/ideas">← 想法</a>
    </div>
  </article>
</Layout>

<style>
  .article-wrap {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 2rem 8rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .article-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
  }

  .article-status {
    font-size: 0.75rem;
    color: var(--accent);
  }

  .article-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0.02em;
    color: var(--ink);
  }

  .article-date {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    color: var(--faint);
    letter-spacing: 0.2em;
    display: block;
    margin-top: 1.5rem;
  }

  .article-content {
    margin-top: 3rem;
  }

  .article-back {
    margin-top: 4rem;
  }

  .article-back a {
    font-size: 0.85rem;
    color: var(--muted);
  }

  .article-back a:hover {
    color: var(--accent);
  }
</style>
