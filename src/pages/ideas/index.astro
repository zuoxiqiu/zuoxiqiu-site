---
import Layout from '../../layouts/Layout.astro';

const ideas = [
  {
    title: "AI Agent 的下一个风口",
    date: "2026-03-13",
    tags: ["AI", "创业"],
    status: "raw",
    excerpt: "GitHub Trending 上的 Agent 项目正在爆发..."
  },
  {
    title: "个人知识库的自动化",
    date: "2026-03-12",
    tags: ["工具", "效率"],
    status: "thinking",
    excerpt: "如何让碎片化的想法自动组织成知识体系..."
  }
];

const statusLabels = {
  raw: { text: "突发奇想", class: "bg-gray-100 text-gray-700" },
  thinking: { text: "在思考", class: "bg-stone text-gray-600" },
  testing: { text: "验证中", class: "bg-gray-200 text-gray-800" },
  done: { text: "已实现", class: "bg-gray-900 text-white" },
  abandoned: { text: "已放弃", class: "bg-white border border-gray-300" }
};
---

<Layout title="想法流">
  <div class="max-w-4xl mx-auto">
    <div class="mb-16">
      <h1 class="text-4xl font-serif font-semibold mb-4">想法流</h1>
      <p class="text-gray-600 font-sans text-lg leading-relaxed">
        随手记录，不加工，不筛选。<br>
        每一个粗糙的想法，都可能长出意想不到的花。
      </p>
    </div>

    <!-- Filters -->
    <div class="flex gap-3 mb-10 overflow-x-auto pb-2">
      <button class="px-5 py-2.5 bg-ink text-white text-sm font-medium transition hover:bg-gray-800">全部</button>
      <button class="px-5 py-2.5 bg-white border border-gray-200 text-gray-600 text-sm font-medium hover:border-ink hover:text-ink transition">AI</button>
      <button class="px-5 py-2.5 bg-white border border-gray-200 text-gray-600 text-sm font-medium hover:border-ink hover:text-ink transition">创业</button>
      <button class="px-5 py-2.5 bg-white border border-gray-200 text-gray-600 text-sm font-medium hover:border-ink hover:text-ink transition">工具</button>
      <button class="px-5 py-2.5 bg-white border border-gray-200 text-gray-600 text-sm font-medium hover:border-ink hover:text-ink transition">生活</button>
    </div>

    <!-- Ideas List -->
    <div class="space-y-8">
      {ideas.map((idea) => (
        <article class="bg-white p-8 shadow-soft group hover:shadow-lg transition-all duration-300" style="border: 1px solid rgba(0,0,0,0.04); border-radius: 16px;">
          <div class="flex items-start justify-between mb-5">
            <div class="flex gap-2 flex-wrap">
              {idea.tags.map((tag) => (
                <span class="px-3 py-1 bg-stone text-gray-600 text-xs font-medium rounded-full">
                  #{tag}
                </span>
              ))}
            </div>
            <span class={`px-3 py-1.5 rounded-full text-xs font-medium ${statusLabels[idea.status].class}`}>
              {statusLabels[idea.status].text}
            </span>
          </div>
          
          <h2 class="text-2xl font-serif font-semibold mb-3 group-hover:underline cursor-pointer">
            {idea.title}
          </h2>
          
          <p class="text-gray-600 font-sans leading-relaxed mb-4">
            {idea.excerpt}
          </p>
          
          <div class="flex items-center justify-between text-sm text-gray-400">
            <time>{idea.date}</time>
            <span class="text-gray-300">|</span>
            <span class="font-sans">阅读全文</span>
          </div>
        </article>
      ))}
    </div>

    {/* Empty State */}
    {ideas.length === 0 && (
      <div class="text-center py-24">
        <div class="text-7xl mb-8 opacity-20">📭</div>
        <h3 class="text-2xl font-serif font-semibold mb-3">还没有想法</h3>
        <p class="text-gray-600 mb-6 font-sans">开始记录你的第一个灵感吧</p>
        <div class="inline-block bg-stone px-6 py-4 rounded-lg font-mono text-sm text-gray-600">
          src/content/ideas/your-idea.md
        </div>
      </div>
    )}

    <!-- Add Button -->
    <div class="mt-16 text-center">
      <button class="btn-primary">
        <span>➕ 添加新想法</span>
      </button>
    </div>
  </div>
</Layout>
