---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const ideas = await getCollection('ideas');
ideas.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const statusLabels: Record<string, { text: string }> = {
  raw: { text: '💡 突发奇想' },
  thinking: { text: '🤔 在思考' },
  testing: { text: '🧪 验证中' },
  done: { text: '✅ 已实现' },
  abandoned: { text: '❌ 已放弃' },
};
---

<Layout title="想法">
  <div class="page-wrap">
    <div class="page-header">
      <h1 class="page-title">想法</h1>
      <p class="page-desc">记录每一个灵感瞬间，不筛选，不加工</p>
    </div>

    <div class="divider"><div class="divider-dot"></div></div>

    <div class="writing-list">
      {ideas.map((idea) => (
        <a href={`/ideas/${idea.id}`} class="writing-item">
          <div class="writing-date">
            {idea.data.date.toISOString().slice(0, 10)}
            &nbsp;·&nbsp;
            {idea.data.tags.map(t => `#${t}`).join(' ')}
            &nbsp;·&nbsp;
            {statusLabels[idea.data.status]?.text}
          </div>
          <div class="writing-title">{idea.data.title}</div>
        </a>
      ))}
    </div>

    {ideas.length === 0 && (
      <div class="empty-state">
        <p>还没有想法</p>
      </div>
    )}
  </div>
</Layout>

<style>
  .page-wrap {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 2rem 8rem;
  }

  .page-header {
    padding: 6rem 0 2rem;
  }

  .page-title {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 200;
    letter-spacing: 0.2em;
    margin-right: -0.2em;
    color: var(--ink);
  }

  .page-desc {
    font-size: 0.9rem;
    color: var(--muted);
    margin-top: 1rem;
  }
</style>
