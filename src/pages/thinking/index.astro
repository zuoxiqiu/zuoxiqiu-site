---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const thoughts = (await getCollection('thinking')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const formatDate = (date: Date) => date.toISOString().slice(0, 10);
const latestDate = thoughts[0] ? formatDate(thoughts[0].data.date) : '--';
const earliestDate = thoughts[thoughts.length - 1] ? formatDate(thoughts[thoughts.length - 1].data.date) : '--';
---

<Layout title="思考" description="那些还没有答案、但值得反复停留的问题。">
  <section class="page-wrap page-shell">
    <div class="page-header reveal">
      <div class="page-header-copy">
        <p class="page-kicker">Thinking archive</p>
        <h1 class="page-title">思考</h1>
        <p class="page-desc">
          这里收纳的是那些没有标准答案的问题。它们也许暂时无法解决，但值得被反复靠近、命名和重新理解。
        </p>
      </div>

      <aside class="page-panel">
        <p class="page-panel-label">Snapshot</p>
        <div class="page-stat-grid">
          <div class="page-stat">
            <div class="page-stat-value">{thoughts.length}</div>
            <div class="page-stat-label">篇思考</div>
          </div>
          <div class="page-stat">
            <div class="page-stat-value">{latestDate.slice(5)}</div>
            <div class="page-stat-label">最近更新</div>
          </div>
          <div class="page-stat">
            <div class="page-stat-value">{earliestDate.slice(5)}</div>
            <div class="page-stat-label">最早记录</div>
          </div>
        </div>
      </aside>
    </div>

    <div class="divider reveal"><div class="divider-dot"></div></div>

    <div class="writing-list">
      {thoughts.map((thought) => (
        <a href={`/thinking/${thought.id}`} class="writing-item reveal">
          <div class="writing-meta">
            <span>{formatDate(thought.data.date)}</span>
          </div>

          <div class="writing-title-row">
            <h2 class="writing-title">{thought.data.title}</h2>
            <span class="writing-arrow">↗</span>
          </div>

          <p class="writing-summary">不是所有问题都需要立刻回答，有些问题本身就是一种更慢的理解方式。</p>
        </a>
      ))}
    </div>

    {thoughts.length === 0 && (
      <div class="empty-state reveal">
        <p>这里还没有思考条目。</p>
      </div>
    )}
  </section>
</Layout>
