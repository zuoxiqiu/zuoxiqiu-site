---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const thoughts = await getCollection('thinking');
thoughts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="思考">
  <div class="page-wrap">
    <div class="page-header">
      <h1 class="page-title">思考</h1>
      <p class="page-desc">那些没有答案的问题</p>
    </div>

    <div class="divider"><div class="divider-dot"></div></div>

    <div class="writing-list">
      {thoughts.map((t) => (
        <a href={`/thinking/${t.id}`} class="writing-item">
          <div class="writing-date">
            {t.data.date.toISOString().slice(0, 10)}
            &nbsp;·&nbsp;
            {t.data.tags.map(tag => `#${tag}`).join(' ')}
          </div>
          <div class="writing-title">{t.data.title}</div>
        </a>
      ))}
    </div>

    {thoughts.length === 0 && (
      <div class="empty-state">
        <p>还没有思考</p>
      </div>
    )}
  </div>
</Layout>

<style>
  .page-wrap {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 2rem 8rem;
  }

  .page-header {
    padding: 6rem 0 2rem;
  }

  .page-title {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 200;
    letter-spacing: 0.2em;
    margin-right: -0.2em;
    color: var(--ink);
  }

  .page-desc {
    font-size: 0.9rem;
    color: var(--muted);
    margin-top: 1rem;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
  }
</style>
