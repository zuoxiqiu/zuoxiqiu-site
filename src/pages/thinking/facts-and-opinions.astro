        box-shadow: 0 0 0 31px rgba(255,255,255,.028), 0 0 0 62px rgba(255,255,255,.015);
      }

      .tool-button {
        min-width: 48px;
        min-height: 48px;
        padding: 0 14px;
      }

      .kicker { margin: 76px 0 45px; }
      .hero h1 { font-size: clamp(42px, 12.5vw, 58px); }
      .deck { margin-top: 25px; font-size: 17px; line-height: 1.72; }

      .chapter-nav {
        grid-template-columns: repeat(3, 1fr);
        gap: 7px;
        padding: 14px;
      }

      .chapter-nav a {
        min-height: 48px;
        padding: 8px 5px;
        font-size: 11px;
      }

      .content { padding: 12px 21px 52px; }

      .chapter {
        padding: 58px 0 18px;
        scroll-margin-top: 10px;
      }

      .chapter:first-child { padding-top: 46px; }
      h2 { margin-bottom: 25px; font-size: 31px; line-height: 1.3; }
      h3 { font-size: 21px; }
      .lead { font-size: 19px; line-height: 1.9; }
      .lead::first-letter { font-size: 53px; }

      .visual-block {
        margin: 34px -7px;
        padding: 20px 17px;
        border-radius: 18px;
      }

      .visual-head {
        align-items: flex-start;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 21px;
      }

      .visual-head p { max-width: none; text-align: left; }

      .layer-map {
        grid-template-columns: 1fr;
        gap: 6px;
      }

      .layer-map .arrow {
        min-height: 22px;
        transform: rotate(90deg);
      }

      .node {
        min-height: 94px;
        padding: 14px;
      }

      .constraint-row {
        grid-template-columns: 1fr;
        gap: 5px;
      }

      .constraint {
        padding: 8px 10px;
        border-top: 0;
        border-left: 2px solid var(--line);
        text-align: left;
      }

      .newton-formulas { grid-template-columns: 1fr; }

      .newton-formula-card {
        min-height: 132px;
        padding: 18px 19px;
      }

      .newton-formula-card b { font-size: 31px; }

      .formula-bridge {
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
      }

      .formula-bridge i:first-child::after { display: none; }

      .newton-simulator { grid-template-columns: 1fr; }
      .newton-controls { padding: 23px 20px; }
      .newton-stage { min-height: 305px; padding: 23px 20px 19px; }
      .newton-track { margin-top: 18px; }
      .newton-cart { width: 74px; }
      .cart-load { left: 20px; }

      .newton-chain {
        grid-template-columns: 1fr;
        gap: 7px;
      }

      .newton-chain-card {
        min-height: auto;
        padding: 17px 18px;
      }

      .newton-chain-card::after { display: none; }

      .newton-chain-card b {
        display: inline;
        margin: 0 0 0 9px;
        font-size: 17px;
      }

      .newton-chain-card p { margin-top: 8px; font-size: 12px; }
      .newton-scope .scope-title { width: 100%; text-align: center; }
      .theory-boundary { grid-template-columns: 1fr; margin: 28px 0; }

      .xray { grid-template-columns: 1fr; }
      .xray-claim { min-height: 150px; }
      .xray-part { grid-template-columns: 52px 1fr; }

      .model-funnel {
        grid-template-columns: 1fr;
        justify-items: center;
        gap: 9px;
      }

      .model-funnel > .arrow {
        min-height: 22px;
        transform: rotate(90deg);
      }

      .chip-cloud { justify-content: center; }
      .model-core { width: 152px; }
      .model-output { width: 100%; grid-template-columns: repeat(3, 1fr); }

      .lane { grid-template-columns: 1fr; gap: 8px; }
      .lane-flow,
      .lane.slow .lane-flow {
        grid-template-columns: 1fr;
        gap: 5px;
      }

      .lane-flow .arrow {
        min-height: 20px;
        transform: rotate(90deg);
      }

      .lane-step { min-height: 58px; }

      .outcome-switcher { gap: 6px; }

      .outcome-button {
        min-height: 82px;
        padding: 10px;
      }

      .outcome-button small { display: none; }
      .model-compare { grid-template-columns: 1fr; }

      .belief-model { padding: 16px; }

      .model-route {
        grid-template-columns: minmax(0, 1fr) 14px minmax(0, 1.15fr) 14px minmax(0, 1fr);
      }

      .model-route span,
      .model-route strong {
        min-height: 66px;
        padding: 6px;
        font-size: 10px;
      }

      .difference-strip { grid-template-columns: 1fr; gap: 5px; }
      .immunity-system { grid-template-columns: 1fr; }

      .evidence-input,
      .belief-core { min-height: 150px; }

      .belief-payoffs,
      .falsify-boundary { grid-template-columns: 1fr; }

      .sample-funnel {
        grid-template-columns: 1fr;
        gap: 5px;
      }

      .sample-funnel .arrow {
        min-height: 20px;
        transform: rotate(90deg);
      }

      .market-grid,
      .market-lock {
        grid-template-columns: minmax(0, 1fr) 68px minmax(0, 1fr);
        gap: 7px;
      }

      .market-cell,
      .price-path { min-height: 74px; padding: 8px 5px; font-size: 12px; }
      .market-head { font-size: 11px; }
      .lock-node { padding: 10px 5px; }

      .test-bar {
        grid-template-columns: 1fr;
        gap: 5px;
      }

      .test-bar .arrow {
        min-height: 20px;
        transform: rotate(90deg);
      }

      .test-point { min-height: 52px; }

      .audit {
        grid-template-columns: 1fr;
        justify-items: center;
      }

      .audit-list { grid-template-columns: 1fr; width: 100%; }
      .audit-item { min-height: 62px; font-size: 13px; }
      .audit-item input { width: 24px; height: 24px; }

      .quote { padding: 23px 21px; border-radius: 18px; font-size: 20px; }
      .closing { padding: 31px 21px; border-radius: 18px; }
      .closing p { font-size: 24px; }
      .footer { padding: 24px 21px; flex-direction: column; }
    }

    @media (max-width: 370px) {
      .shell { width: calc(100% - 12px); margin-top: 6px; }
      .hero { padding-inline: 18px; }
      .content { padding-inline: 17px; }
      .chapter-nav { padding-inline: 10px; }
      .hero h1 { font-size: 40px; }
      .model-output { grid-template-columns: 1fr; }
      .visual-block { margin-inline: -5px; padding-inline: 14px; }
    }

    @media print {
      .fact-opinion-page {
        --page: #fff;
        --paper: #fff;
        --paper-soft: #f8f6f0;
        --ink: #111;
        --muted: #555;
        --line: #ddd;
      }

      .fact-opinion-page { background: #fff; font-size: 11pt; }
      .fact-progress, .hero-tools, .chapter-nav { display: none; }
      .shell { width: 100%; margin: 0; }
      .paper { border: 0; border-radius: 0; box-shadow: none; }
      .hero { min-height: auto; padding: 45px; print-color-adjust: exact; -webkit-print-color-adjust: exact; }
      .kicker { margin: 20px 0 35px; }
      .content { padding: 10px 45px 40px; }
      .visual-block, .quote, .closing { break-inside: avoid; }
      .footer { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
    }
  

  .fact-opinion-page {
    position: relative;
    margin-top: clamp(2rem, 5vw, 4.5rem);
    background: transparent;
  }

  .fact-opinion-page .shell {
    margin-top: 0;
  }

  .fact-opinion-page .paper {
    border-top: 2px solid var(--ink);
  }

  .fact-opinion-page .chapter-nav {
    position: sticky;
    top: 0;
    z-index: 30;
    backdrop-filter: blur(16px);
  }

  .fact-opinion-page .hero {
    animation: fact-hero-in 900ms var(--ease-out) both;
  }

  .fact-opinion-page .hero h1,
  .fact-opinion-page .hero .deck,
  .fact-opinion-page .hero .kicker {
    animation: fact-copy-in 900ms var(--ease-out) both;
  }

  .fact-opinion-page .hero h1 {
    animation-delay: 120ms;
  }

  .fact-opinion-page .hero .deck {
    animation-delay: 220ms;
  }

  .fact-opinion-page .chapter {
    scroll-margin-top: 5.5rem;
  }

  @keyframes fact-hero-in {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
  }

  @keyframes fact-copy-in {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
  }

  @media (max-width: 760px) {
    .fact-opinion-page {
      margin-top: 1.25rem;
    }

    .fact-opinion-page .shell {
      width: 100%;
      margin-bottom: 2rem;
    }

    .fact-opinion-page .paper {
      border-inline: 0;
      border-radius: 0;
    }

    .fact-opinion-page .chapter-nav {
      top: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fact-opinion-page .hero,
    .fact-opinion-page .hero h1,
    .fact-opinion-page .hero .deck,
    .fact-opinion-page .hero .kicker {
      animation: none;
    }

    .newton-cart,
    .force-vector {
      transition: none;
    }
  }
</style>

<script is:inline>
  (() => {
    const progress = document.getElementById('factProgress');
    const checks = [...document.querySelectorAll('.audit-list input[type="checkbox"]')];
    const gauge = document.getElementById('auditGauge');
    const score = document.getElementById('auditScore');
    const status = document.getElementById('auditStatus');
    const falsifyLab = document.querySelector('.falsify-lab');
    const outcomeButtons = [...document.querySelectorAll('[data-outcome-choice]')];
    const closedObserved = document.getElementById('closedObserved');
    const closedRescue = document.getElementById('closedRescue');
    const openObserved = document.getElementById('openObserved');
    const openReading = document.getElementById('openReading');
    const openAction = document.getElementById('openAction');
    const openDelta = document.getElementById('openDelta');
    const openRule = document.getElementById('openRule');
    const forceInput = document.getElementById('forceInput');
    const massInput = document.getElementById('massInput');
    const forceValue = document.getElementById('forceValue');
    const massValue = document.getElementById('massValue');
    const accelerationValue = document.getElementById('accelerationValue');
    const newtonCart = document.getElementById('newtonCart');
    const newtonPrediction = document.getElementById('newtonPrediction');
    const newtonLab = newtonCart?.closest('.newton-lab');
    const outcomeStates = {
      up: {
        observed: '结果向好',
        rescue: '偶然、外力、暂时',
        reading: '与原预测冲突',
        action: '下调置信度',
        delta: '−',
        rule: '承认反证并检查替代模型',
      },
      flat: {
        observed: '结果稳定',
        rescue: '时间还不够长',
        reading: '预测暂未兑现',
        action: '保留但降权',
        delta: '↓',
        rule: '到期仍无变化就调整模型',
      },
      down: {
        observed: '结果转坏',
        rescue: '终于验证了我',
        reading: '与预测方向一致',
        action: '有限上调',
        delta: '+',
        rule: '继续排除巧合与替代解释',
      },
    };
    const messages = [
      '目前更像一个标签：现实还没有可以反驳它的入口。',
      '开始接触事实，但判断仍然很容易吸收任何结果。',
      '已有局部结构；还需要替代解释和明确边界。',
      '模型开始成形，但尚未充分承担失败风险。',
      '已经可以检验；新的结果能够提高或降低可信度。',
      '模型高度开放，只剩更新规则需要提前固定。',
      '它终于允许现实说“不”：这才是可更新的观点。'
    ];

    const updateProgress = () => {
      if (!progress) return;
      const scrollable = document.documentElement.scrollHeight - window.innerHeight;
      const ratio = scrollable > 0 ? window.scrollY / scrollable : 0;
      progress.style.width = `${Math.min(100, Math.max(0, ratio * 100))}%`;
    };

    const updateAudit = () => {
      if (!gauge || !score || !status) return;
      const count = checks.filter((item) => item.checked).length;
      score.textContent = `${count} / 6`;
      status.textContent = messages[count];
      gauge.style.setProperty('--score-angle', `${count * 60}deg`);
      gauge.setAttribute('aria-label', `模型开放入口${count}项，共六项`);
    };

    const updateOutcome = (choice) => {
      const next = outcomeStates[choice];
      if (!next || !falsifyLab) return;

      falsifyLab.dataset.outcome = choice;
      outcomeButtons.forEach((button) => {
        const active = button.dataset.outcomeChoice === choice;
        button.classList.toggle('is-active', active);
        button.setAttribute('aria-pressed', String(active));
      });

      if (closedObserved) closedObserved.textContent = next.observed;
      if (closedRescue) closedRescue.textContent = next.rescue;
      if (openObserved) openObserved.textContent = next.observed;
      if (openReading) openReading.textContent = next.reading;
      if (openAction) openAction.textContent = next.action;
      if (openDelta) openDelta.textContent = next.delta;
      if (openRule) openRule.textContent = next.rule;
    };

    const updateNewtonLab = () => {
      if (!forceInput || !massInput || !newtonLab) return;

      const force = Number(forceInput.value);
      const mass = Number(massInput.value);
      const acceleration = force / mass;
      const accelerationLabel = acceleration.toFixed(1);
      const massLabel = Number.isInteger(mass) ? mass.toFixed(0) : mass.toFixed(1);
      const normalizedAcceleration = Math.min(1, Math.max(0, (acceleration - 0.2) / 9.8));

      if (forceValue) forceValue.textContent = `${force} N`;
      if (massValue) massValue.textContent = `${massLabel} kg`;
      if (accelerationValue) accelerationValue.textContent = accelerationLabel;
      if (newtonPrediction) {
        newtonPrediction.textContent = `${force} N 的合外力作用在 ${massLabel} kg 的小车上，模型预测加速度为 ${accelerationLabel} m/s²。`;
      }

      newtonLab.style.setProperty('--cart-position', `${18 + normalizedAcceleration * 64}%`);
      newtonLab.style.setProperty('--force-width', `${34 + ((force - 1) / 9) * 42}px`);
    };

    window.addEventListener('scroll', updateProgress, { passive: true });
    checks.forEach((check) => check.addEventListener('change', updateAudit));
    outcomeButtons.forEach((button) => {
      button.addEventListener('click', () => updateOutcome(button.dataset.outcomeChoice));
    });
    forceInput?.addEventListener('input', updateNewtonLab);
    massInput?.addEventListener('input', updateNewtonLab);
    updateProgress();
    updateNewtonLab();
    updateOutcome('up');
    updateAudit();
  })();
</script>
</body>
</html>
