      color: var(--green);
      font-family: var(--serif);
      font-size: clamp(30px, 4.4vw, 43px);
      font-weight: 650;
      line-height: 1.27;
      letter-spacing: -.035em;
    }

    h3 {
      margin: 0;
      font-family: var(--serif);
      font-size: 23px;
      line-height: 1.35;
    }

    p { margin: 0 0 24px; }
    strong { color: var(--green); }

    .lead {
      color: var(--ink);
      font-family: var(--serif);
      font-size: 21px;
      line-height: 1.92;
    }

    .lead::first-letter {
      float: left;
      margin: 11px 9px 0 0;
      color: var(--red);
      font-size: 59px;
      font-weight: 700;
      line-height: .72;
    }

    .visual-block {
      margin: 42px 0;
      padding: 28px;
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: var(--radius-panel);
      background: var(--paper-soft);
    }

    .visual-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 22px;
      margin-bottom: 27px;
    }

    .visual-head p {
      max-width: 390px;
      margin: 0;
      color: var(--muted);
      text-align: right;
      font-size: 13px;
      line-height: 1.6;
    }

    .node {
      display: flex;
      min-width: 0;
      min-height: 115px;
      padding: 16px;
      flex-direction: column;
      justify-content: space-between;
      border: 1px solid color-mix(in srgb, var(--blue) 27%, var(--line));
      border-radius: var(--radius-node);
      background: var(--blue-soft);
    }

    .node.model {
      border-color: color-mix(in srgb, var(--gold) 33%, var(--line));
      background: var(--gold-soft);
    }

    .node.output {
      border-color: color-mix(in srgb, var(--green) 28%, var(--line));
      background: var(--green-soft);
    }

    .node b { font-size: 15px; }
    .node small { color: var(--muted); font-size: 12px; line-height: 1.55; }

    .arrow {
      display: grid;
      min-width: 22px;
      place-items: center;
      color: var(--muted);
      font-weight: 700;
    }

    .layer-map {
      display: grid;
      grid-template-columns: 1fr 24px 1.16fr 24px 1fr 24px 1fr 24px 1fr;
      align-items: stretch;
    }

    .constraint-row {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 8px;
      margin-top: 13px;
    }

    .constraint {
      padding-top: 9px;
      border-top: 2px solid var(--line);
      color: var(--muted);
      text-align: center;
      font-size: 12px;
      line-height: 1.45;
    }

    .newton-lab {
      position: relative;
      overflow: hidden;
      background:
        radial-gradient(circle at 84% 11%, rgba(177, 68, 48, .09), transparent 25%),
        linear-gradient(155deg, color-mix(in srgb, var(--paper) 86%, white), var(--paper-deep));
    }

    .newton-lab::after {
      position: absolute;
      width: 210px;
      height: 210px;
      right: -128px;
      bottom: -142px;
      border: 1px solid color-mix(in srgb, var(--gold) 25%, transparent);
      border-radius: 50%;
      box-shadow: 0 0 0 34px color-mix(in srgb, var(--gold) 5%, transparent), 0 0 0 69px color-mix(in srgb, var(--gold) 4%, transparent);
      content: '';
      pointer-events: none;
    }

    .newton-formulas {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr 132px 1fr;
      gap: 16px;
      align-items: center;
    }

    .newton-formula-card {
      display: flex;
      min-height: 158px;
      padding: 20px 22px;
      flex-direction: column;
      justify-content: center;
      border: 1px solid var(--line);
      border-radius: var(--radius-node);
      background: color-mix(in srgb, var(--paper) 90%, white);
    }

    .newton-formula-card.general {
      border-color: color-mix(in srgb, var(--green) 30%, var(--line));
      box-shadow: inset 4px 0 0 color-mix(in srgb, var(--green) 72%, transparent);
    }

    .newton-formula-card.familiar {
      border-color: color-mix(in srgb, var(--red) 30%, var(--line));
      box-shadow: inset 4px 0 0 color-mix(in srgb, var(--red) 72%, transparent);
    }

    .newton-formula-card span {
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .12em;
    }

    .newton-formula-card b {
      margin: 8px 0 5px;
      font-family: var(--serif);
      font-size: clamp(28px, 3.8vw, 42px);
      font-weight: 650;
      letter-spacing: -.03em;
    }

    .newton-formula-card small {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.55;
    }

    .formula-bridge {
      display: grid;
      gap: 7px;
      color: var(--muted);
      text-align: center;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .08em;
    }

    .formula-bridge i {
      position: relative;
      display: block;
      height: 1px;
      background: var(--line);
    }

    .formula-bridge i:first-child::after {
      position: absolute;
      width: 7px;
      height: 7px;
      right: 0;
      top: -3px;
      border-top: 1px solid var(--muted);
      border-right: 1px solid var(--muted);
      content: '';
      transform: rotate(45deg);
    }

    .newton-simulator {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: minmax(220px, .72fr) minmax(360px, 1.28fr);
      margin-top: 18px;
      overflow: hidden;
      border: 1px solid color-mix(in srgb, var(--ink) 22%, var(--line));
      border-radius: 18px;
      background: var(--ink);
      box-shadow: 0 18px 45px rgba(35, 31, 26, .12);
    }

    .newton-controls {
      display: grid;
      gap: 20px;
      align-content: center;
      padding: 26px 25px;
      color: var(--ink);
      background: color-mix(in srgb, var(--paper) 92%, white);
    }

    .newton-control {
      display: grid;
      gap: 10px;
    }

    .control-label,
    .range-scale {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .control-label label {
      font-size: 13px;
      font-weight: 750;
    }

    .control-label output {
      min-width: 52px;
      padding: 5px 8px;
      border: 1px solid var(--line);
      border-radius: var(--radius-pill);
      color: var(--red);
      background: var(--paper);
      text-align: center;
      font-family: var(--serif);
      font-size: 14px;
      font-weight: 700;
    }

    .newton-control input[type='range'] {
      width: 100%;
      height: 5px;
      margin: 2px 0;
      appearance: none;
      border-radius: var(--radius-pill);
      outline: none;
      background: linear-gradient(90deg, var(--red), color-mix(in srgb, var(--red) 18%, var(--line)));
      cursor: ew-resize;
    }

    .newton-control input[type='range']::-webkit-slider-thumb {
      width: 19px;
      height: 19px;
      appearance: none;
      border: 4px solid var(--paper);
      border-radius: 50%;
      background: var(--red);
      box-shadow: 0 0 0 1px color-mix(in srgb, var(--red) 55%, var(--line)), 0 3px 9px rgba(35, 31, 26, .18);
    }

    .newton-control input[type='range']::-moz-range-thumb {
      width: 12px;
      height: 12px;
      border: 4px solid var(--paper);
      border-radius: 50%;
      background: var(--red);
      box-shadow: 0 0 0 1px color-mix(in srgb, var(--red) 55%, var(--line));
    }

    .range-scale {
      color: var(--muted);
      font-size: 12px;
    }

    .control-hint {
      margin: 0;
      padding-top: 16px;
      border-top: 1px solid var(--line);
      color: var(--muted);
      font-size: 12px;
      line-height: 1.65;
    }

    .newton-stage {
      display: grid;
      min-height: 335px;
      padding: 26px 28px 22px;
      align-content: space-between;
      color: #f4efe5;
      background:
        radial-gradient(circle at 72% 12%, rgba(198, 164, 89, .14), transparent 26%),
        linear-gradient(145deg, #292b27, #1c1e1c);
    }

    .newton-readout span {
      display: block;
      color: rgba(244, 239, 229, .52);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .12em;
    }

    .newton-readout b {
      display: block;
      margin-top: 5px;
      font-family: var(--serif);
      font-size: clamp(24px, 3.2vw, 35px);
      font-weight: 500;
    }

    .newton-readout strong {
      color: #d7bd79;
      font-weight: 650;
    }

    .newton-track {
      position: relative;
      height: 94px;
      margin: 24px 0 20px;
      border-bottom: 2px solid rgba(244, 239, 229, .34);
      background: repeating-linear-gradient(90deg, transparent 0, transparent 49px, rgba(244, 239, 229, .055) 50px);
    }

    .track-mark {
      position: absolute;
      bottom: -7px;
      width: 1px;
      height: 11px;
      background: rgba(244, 239, 229, .38);
    }

    .mark-one { left: 16%; }
    .mark-two { left: 50%; }
    .mark-three { left: 84%; }

    .newton-cart {
      position: absolute;
      width: 86px;
      height: 48px;
      left: var(--cart-position);
      bottom: 11px;
      border: 1px solid rgba(244, 239, 229, .5);
      border-radius: 8px 8px 3px 3px;
      background: linear-gradient(135deg, #c5624c, #9d3f31);
      box-shadow: 0 10px 20px rgba(0, 0, 0, .28);
      transform: translateX(-50%);
      transition: left 520ms cubic-bezier(.2, .8, .2, 1);
    }

    .cart-load {
      display: grid;
      position: absolute;
      width: 34px;
      height: 29px;
      left: 26px;
      top: 9px;
      place-items: center;
      border: 1px solid rgba(255,255,255,.3);
      border-radius: 4px;
      color: rgba(255,255,255,.82);
      font-family: var(--serif);
      font-style: italic;
      font-weight: 700;
    }

    .cart-wheel {
      position: absolute;
      width: 15px;
      height: 15px;
      bottom: -11px;
      border: 3px solid #b9b4a9;
      border-radius: 50%;
      background: #252724;
    }

    .wheel-left { left: 12px; }
    .wheel-right { right: 12px; }

    .force-vector {
      position: absolute;
      width: var(--force-width);
      max-width: 76px;
      min-width: 34px;
      right: calc(100% + 8px);
      top: 22px;
      border-top: 2px solid #d7bd79;
      color: #d7bd79;
      font-family: var(--serif);
      font-size: 12px;
      line-height: 0;
      text-align: center;
      transition: width 320ms ease;
    }

    .force-vector::after {
      position: absolute;
      width: 7px;
      height: 7px;
      right: -1px;
      top: -5px;
      border-top: 2px solid #d7bd79;
      border-right: 2px solid #d7bd79;
      content: '';
      transform: rotate(45deg);
    }

    .newton-stage > p {
      min-height: 43px;
      margin: 0;
      color: rgba(244, 239, 229, .68);
      font-size: 12px;
      line-height: 1.7;
    }

    .newton-chain {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 9px;
      margin-top: 18px;
    }

    .newton-chain-card {
      position: relative;
      min-height: 177px;
      padding: 19px 17px 16px;
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: color-mix(in srgb, var(--paper) 90%, white);
    }

    .newton-chain-card::after {
      position: absolute;
      width: 46px;
      height: 1px;
      right: -28px;
      top: 31px;
      background: var(--red);
      content: '';
    }

    .newton-chain-card:last-child::after { display: none; }

    .newton-chain-card > span {
      color: var(--red);
      font-family: var(--serif);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .1em;
    }

    .newton-chain-card b {
      display: block;
      margin: 17px 0 7px;
      font-family: var(--serif);
      font-size: 18px;
    }

    .newton-chain-card p {
      margin: 0;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.65;
    }

    .newton-scope {
      position: relative;
      z-index: 1;
      display: flex;
      gap: 8px;
      margin-top: 14px;
      flex-wrap: wrap;
      align-items: center;
    }

    .newton-scope span {
      padding: 8px 11px;
      border: 1px solid var(--line);
      border-radius: var(--radius-pill);
      color: var(--muted);
      background: color-mix(in srgb, var(--paper) 86%, white);
      font-size: 12px;
      line-height: 1.2;
    }

    .newton-scope .scope-title {
      border-color: var(--ink);
      color: var(--paper);
      background: var(--ink);
      font-weight: 700;
    }

    .theory-boundary {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      margin: 30px 0;
    }

    .theory-boundary > div {
      padding: 22px 23px;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--paper);
    }

    .theory-boundary > div:first-child { border-top: 3px solid var(--gold); }
    .theory-boundary > div:last-child { border-top: 3px solid var(--green); }

    .theory-boundary span {
      color: var(--muted);
      font-size: 12px;
      font-weight: 750;
      letter-spacing: .1em;
    }

    .theory-boundary b {
      display: block;
      margin: 9px 0 7px;
      font-family: var(--serif);
      font-size: 17px;
      line-height: 1.45;
    }

    .theory-boundary p {
      margin: 0;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.75;
    }

    .xray {
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 18px;
      align-items: stretch;
    }

    .xray-claim {
      display: flex;
      min-height: 220px;
      padding: 25px;
      flex-direction: column;
      justify-content: center;
      border: 1px solid color-mix(in srgb, var(--red) 25%, var(--line));
      border-radius: var(--radius-node);
      background: var(--red-soft);
    }

    .xray-claim span { color: var(--muted); font-size: 12px; }
    .xray-claim b { margin-top: 12px; font-family: var(--serif); font-size: 28px; }

    .xray-parts { display: grid; gap: 8px; }

    .xray-part {
      display: grid;
      grid-template-columns: 60px 1fr;
      gap: 12px;
      align-items: center;
      padding: 10px 13px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--paper);
      font-size: 13px;
      line-height: 1.5;
    }

    .xray-part b { color: var(--red); }

    .claim-stack-block {
      position: relative;
      padding: 32px;
      background:
        linear-gradient(120deg, transparent 0 62%, color-mix(in srgb, var(--gold) 8%, transparent) 62% 100%),
        color-mix(in srgb, var(--paper-soft) 88%, white);
    }

    .claim-stack-block::before {
      position: absolute;
      width: 180px;
      height: 180px;
      right: -92px;
      top: -104px;
      border: 1px solid color-mix(in srgb, var(--gold) 30%, transparent);
      border-radius: 50%;
      content: '';
      pointer-events: none;
    }

    .claim-stack {
      position: relative;
      display: grid;
      grid-template-columns: minmax(220px, .78fr) minmax(0, 1.22fr);
      gap: 15px;
      align-items: stretch;
    }

    .fact-anchor {
      display: flex;
      min-height: 354px;
      padding: 24px;
      flex-direction: column;
      justify-content: center;
      border-radius: 17px;
      color: #f6f1e7;
      background:
        radial-gradient(circle at 85% 12%, rgba(223, 183, 97, .18), transparent 30%),
        linear-gradient(145deg, #1e2925, #293a34);
      box-shadow: 0 18px 38px rgba(35, 31, 26, .14);
    }

    .fact-meta {
      display: flex;
      gap: 6px;
      margin-bottom: auto;
      flex-wrap: wrap;
    }

    .fact-meta span {
      padding: 5px 8px;
      border: 1px solid rgba(246, 241, 231, .18);
      border-radius: var(--radius-pill);
      color: rgba(246, 241, 231, .7);
      font-size: 12px;
      line-height: 1.2;
    }

    .fact-anchor small {
      color: #dfc675;
      font-size: 12px;
      font-weight: 750;
      letter-spacing: .1em;
    }

    .fact-anchor b {
      display: block;
      margin: 13px 0 10px;
      font-family: var(--serif);
      font-size: clamp(29px, 4vw, 40px);
      font-weight: 650;
      line-height: 1.24;
      letter-spacing: -.035em;
    }

    .fact-anchor p {
      margin: 0;
      color: rgba(246, 241, 231, .64);
      font-size: 13px;
      line-height: 1.65;
    }

    .added-layers {
      display: grid;
      gap: 8px;
    }

    .added-layer {
      position: relative;
      display: grid;
      grid-template-columns: 72px minmax(0, 1fr);
      gap: 3px 13px;
      min-height: 80px;
      padding: 14px 17px 13px;
      overflow: hidden;
      border: 1px solid var(--line);
      border-left: 3px solid var(--layer-color, var(--gold));
      border-radius: 12px;
      background: color-mix(in srgb, var(--paper) 91%, white);
    }

    .added-layer::after {
      position: absolute;
      right: 12px;
      top: -15px;
      color: color-mix(in srgb, var(--layer-color, var(--gold)) 10%, transparent);
      content: '+';
      font-family: var(--serif);
      font-size: 76px;
      line-height: 1;
      pointer-events: none;
    }

    .added-layer.explanation { --layer-color: var(--gold); }
    .added-layer.evaluation { --layer-color: var(--red); }
    .added-layer.forecast { --layer-color: var(--blue); }
    .added-layer.decision { --layer-color: var(--green); }

    .added-layer > span {
      position: relative;
      z-index: 1;
      grid-row: 1 / 3;
      color: var(--layer-color);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: .08em;
    }

    .added-layer b {
      position: relative;
      z-index: 1;
      font-family: var(--serif);
      font-size: 17px;
      line-height: 1.35;
    }

    .added-layer p {
      position: relative;
      z-index: 1;
      margin: 0;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.45;
    }

    .layer-equation {
      display: flex;
      gap: 7px;
      margin-top: 15px;
      align-items: center;
      flex-wrap: wrap;
    }

    .layer-equation span,
    .layer-equation b {
      padding: 7px 10px;
      border: 1px solid var(--line);
      border-radius: var(--radius-pill);
      background: var(--paper);
      font-size: 12px;
      line-height: 1.2;
    }

    .layer-equation i {
      color: var(--red);
      font-family: var(--serif);
      font-size: 17px;
      font-style: normal;
    }

    .layer-equation b {
      border-color: var(--green);
      color: #f6f1e7;
      background: var(--green);
    }

    .layer-conclusion {
      display: grid;
      grid-template-columns: 118px 1fr;
      gap: 18px;
      margin-top: 24px;
      padding-top: 22px;
      align-items: start;
      border-top: 1px solid var(--line);
    }

    .layer-conclusion span {
      color: var(--red);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: .12em;
    }

    .layer-conclusion b {
      font-family: var(--serif);
      font-size: clamp(21px, 3vw, 29px);
      font-weight: 650;
      line-height: 1.48;
      letter-spacing: -.02em;
    }

    .formula-proof-block {
      background:
        linear-gradient(rgba(49, 95, 85, .04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(49, 95, 85, .04) 1px, transparent 1px),
        color-mix(in srgb, var(--green-soft) 52%, var(--paper));
      background-size: 28px 28px;
    }

    .formula-proof-flow {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 68px minmax(170px, 1fr) 68px minmax(0, 1fr);
      gap: 9px;
      align-items: stretch;
    }

    .proof-card,
    .proof-formula {
      display: flex;
      min-width: 0;
      min-height: 160px;
      padding: 18px;
      flex-direction: column;
      justify-content: center;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: color-mix(in srgb, var(--paper) 91%, white);
    }

    .proof-card > span,
    .proof-formula > span {
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: .1em;
    }

    .proof-card b {
      margin: 12px 0 8px;
      font-family: var(--serif);
      font-size: 17px;
      line-height: 1.5;
    }

    .proof-card small,
    .proof-formula small {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.55;
    }

    .proof-formula {
      border-color: color-mix(in srgb, var(--green) 38%, var(--line));
      color: #f6f1e7;
      background: linear-gradient(145deg, #24372f, #315047);
      box-shadow: 0 15px 30px rgba(35, 31, 26, .12);
    }

    .proof-formula > span,
    .proof-formula small { color: rgba(246, 241, 231, .68); }

    .proof-formula b {
      margin: 9px 0 7px;
      color: #e3c66f;
      font-family: var(--serif);
      font-size: clamp(30px, 3.5vw, 35px);
      font-weight: 650;
      line-height: 1.15;
      letter-spacing: -.03em;
      white-space: nowrap;
    }

    .proof-arrow {
      display: grid;
      place-content: center;
      color: var(--muted);
      text-align: center;
    }

    .proof-arrow span {
      font-size: 12px;
      line-height: 1.35;
    }

    .proof-arrow i {
      color: var(--red);
      font-family: var(--serif);
      font-size: 25px;
      font-style: normal;
      line-height: 1.2;
    }

    .formula-boundary {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 9px;
      margin-top: 14px;
    }

    .formula-boundary > div {
      padding: 14px 15px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: color-mix(in srgb, var(--paper) 90%, white);
    }

    .formula-boundary span {
      display: block;
      color: var(--muted);
      font-size: 12px;
    }

    .formula-boundary b {
      display: block;
      margin-top: 5px;
      font-family: var(--serif);
      font-size: 15px;
      line-height: 1.42;
    }

    .formula-boundary .answer {
      border-color: var(--green);
      color: #f6f1e7;
      background: var(--green);
    }

    .formula-boundary .answer span { color: rgba(246, 241, 231, .68); }

    .formula-final {
      display: grid;
      grid-template-columns: minmax(210px, .72fr) 1.28fr;
      gap: 22px;
      margin-top: 22px;
      padding-top: 21px;
      align-items: start;
      border-top: 1px solid color-mix(in srgb, var(--green) 22%, var(--line));
    }

    .formula-final b {
      color: var(--red);
      font-family: var(--serif);
      font-size: clamp(22px, 3vw, 29px);
      line-height: 1.32;
    }

    .formula-final p {
      margin: 0;
      font-size: 14px;
      line-height: 1.75;
    }

    .model-lab {
      --model-accent: var(--green);
      background:
        linear-gradient(rgba(49, 95, 85, .035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(49, 95, 85, .035) 1px, transparent 1px),
        color-mix(in srgb, var(--paper-soft) 82%, var(--green-soft));
      background-size: 30px 30px;
    }

    .model-case {
      display: grid;
      gap: 13px;
    }

    .case-fact {
      display: grid;
      grid-template-columns: minmax(0, .72fr) minmax(0, 1.1fr) minmax(0, 1.35fr);
      gap: 18px;
      align-items: center;
      padding: 20px 22px;
      border-radius: 16px;
      color: #f8f5ec;
      background:
        radial-gradient(circle at 85% 20%, rgba(174, 127, 53, .18), transparent 30%),
        linear-gradient(135deg, #20221f, #171411);
    }

    .case-fact > span {
      color: rgba(248,245,236,.62);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .08em;
    }

    .case-fact > b {
      font-family: var(--serif);
      font-size: 22px;
      line-height: 1.45;
    }

    .case-fact > p {
      margin: 0;
      color: rgba(248,245,236,.68);
      font-size: 13px;
      line-height: 1.7;
    }

    .model-candidates {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .model-candidate {
      --candidate-color: var(--green);
      min-width: 0;
      padding: 18px;
      border: 1px solid color-mix(in srgb, var(--candidate-color) 30%, var(--line));
      border-top: 4px solid var(--candidate-color);
      border-radius: 15px;
      background: color-mix(in srgb, var(--paper) 92%, white);
      transition: border-color 280ms ease, transform 280ms ease;
    }

    .model-candidate.marketing { --candidate-color: var(--red); }
    .model-candidate.context { --candidate-color: var(--blue); }

    .model-candidate header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 10px;
    }

    .model-candidate header span {
      color: var(--candidate-color);
      font-size: 12px;
      font-weight: 750;
      letter-spacing: .08em;
    }

    .model-candidate header b {
      font-family: var(--serif);
      font-size: 18px;
    }

    .model-candidate > p {
      min-height: 47px;
      margin: 12px 0 15px;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.65;
    }

    .support-meter {
      height: 7px;
      overflow: hidden;
      border-radius: var(--radius-pill);
      background: var(--line);
    }

    .support-meter i {
      display: block;
      width: 0;
      height: 100%;
      border-radius: inherit;
      background: var(--candidate-color);
      transition: width 520ms cubic-bezier(.2, .8, .2, 1);
    }

    #productSupport { width: 78%; }
    #marketingSupport { width: 42%; }
    #contextSupport { width: 32%; }

    .support-reading {
      display: grid;
      grid-template-columns: auto auto;
      gap: 3px 8px;
      align-items: center;
      margin-top: 10px;
    }

    .support-reading span {
      color: var(--muted);
      font-size: 12px;
    }

    .support-reading b {
      color: var(--candidate-color);
      text-align: right;
      font-family: var(--serif);
      font-size: 20px;
      line-height: 1;
    }

    .support-reading small {
      grid-column: 1 / -1;
      min-height: 39px;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.55;
    }

    .evidence-switcher {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 9px;
      margin-top: 0;
    }

    .evidence-choice {
      display: grid;
      min-height: 102px;
      padding: 13px 15px;
      border: 1px solid var(--line);
      border-radius: 13px;
      color: var(--muted);
      background: color-mix(in srgb, var(--paper) 88%, transparent);
      text-align: left;
      cursor: pointer;
      transition: transform 220ms ease, border-color 220ms ease, background-color 220ms ease;
    }

    .evidence-choice:hover { transform: translateY(-2px); }

    .evidence-choice.is-active {
      border-color: color-mix(in srgb, var(--green) 48%, var(--line));
      color: var(--ink);
      background: var(--green-soft);
    }

    .evidence-choice span {
      color: var(--green);
      font-size: 12px;
      font-weight: 750;
      letter-spacing: .07em;
    }

    .evidence-choice b { margin: 5px 0 2px; font-size: 14px; }
    .evidence-choice small { font-size: 12px; }

    .evidence-verdict {
      display: grid;
      grid-template-columns: 150px 1fr;
      gap: 6px 18px;
      margin-top: 11px;
      padding: 17px 19px;
      border-left: 4px solid var(--green);
      background: color-mix(in srgb, var(--green-soft) 72%, var(--paper));
    }

    .evidence-verdict > span {
      grid-row: span 2;
      color: var(--green);
      font-size: 12px;
      font-weight: 750;
      letter-spacing: .06em;
    }

    .evidence-verdict p {
      margin: 0;
      font-size: 13px;
      line-height: 1.65;
    }

    .evidence-verdict small {
      color: var(--muted);
      font-size: 12px;
    }

    .model-validity {
      display: grid;
      grid-template-columns: 1fr 44px 1fr;
      gap: 10px;
      align-items: stretch;
      margin-top: 18px;
      padding-top: 18px;
      border-top: 1px solid var(--line);
    }

    .model-validity > div {
      padding: 15px 17px;
      border: 1px solid var(--line);
      border-radius: 13px;
      background: var(--paper);
    }

    .model-validity > div:last-child {
      border-color: color-mix(in srgb, var(--green) 30%, var(--line));
      background: var(--green-soft);
    }

    .model-validity span {
      color: var(--muted);
      font-size: 12px;
    }

    .model-validity b {
      display: block;
      margin: 5px 0;
      font-family: var(--serif);
      font-size: 16px;
    }

    .model-validity p {
      margin: 0;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.55;
    }

    .model-validity > i {
      display: grid;
      place-items: center;
      color: var(--red);
      font-family: var(--serif);
      font-size: 24px;
      font-style: normal;
    }

    .thinking-lab {
      background:
        radial-gradient(circle at 90% 8%, rgba(174, 127, 53, .12), transparent 28%),
        color-mix(in srgb, var(--paper-soft) 82%, var(--gold-soft));
    }

    .thinking-case {
      padding: 21px 23px;
      border-radius: 16px;
      color: #f8f5ec;
      background: linear-gradient(135deg, #25221d, #181512);
    }

    .thinking-case span {
      color: #d7bd79;
      font-size: 12px;
      font-weight: 750;
      letter-spacing: .08em;
    }

    .thinking-case b {
      display: block;
      margin: 8px 0;
      font-family: var(--serif);
      font-size: 21px;
      line-height: 1.55;
    }

    .thinking-case small {
      color: rgba(248,245,236,.62);
      font-size: 12px;
      line-height: 1.6;
    }

    .thinking-mode-switch {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 9px;
      margin: 13px 0;
    }

    .thinking-mode-button {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 2px 12px;
      min-height: 84px;
      padding: 13px 16px;
      align-content: center;
      border: 1px solid var(--line);
      border-radius: 13px;
      color: var(--muted);
      background: var(--paper);
      text-align: left;
      cursor: pointer;
      transition: border-color 220ms ease, background-color 220ms ease, transform 220ms ease;
    }

    .thinking-mode-button:hover { transform: translateY(-2px); }

    .thinking-mode-button.is-active {
      border-color: color-mix(in srgb, var(--gold) 46%, var(--line));
      color: var(--ink);
      background: var(--gold-soft);
    }

    .thinking-lab[data-thinking-mode="slow"] .thinking-mode-button.is-active {
      border-color: color-mix(in srgb, var(--green) 46%, var(--line));
      background: var(--green-soft);
    }

    .thinking-mode-button span {
      grid-row: span 2;
      align-self: center;
      color: var(--gold);
      font-size: 12px;
      font-weight: 750;
      letter-spacing: .08em;
    }

    .thinking-mode-button b { font-size: 15px; }
    .thinking-mode-button small { font-size: 12px; }

    .thinking-screen {
      display: grid;
      grid-template-columns: minmax(0, .82fr) minmax(0, 1.18fr);
      gap: 12px;
      min-height: 310px;
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: 17px;
      background: color-mix(in srgb, var(--paper) 88%, transparent);
    }

    .thinking-story {
      display: flex;
      padding: 22px;
      flex-direction: column;
      justify-content: center;
      border: 1px solid color-mix(in srgb, var(--red) 28%, var(--line));
      border-radius: 14px;
      background: var(--red-soft);
      transition: border-color 260ms ease, background-color 260ms ease;
    }

    .thinking-lab[data-thinking-mode="slow"] .thinking-story {
      border-color: color-mix(in srgb, var(--green) 28%, var(--line));
      background: var(--green-soft);
    }

    .thinking-story > span {
      color: var(--red);
      font-size: 12px;
      font-weight: 750;
      letter-spacing: .07em;
    }

    .thinking-lab[data-thinking-mode="slow"] .thinking-story > span { color: var(--green); }

    .thinking-story > b {
      margin: 12px 0 8px;
      font-family: var(--serif);
      font-size: 23px;
      line-height: 1.5;
    }

    .thinking-story > p {
      margin: 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.7;
    }

    .thinking-audit-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
      transition: opacity 260ms ease, filter 260ms ease, transform 260ms ease;
    }

    .thinking-lab[data-thinking-mode="fast"] .thinking-audit-grid {
      opacity: .32;
      filter: grayscale(.8);
      transform: scale(.985);
    }

    .thinking-audit-grid > div {
      display: flex;
      min-height: 138px;
      padding: 15px;
      flex-direction: column;
      justify-content: center;
      border: 1px solid var(--line);
      border-radius: 13px;
      background: var(--paper);
    }

    .thinking-audit-grid span {
      color: var(--green);
      font-size: 12px;
      font-weight: 750;
      letter-spacing: .07em;
    }

    .thinking-audit-grid b {
      margin: 7px 0 3px;
      font-size: 14px;
      line-height: 1.5;
    }

    .thinking-audit-grid small {
      color: var(--muted);
      font-size: 12px;
    }

    .slow-protocol {
      display: grid;
      grid-template-columns: auto 1fr 24px 1fr 24px 1fr 24px 1fr;
      gap: 6px;
      align-items: center;
      margin-top: 13px;
      padding: 14px 15px;
      border: 1px solid color-mix(in srgb, var(--green) 24%, var(--line));
      border-radius: 13px;
      background: var(--green-soft);
    }

    .slow-protocol span {
      color: var(--green);
      font-size: 12px;
      font-weight: 750;
    }

    .slow-protocol b {
      text-align: center;
      font-size: 12px;
    }

    .slow-protocol i {
      color: var(--muted);
      text-align: center;
      font-style: normal;
    }

    .warning-strip {
      margin-top: 21px;
      padding: 15px 17px;
      border-left: 4px solid var(--red);
      border-radius: 4px var(--radius-node) var(--radius-node) 4px;
      background: var(--red-soft);
      font-size: 14px;
    }

    .immunity-block {
      background: color-mix(in srgb, var(--paper-soft) 74%, var(--green-soft));
    }

    .immunity-system {
      display: grid;
      grid-template-columns: .72fr 1.8fr .9fr;
      gap: 13px;
      align-items: stretch;
    }

    .evidence-input,
    .belief-core {
      display: flex;
      min-height: 250px;
      padding: 18px;
      flex-direction: column;
      justify-content: center;
      border: 1px solid var(--line);
      border-radius: 18px;
      text-align: center;
    }

    .evidence-input { background: var(--blue-soft); }

    .evidence-input span,
    .belief-core > span,
    .defense-layer-title span {
      color: var(--muted);
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: .12em;
      text-transform: uppercase;
    }

    .evidence-input b,
    .belief-core > b { margin: 8px 0; font-family: var(--serif); font-size: 18px; }
    .evidence-input small,
    .belief-core > small { color: var(--muted); font-size: 12px; line-height: 1.5; }

    .defense-layer {
      padding: 16px;
      border: 1px solid color-mix(in srgb, var(--gold) 35%, var(--line));
      border-radius: 18px;
      background: var(--gold-soft);
    }

    .defense-layer-title {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }

    .defense-layer-title b { font-family: var(--serif); font-size: 17px; }

    .defense-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
    }

    .defense-card {
      min-height: 96px;
      padding: 11px;
      border: 1px solid color-mix(in srgb, var(--gold) 23%, var(--line));
      border-radius: 11px;
      background: color-mix(in srgb, var(--paper) 80%, transparent);
    }

    .defense-card span {
      color: var(--red);
      font-family: var(--mono);
      font-size: 12px;
    }

    .defense-card b { display: block; margin: 3px 0; font-size: 12px; }
    .defense-card small { color: var(--muted); font-size: 12px; line-height: 1.45; }

    .belief-core {
      color: #f8f5ec;
      background:
        radial-gradient(circle at 50% 45%, rgba(255,255,255,.08), transparent 35%),
        linear-gradient(145deg, #181411, #315f55);
    }

    .belief-core > span,
    .belief-core > small { color: rgba(248,245,236,.66); }

    .belief-lock {
      position: relative;
      width: 42px;
      height: 36px;
      margin: 17px auto 3px;
      border: 2px solid var(--gold);
      border-radius: 8px;
    }

    .belief-lock::before {
      content: "";
      position: absolute;
      left: 8px;
      bottom: calc(100% - 3px);
      width: 22px;
      height: 20px;
      border: 2px solid var(--gold);
      border-bottom: 0;
      border-radius: 14px 14px 0 0;
    }

    .belief-lock i {
      position: absolute;
      top: 13px;
      left: 17px;
      width: 5px;
      height: 10px;
      border-radius: 4px;
      background: var(--gold);
    }

    .belief-payoffs {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 9px;
      margin-top: 13px;
    }

    .belief-payoffs > div {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 3px 9px;
      padding: 13px;
      border: 1px solid color-mix(in srgb, var(--violet) 22%, var(--line));
      border-radius: 12px;
      background: var(--violet-soft);
    }

    .belief-payoffs span {
      grid-row: span 2;
      color: var(--violet);
      font-family: var(--mono);
      font-size: 12px;
    }

    .belief-payoffs b { font-size: 12px; }
    .belief-payoffs small { color: var(--muted); font-size: 12px; line-height: 1.45; }

    .falsify-boundary {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 13px;
      margin: 40px 0;
    }

    .falsify-boundary article {
      padding: 23px;
      border: 1px solid color-mix(in srgb, var(--green) 28%, var(--line));
      border-radius: var(--radius-panel);
      background: var(--green-soft);
    }

    .falsify-boundary article + article {
      border-color: color-mix(in srgb, var(--red) 28%, var(--line));
      background: var(--red-soft);
    }

    .falsify-boundary span {
      display: inline-block;
      margin-bottom: 13px;
      color: var(--green);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .14em;
    }

    .falsify-boundary article + article span { color: var(--red); }
    .falsify-boundary b { display: block; font-family: var(--serif); font-size: 18px; line-height: 1.65; }
    .falsify-boundary p { margin-top: 12px; color: var(--muted); font-size: 12px; line-height: 1.65; }

    .market-mirror-lab {
      --market-accent: var(--green);
      --market-soft: var(--green-soft);
      background:
        linear-gradient(90deg, rgba(184, 92, 54, .045), transparent 34% 66%, rgba(49, 95, 85, .05)),
        color-mix(in srgb, var(--paper-soft) 86%, white);
    }

    .market-mirror-lab[data-market-path="flat"] {
      --market-accent: var(--gold);
      --market-soft: var(--gold-soft);
    }

    .market-mirror-lab[data-market-path="down"] {
      --market-accent: var(--red);
      --market-soft: var(--red-soft);
    }

    .market-path-switcher {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
      margin-bottom: 13px;
    }

    .market-path-button {
      display: grid;
      grid-template-columns: 32px 1fr;
      gap: 1px 9px;
      min-height: 64px;
      padding: 10px 13px;
      align-items: center;
      border: 1px solid var(--line);
      border-radius: 13px;
      color: var(--muted);
      background: color-mix(in srgb, var(--paper) 92%, white);
      text-align: left;
      cursor: pointer;
      transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
    }

    .market-path-button:hover { transform: translateY(-2px); }

    .market-path-button.is-active {
      border-color: color-mix(in srgb, var(--market-accent) 55%, var(--line));
      color: var(--ink);
      background: var(--market-soft);
      box-shadow: inset 0 -3px 0 var(--market-accent);
    }

    .market-path-button span {
      grid-row: 1 / 3;
      color: var(--market-accent);
      font-family: var(--serif);
      font-size: 25px;
      line-height: 1;
      text-align: center;
    }

    .market-path-button b { font-size: 13px; }
    .market-path-button small { font-size: 12px; }

    .market-mirror {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 150px minmax(0, 1fr);
      gap: 10px;
      align-items: stretch;
    }

    .narrative-panel {
      display: flex;
      min-width: 0;
      min-height: 300px;
      padding: 18px;
      flex-direction: column;
      border: 1px solid var(--line);
      border-radius: 16px;
      background: var(--paper);
    }

    .narrative-panel.bear {
      border-color: color-mix(in srgb, var(--red) 34%, var(--line));
      box-shadow: inset 4px 0 0 var(--red);
    }

    .narrative-panel.bull {
      border-color: color-mix(in srgb, var(--green) 34%, var(--line));
      box-shadow: inset -4px 0 0 var(--green);
    }

    .narrative-panel header {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      padding-bottom: 12px;
      align-items: baseline;
      border-bottom: 1px solid var(--line);
    }

    .narrative-panel header span {
      color: var(--muted);
      font-size: 12px;
      font-weight: 750;
      letter-spacing: .1em;
      text-transform: uppercase;
    }

    .narrative-panel header b { font-family: var(--serif); font-size: 17px; }

    .narrative-reading {
      display: flex;
      flex: 1;
      padding: 20px 2px 17px;
      flex-direction: column;
      justify-content: center;
      transition: opacity 150ms ease, transform 150ms ease;
    }

    .market-mirror-lab.is-updating .narrative-reading {
      opacity: .25;
      transform: translateY(4px);
    }

    .narrative-reading small {
      color: var(--muted);
      font-size: 12px;
    }

    .narrative-reading strong {
      margin: 7px 0 8px;
      font-family: var(--serif);
      font-size: clamp(22px, 3vw, 28px);
      line-height: 1.25;
    }

    .narrative-panel.bear .narrative-reading strong { color: var(--red); }
    .narrative-panel.bull .narrative-reading strong { color: var(--green); }

    .narrative-reading p {
      margin: 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.65;
    }

    .narrative-panel footer {
      display: grid;
      grid-template-columns: auto 32px;
      gap: 3px 8px;
      padding-top: 12px;
      align-items: center;
      border-top: 1px solid var(--line);
    }

    .narrative-panel footer span {
      color: var(--muted);
      font-size: 12px;
    }

    .narrative-panel footer b {
      grid-row: 1 / 3;
      grid-column: 2;
      color: var(--red);
      font-family: var(--serif);
      font-size: 27px;
      text-align: right;
    }

    .narrative-panel.bull footer b { color: var(--green); }

    .narrative-panel footer small {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.45;
    }

    .market-fact-core {
      display: grid;
      min-height: 300px;
      padding: 18px 13px;
      place-content: center;
      border-radius: 16px;
      color: #f7f3ea;
      background:
        radial-gradient(circle at 50% 22%, color-mix(in srgb, var(--market-accent) 36%, transparent), transparent 34%),
        linear-gradient(155deg, #1d211f, #2d322f);
      text-align: center;
      transition: background 220ms ease;
    }

    .market-fact-core span,
    .market-fact-core small {
      color: rgba(247, 243, 234, .6);
      font-size: 12px;
    }

    .market-fact-core b {
      margin: 18px 0 16px;
      color: #e3c66f;
      font-family: var(--serif);
      font-size: 23px;
      line-height: 1.35;
    }

    .market-mirror-verdict {
      display: grid;
      grid-template-columns: 130px 1fr;
      gap: 18px;
      margin-top: 13px;
      padding: 17px 19px;
      align-items: start;
      border-left: 4px solid var(--gold);
      background: var(--gold-soft);
    }

    .market-mirror-verdict span {
      color: var(--red);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: .08em;
    }

    .market-mirror-verdict b {
      font-family: var(--serif);
      font-size: 17px;
      line-height: 1.55;
    }

    .prediction-contract {
      margin-top: 21px;
      padding-top: 19px;
      border-top: 1px solid var(--line);
    }

    .contract-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 11px;
    }

    .contract-head span {
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .1em;
      text-transform: uppercase;
    }

    .contract-head b {
      color: var(--green);
      font-family: var(--serif);
      font-size: 17px;
    }

    .contract-fields {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 8px;
    }

    .contract-fields > div {
      min-height: 105px;
      padding: 13px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--paper);
    }

    .contract-fields span {
      color: var(--red);
      font-family: var(--serif);
      font-size: 12px;
      font-weight: 750;
    }

    .contract-fields b {
      display: block;
      margin: 9px 0 3px;
      font-size: 13px;
    }

    .contract-fields small {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.5;
    }

    .audit-gateway {
      position: relative;
      display: flex;
      min-height: 100svh;
      padding: 24px 28px 16px;
      overflow: hidden;
      flex-direction: column;
      background:
        radial-gradient(circle at 92% 5%, rgba(174, 127, 53, .15), transparent 25%),
        linear-gradient(145deg, #f1ebe1, #faf8f4 56%, #e8ede9);
      border-bottom: 1px solid var(--line);
    }

    .audit-gateway::before {
      position: absolute;
      width: 230px;
      height: 230px;
      right: -128px;
      top: -132px;
      border: 1px solid color-mix(in srgb, var(--gold) 30%, transparent);
      border-radius: 50%;
      box-shadow: 0 0 0 42px color-mix(in srgb, var(--gold) 5%, transparent);
      content: '';
      pointer-events: none;
    }

    .audit-gateway-head {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 190px minmax(0, 1fr);
      gap: 28px;
      margin-bottom: 12px;
      padding-bottom: 12px;
      align-items: end;
      border-bottom: 1px solid var(--line);
    }

    .audit-gateway-head > p {
      margin: 0;
      color: var(--red);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: .09em;
      line-height: 1.5;
      text-transform: uppercase;
    }

    .audit-gateway-head > div {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 24px;
    }

    .audit-gateway-head b {
      font-family: var(--serif);
      font-size: clamp(28px, 4.2vw, 42px);
      font-weight: 650;
      line-height: 1.2;
      letter-spacing: -.035em;
    }

    .audit-gateway-head span {
      max-width: 360px;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.6;
    }

    .audit-gateway .audit-lab {
      position: relative;
      z-index: 1;
      margin: 0;
      padding: 18px;
      border: 1px solid var(--line);
      border-radius: 19px;
      box-shadow: 0 18px 50px rgba(35, 31, 26, .08);
    }

    .audit-gateway .audit-claim {
      margin-bottom: 12px;
      padding: 12px 16px;
    }

    .audit-gateway .audit {
      grid-template-columns: 190px minmax(0, 1fr);
      gap: 18px;
    }

    .audit-gateway .gauge-wrap { position: static; }
    .audit-gateway .gauge { width: 158px; }
    .audit-gateway .gauge::before { inset: 15px; }
    .audit-gateway .gauge-readout b { font-size: 34px; }
    .audit-gateway .audit-status,
    .audit-gateway .audit-weak { width: 190px; }
    .audit-gateway .audit-list { gap: 7px; }
    .audit-gateway .audit-dimension { padding: 7px 10px; }
    .audit-gateway .audit-dimension legend { padding-bottom: 5px; }
    .audit-gateway .audit-choice > span { min-height: 52px; padding: 6px 9px; }

    .audit-scroll-cue {
      position: relative;
      z-index: 1;
      display: flex;
      margin: 14px auto 0;
      align-items: center;
      gap: 10px;
      color: var(--muted);
      text-decoration: none;
      font-size: 12px;
      font-weight: 750;
      letter-spacing: .08em;
    }

    .audit-scroll-cue i {
      color: var(--red);
      font-family: var(--serif);
      font-size: 20px;
      font-style: normal;
      animation: audit-cue 1.5s ease-in-out infinite;
    }

    @keyframes audit-cue {
      50% { transform: translateY(5px); }
    }

    .audit-lab {
      --audit-color: var(--red);
      --audit-soft: var(--red-soft);
      background:
        radial-gradient(circle at 12% 45%, color-mix(in srgb, var(--audit-color) 9%, transparent), transparent 26%),
        color-mix(in srgb, var(--paper-soft) 88%, white);
      transition: background 220ms ease;
    }

    .audit-claim {
      display: grid;
      grid-template-columns: 118px 1fr;
      gap: 18px;
      margin-bottom: 18px;
      padding: 16px 19px;
      align-items: center;
      border: 1px solid color-mix(in srgb, var(--red) 28%, var(--line));
      border-radius: 13px;
      background: var(--red-soft);
    }

    .audit-claim span {
      color: var(--red);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: .1em;
    }

    .audit-claim b {
      font-family: var(--serif);
      font-size: 18px;
      line-height: 1.45;
    }

    .audit {
      display: grid;
      grid-template-columns: 210px minmax(0, 1fr);
      gap: 25px;
      align-items: start;
    }

    .gauge-wrap {
      position: sticky;
      top: 92px;
      display: grid;
      place-items: center;
    }

    .gauge {
      --score-angle: 0deg;
      position: relative;
      display: grid;
      width: 182px;
      aspect-ratio: 1;
      place-items: center;
      border-radius: 50%;
      background: conic-gradient(var(--audit-color) var(--score-angle), var(--line) 0);
      box-shadow: 0 14px 30px rgba(35, 31, 26, .08);
      transition: background .22s ease;
    }

    .gauge::before {
      content: "";
      position: absolute;
      inset: 17px;
      border-radius: inherit;
      background: color-mix(in srgb, var(--paper-soft) 88%, white);
    }

    .gauge-readout {
      position: relative;
      text-align: center;
    }

    .gauge-readout b {
      display: block;
      color: var(--audit-color);
      font-family: var(--serif);
      font-size: 39px;
      line-height: 1;
      transition: color 180ms ease;
    }

    .gauge-readout small { color: var(--muted); font-size: 12px; }

    .gauge-readout strong {
      display: block;
      margin-top: 7px;
      color: var(--ink);
      font-size: 12px;
      font-weight: 800;
    }

    .audit-answered {
      margin-top: 11px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
    }

    .audit-status {
      width: 210px;
      margin-top: 9px;
      padding: 11px 13px;
      border-radius: var(--radius-node);
      color: var(--audit-color);
      background: var(--audit-soft);
      text-align: center;
      font-size: 12px;
      line-height: 1.6;
      transition: color 180ms ease, background 180ms ease;
    }

    .audit-weak {
      display: flex;
      width: 210px;
      margin-top: 8px;
      padding-top: 9px;
      justify-content: space-between;
      gap: 10px;
      border-top: 1px solid var(--line);
      font-size: 12px;
    }

    .audit-weak span { color: var(--muted); }
    .audit-weak b { color: var(--red); }

    .audit-list {
      display: grid;
      gap: 10px;
      min-width: 0;
    }

    .audit-dimension {
      min-width: 0;
      margin: 0;
      padding: 13px;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: color-mix(in srgb, var(--paper) 92%, white);
    }

    .audit-dimension legend {
      display: flex;
      width: 100%;
      padding: 0 1px 10px;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .audit-dimension legend span {
      color: var(--ink);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: .06em;
    }

    .audit-dimension legend b {
      color: var(--muted);
      font-size: 12px;
    }

    .audit-options {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 7px;
    }

    .audit-choice { min-width: 0; cursor: pointer; }

    .audit-choice input {
      position: absolute;
      width: 1px;
      height: 1px;
      opacity: 0;
      pointer-events: none;
    }

    .audit-choice > span {
      display: flex;
      min-height: 72px;
      padding: 10px;
      flex-direction: column;
      justify-content: center;
      border: 1px solid var(--line);
      border-radius: 11px;
      color: var(--muted);
      background: var(--paper);
      transition: border-color 170ms ease, background 170ms ease, transform 170ms ease;
    }

    .audit-choice:hover > span { transform: translateY(-1px); }

    .audit-choice input:focus-visible + span {
      outline: 3px solid color-mix(in srgb, var(--gold) 48%, transparent);
      outline-offset: 2px;
    }

    .audit-choice input:checked + span {
      border-color: var(--audit-color);
      color: var(--ink);
      background: var(--audit-soft);
      box-shadow: inset 0 -3px 0 var(--audit-color);
    }

    .audit-choice b {
      font-size: 12px;
      line-height: 1.35;
    }

    .audit-choice small {
      margin-top: 4px;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.4;
    }

    .audit-recap {
      display: grid;
      grid-template-columns: 160px 170px minmax(0, 1fr);
      gap: 20px;
      margin: 38px 0;
      padding: 24px;
      align-items: center;
      border: 1px solid color-mix(in srgb, var(--green) 30%, var(--line));
      border-radius: var(--radius-panel);
      background:
        radial-gradient(circle at 8% 50%, rgba(49, 95, 85, .1), transparent 24%),
        var(--green-soft);
    }

    .audit-recap > span {
      color: var(--green);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: .08em;
    }

    .audit-recap-score {
      display: flex;
      align-items: baseline;
      gap: 5px;
    }

    .audit-recap-score b {
      color: var(--green);
      font-family: var(--serif);
      font-size: 38px;
      line-height: 1;
    }

    .audit-recap-score small { color: var(--muted); font-size: 12px; }

    .audit-recap-score strong {
      margin-left: 7px;
      font-size: 12px;
    }

    .audit-recap p {
      margin: 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.7;
    }

    .audit-recap-controls {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
    }

    .audit-recap-row {
      display: grid;
      grid-template-columns: 106px minmax(0, 1fr);
      gap: 8px;
      align-items: center;
      padding: 9px 10px;
      border: 1px solid color-mix(in srgb, var(--green) 15%, var(--line));
      border-radius: 12px;
      background: color-mix(in srgb, var(--paper) 70%, transparent);
    }

    .audit-recap-row > span {
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: .03em;
    }

    .audit-recap-row > div {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 4px;
    }

    .audit-recap-row button {
      min-height: 36px;
      padding: 6px 5px;
      border: 1px solid transparent;
      border-radius: 9px;
      color: var(--muted);
      background: color-mix(in srgb, var(--paper) 84%, var(--green-soft));
      font: inherit;
      font-size: 12px;
      font-weight: 720;
      line-height: 1.25;
      cursor: pointer;
      transition: color .18s ease, background .18s ease, border-color .18s ease, transform .18s ease;
    }

    .audit-recap-row button:hover {
      color: var(--green);
      border-color: color-mix(in srgb, var(--green) 28%, var(--line));
      transform: translateY(-1px);
    }

    .audit-recap-row button.is-active {
      border-color: var(--green);
      color: var(--paper);
      background: var(--green);
      box-shadow: 0 5px 14px rgba(49, 95, 85, .16);
    }

    .audit-recap-row button:focus-visible {
      outline: 2px solid var(--gold);
      outline-offset: 2px;
    }

    .audit-recap-hint {
      grid-column: 1 / -1;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.55;
    }

    .quote {
      margin: 40px 0;
      padding: 28px 31px;
      border: 1px solid color-mix(in srgb, var(--gold) 30%, var(--line));
      border-radius: var(--radius-panel);
      color: var(--green);
      background: var(--gold-soft);
      font-family: var(--serif);
      font-size: 22px;
      line-height: 1.7;
    }

    .closing {
      margin-top: 38px;
      padding: 40px;
      border: 1px solid color-mix(in srgb, var(--gold) 35%, var(--line));
      border-radius: var(--radius-panel);
      background: color-mix(in srgb, var(--gold-soft) 68%, var(--paper));
      text-align: center;
    }

    .closing small {
      display: block;
      margin-bottom: 13px;
      color: var(--red);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .18em;
      text-transform: uppercase;
    }

    .closing p {
      margin: 0;
      color: var(--green);
      font-family: var(--serif);
      font-size: 28px;
      line-height: 1.6;
    }

    .footer {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      padding: 28px 68px;
      color: rgba(255,255,255,.58);
      background: #181411;
      font-size: 12px;
      letter-spacing: .1em;
      text-transform: uppercase;
    }

    .fact-opinion-page :where(button, input, a):focus-visible {
      outline: 3px solid color-mix(in srgb, var(--gold) 72%, white);
      outline-offset: 3px;
    }

    .fact-opinion-page.reveal-ready .reveal-target {
      opacity: 0;
      transform: translateY(22px);
      transition: opacity 620ms var(--ease-out), transform 620ms var(--ease-out);
    }

    .fact-opinion-page.reveal-ready .reveal-target.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0,0,0,0);
      white-space: nowrap;
      border: 0;
    }

    @media (max-width: 760px) {
      .fact-opinion-page {
        font-size: 16px;
        line-height: 1.86;
      }

      .shell {
        width: calc(100% - 20px);
        margin: 10px auto 28px;
      }

      .paper { border-radius: 24px; }

      .hero {
        min-height: 530px;
        padding: calc(18px + env(safe-area-inset-top)) 22px 48px;
      }

      .hero::before {
        width: 250px;
        height: 250px;
        right: -120px;
        top: -90px;
      }

      .hero::after {
        width: 120px;
        height: 120px;
        right: 35px;
        top: 112px;
        box-shadow: 0 0 0 31px rgba(255,255,255,.028), 0 0 0 62px rgba(255,255,255,.015);
      }

      .tool-button {
        min-width: 48px;
        min-height: 48px;
        padding: 0 14px;
      }

      .kicker { margin: 76px 0 45px; }
      .hero h1 { font-size: clamp(42px, 12.5vw, 58px); }
      .deck { margin-top: 25px; font-size: 17px; line-height: 1.72; }

      .chapter-nav {
        grid-template-columns: repeat(3, 1fr);
        gap: 7px;
        padding: 14px;
      }

      .chapter-nav a {
        min-height: 48px;
        padding: 8px 5px;
        font-size: 12px;
      }

      .content { padding: 12px 21px 52px; }

      .chapter {
        padding: 58px 0 18px;
        scroll-margin-top: 10px;
      }

      .chapter:first-child { padding-top: 46px; }
      h2 { margin-bottom: 25px; font-size: 31px; line-height: 1.3; }
      h3 { font-size: 21px; }
      .lead { font-size: 19px; line-height: 1.9; }
      .lead::first-letter { font-size: 53px; }

      .visual-block {
        margin: 34px -7px;
        padding: 20px 17px;
        border-radius: 18px;
      }

      .visual-head {
        align-items: flex-start;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 21px;
      }

      .visual-head p { max-width: none; text-align: left; }

      .layer-map {
        grid-template-columns: 1fr;
        gap: 6px;
      }

      .layer-map .arrow {
        min-height: 22px;
        transform: rotate(90deg);
      }

      .node {
        min-height: 94px;
        padding: 14px;
      }

      .constraint-row {
        grid-template-columns: 1fr;
        gap: 5px;
      }

      .constraint {
        padding: 8px 10px;
        border-top: 0;
        border-left: 2px solid var(--line);
        text-align: left;
      }

      .newton-formulas { grid-template-columns: 1fr; }

      .newton-formula-card {
        min-height: 132px;
        padding: 18px 19px;
      }

      .newton-formula-card b { font-size: 31px; }

      .formula-bridge {
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
      }

      .formula-bridge i:first-child::after { display: none; }

      .newton-simulator { grid-template-columns: 1fr; }
      .newton-controls { padding: 23px 20px; }
      .newton-stage { min-height: 305px; padding: 23px 20px 19px; }
      .newton-track { margin-top: 18px; }
      .newton-cart { width: 74px; }
      .cart-load { left: 20px; }

      .newton-chain {
        grid-template-columns: 1fr;
        gap: 7px;
      }

      .newton-chain-card {
        min-height: auto;
        padding: 17px 18px;
      }

      .newton-chain-card::after { display: none; }

      .newton-chain-card b {
        display: inline;
        margin: 0 0 0 9px;
        font-size: 17px;
      }

      .newton-chain-card p { margin-top: 8px; font-size: 12px; }
      .newton-scope .scope-title { width: 100%; text-align: center; }
      .theory-boundary { grid-template-columns: 1fr; margin: 28px 0; }

      .xray { grid-template-columns: 1fr; }
      .xray-claim { min-height: 150px; }
      .xray-part { grid-template-columns: 52px 1fr; }

      .claim-stack-block { padding: 22px 18px; }

      .claim-stack {
        grid-template-columns: 1fr;
        gap: 9px;
      }

      .fact-anchor {
        min-height: 275px;
        padding: 21px;
      }

      .fact-anchor b { font-size: 31px; }

      .added-layer {
        grid-template-columns: 64px minmax(0, 1fr);
        min-height: 86px;
        padding: 14px;
      }

      .added-layer b { font-size: 16px; }

      .layer-equation {
        gap: 5px;
        margin-top: 13px;
      }

      .layer-equation span,
      .layer-equation b { padding: 7px 8px; }

      .layer-conclusion {
        grid-template-columns: 1fr;
        gap: 8px;
        margin-top: 21px;
      }

      .layer-conclusion b { font-size: 23px; }

      .formula-proof-flow { grid-template-columns: 1fr; }

      .proof-card,
      .proof-formula {
        min-height: 134px;
        padding: 17px;
      }

      .proof-arrow {
        grid-template-columns: auto auto;
        gap: 8px;
        min-height: 31px;
        align-items: center;
      }

      .proof-arrow i { transform: rotate(90deg); }

      .formula-boundary { grid-template-columns: 1fr; }

      .formula-final {
        grid-template-columns: 1fr;
        gap: 9px;
      }

