      z-index: 1;
      display: grid;
      grid-template-columns: minmax(220px, .72fr) minmax(360px, 1.28fr);
      margin-top: 18px;
      overflow: hidden;
      border: 1px solid color-mix(in srgb, var(--ink) 22%, var(--line));
      border-radius: 18px;
      background: var(--ink);
      box-shadow: 0 18px 45px rgba(35, 31, 26, .12);
    }

    .newton-controls {
      display: grid;
      gap: 20px;
      align-content: center;
      padding: 26px 25px;
      color: var(--ink);
      background: color-mix(in srgb, var(--paper) 92%, white);
    }

    .newton-control {
      display: grid;
      gap: 10px;
    }

    .control-label,
    .range-scale {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .control-label label {
      font-size: 13px;
      font-weight: 750;
    }

    .control-label output {
      min-width: 52px;
      padding: 5px 8px;
      border: 1px solid var(--line);
      border-radius: var(--radius-pill);
      color: var(--red);
      background: var(--paper);
      text-align: center;
      font-family: var(--serif);
      font-size: 14px;
      font-weight: 700;
    }

    .newton-control input[type='range'] {
      width: 100%;
      height: 5px;
      margin: 2px 0;
      appearance: none;
      border-radius: var(--radius-pill);
      outline: none;
      background: linear-gradient(90deg, var(--red), color-mix(in srgb, var(--red) 18%, var(--line)));
      cursor: ew-resize;
    }

    .newton-control input[type='range']::-webkit-slider-thumb {
      width: 19px;
      height: 19px;
      appearance: none;
      border: 4px solid var(--paper);
      border-radius: 50%;
      background: var(--red);
      box-shadow: 0 0 0 1px color-mix(in srgb, var(--red) 55%, var(--line)), 0 3px 9px rgba(35, 31, 26, .18);
    }

    .newton-control input[type='range']::-moz-range-thumb {
      width: 12px;
      height: 12px;
      border: 4px solid var(--paper);
      border-radius: 50%;
      background: var(--red);
      box-shadow: 0 0 0 1px color-mix(in srgb, var(--red) 55%, var(--line));
    }

    .range-scale {
      color: var(--muted);
      font-size: 10px;
    }

    .control-hint {
      margin: 0;
      padding-top: 16px;
      border-top: 1px solid var(--line);
      color: var(--muted);
      font-size: 11px;
      line-height: 1.65;
    }

    .newton-stage {
      display: grid;
      min-height: 335px;
      padding: 26px 28px 22px;
      align-content: space-between;
      color: #f4efe5;
      background:
        radial-gradient(circle at 72% 12%, rgba(198, 164, 89, .14), transparent 26%),
        linear-gradient(145deg, #292b27, #1c1e1c);
    }

    .newton-readout span {
      display: block;
      color: rgba(244, 239, 229, .52);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .12em;
    }

    .newton-readout b {
      display: block;
      margin-top: 5px;
      font-family: var(--serif);
      font-size: clamp(24px, 3.2vw, 35px);
      font-weight: 500;
    }

    .newton-readout strong {
      color: #d7bd79;
      font-weight: 650;
    }

    .newton-track {
      position: relative;
      height: 94px;
      margin: 24px 0 20px;
      border-bottom: 2px solid rgba(244, 239, 229, .34);
      background: repeating-linear-gradient(90deg, transparent 0, transparent 49px, rgba(244, 239, 229, .055) 50px);
    }

    .track-mark {
      position: absolute;
      bottom: -7px;
      width: 1px;
      height: 11px;
      background: rgba(244, 239, 229, .38);
    }

    .mark-one { left: 16%; }
    .mark-two { left: 50%; }
    .mark-three { left: 84%; }

    .newton-cart {
      position: absolute;
      width: 86px;
      height: 48px;
      left: var(--cart-position);
      bottom: 11px;
      border: 1px solid rgba(244, 239, 229, .5);
      border-radius: 8px 8px 3px 3px;
      background: linear-gradient(135deg, #c5624c, #9d3f31);
      box-shadow: 0 10px 20px rgba(0, 0, 0, .28);
      transform: translateX(-50%);
      transition: left 520ms cubic-bezier(.2, .8, .2, 1);
    }

    .cart-load {
      display: grid;
      position: absolute;
      width: 34px;
      height: 29px;
      left: 26px;
      top: 9px;
      place-items: center;
      border: 1px solid rgba(255,255,255,.3);
      border-radius: 4px;
      color: rgba(255,255,255,.82);
      font-family: var(--serif);
      font-style: italic;
      font-weight: 700;
    }

    .cart-wheel {
      position: absolute;
      width: 15px;
      height: 15px;
      bottom: -11px;
      border: 3px solid #b9b4a9;
      border-radius: 50%;
      background: #252724;
    }

    .wheel-left { left: 12px; }
    .wheel-right { right: 12px; }

    .force-vector {
      position: absolute;
      width: var(--force-width);
      max-width: 76px;
      min-width: 34px;
      right: calc(100% + 8px);
      top: 22px;
      border-top: 2px solid #d7bd79;
      color: #d7bd79;
      font-family: var(--serif);
      font-size: 11px;
      line-height: 0;
      text-align: center;
      transition: width 320ms ease;
    }

    .force-vector::after {
      position: absolute;
      width: 7px;
      height: 7px;
      right: -1px;
      top: -5px;
      border-top: 2px solid #d7bd79;
      border-right: 2px solid #d7bd79;
      content: '';
      transform: rotate(45deg);
    }

    .newton-stage > p {
      min-height: 43px;
      margin: 0;
      color: rgba(244, 239, 229, .68);
      font-size: 12px;
      line-height: 1.7;
    }

    .newton-chain {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 9px;
      margin-top: 18px;
    }

    .newton-chain-card {
      position: relative;
      min-height: 177px;
      padding: 19px 17px 16px;
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: color-mix(in srgb, var(--paper) 90%, white);
    }

    .newton-chain-card::after {
      position: absolute;
      width: 46px;
      height: 1px;
      right: -28px;
      top: 31px;
      background: var(--red);
      content: '';
    }

    .newton-chain-card:last-child::after { display: none; }

    .newton-chain-card > span {
      color: var(--red);
      font-family: var(--serif);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .1em;
    }

    .newton-chain-card b {
      display: block;
      margin: 17px 0 7px;
      font-family: var(--serif);
      font-size: 18px;
    }

    .newton-chain-card p {
      margin: 0;
      color: var(--muted);
      font-size: 11px;
      line-height: 1.65;
    }

    .newton-scope {
      position: relative;
      z-index: 1;
      display: flex;
      gap: 8px;
      margin-top: 14px;
      flex-wrap: wrap;
      align-items: center;
    }

    .newton-scope span {
      padding: 8px 11px;
      border: 1px solid var(--line);
      border-radius: var(--radius-pill);
      color: var(--muted);
      background: color-mix(in srgb, var(--paper) 86%, white);
      font-size: 10px;
      line-height: 1.2;
    }

    .newton-scope .scope-title {
      border-color: var(--ink);
      color: var(--paper);
      background: var(--ink);
      font-weight: 700;
    }

    .theory-boundary {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      margin: 30px 0;
    }

    .theory-boundary > div {
      padding: 22px 23px;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--paper);
    }

    .theory-boundary > div:first-child { border-top: 3px solid var(--gold); }
    .theory-boundary > div:last-child { border-top: 3px solid var(--green); }

    .theory-boundary span {
      color: var(--muted);
      font-size: 10px;
      font-weight: 750;
      letter-spacing: .1em;
    }

    .theory-boundary b {
      display: block;
      margin: 9px 0 7px;
      font-family: var(--serif);
      font-size: 17px;
      line-height: 1.45;
    }

    .theory-boundary p {
      margin: 0;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.75;
    }

    .xray {
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 18px;
      align-items: stretch;
    }

    .xray-claim {
      display: flex;
      min-height: 220px;
      padding: 25px;
      flex-direction: column;
      justify-content: center;
      border: 1px solid color-mix(in srgb, var(--red) 25%, var(--line));
      border-radius: var(--radius-node);
      background: var(--red-soft);
    }

    .xray-claim span { color: var(--muted); font-size: 12px; }
    .xray-claim b { margin-top: 12px; font-family: var(--serif); font-size: 28px; }

    .xray-parts { display: grid; gap: 8px; }

    .xray-part {
      display: grid;
      grid-template-columns: 60px 1fr;
      gap: 12px;
      align-items: center;
      padding: 10px 13px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--paper);
      font-size: 13px;
      line-height: 1.5;
    }

    .xray-part b { color: var(--red); }

    .model-funnel {
      display: grid;
      grid-template-columns: 1fr 70px 165px 70px 1fr;
      align-items: center;
      gap: 8px;
    }

    .chip-cloud {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-content: center;
    }

    .chip {
      padding: 9px 12px;
      border-radius: var(--radius-pill);
      color: var(--muted);
      background: var(--paper);
      border: 1px solid var(--line);
      font-size: 12px;
      line-height: 1.3;
    }

    .model-core {
      display: grid;
      width: 165px;
      aspect-ratio: 1;
      place-items: center;
      padding: 20px;
      border: 1px solid color-mix(in srgb, var(--gold) 38%, var(--line));
      border-radius: 50%;
      background: var(--gold-soft);
      text-align: center;
      font-family: var(--serif);
      font-size: 20px;
      line-height: 1.4;
    }

    .model-output { display: grid; gap: 8px; }

    .output-pill {
      padding: 11px 13px;
      border-radius: var(--radius-pill);
      background: var(--green-soft);
      border: 1px solid color-mix(in srgb, var(--green) 24%, var(--line));
      text-align: center;
      font-size: 13px;
    }

    .formula-strip {
      margin-top: 22px;
      padding: 15px 18px;
      border-radius: var(--radius-node);
      color: var(--green);
      background: color-mix(in srgb, var(--green-soft) 72%, var(--paper));
      text-align: center;
      font-family: var(--serif);
      font-size: 18px;
    }

    .lanes { display: grid; gap: 18px; }

    .lane {
      display: grid;
      grid-template-columns: 92px 1fr;
      gap: 14px;
      align-items: center;
    }

    .lane-name {
      color: var(--gold);
      font-weight: 700;
    }

    .lane.slow .lane-name { color: var(--green); }

    .lane-flow {
      display: grid;
      grid-template-columns: repeat(7, minmax(0, 1fr));
      align-items: center;
    }

    .lane.slow .lane-flow { grid-template-columns: repeat(9, minmax(0, 1fr)); }

    .lane-step {
      display: grid;
      min-height: 76px;
      padding: 9px;
      place-items: center;
      border: 1px solid color-mix(in srgb, var(--gold) 26%, var(--line));
      border-radius: 12px;
      background: var(--gold-soft);
      text-align: center;
      font-size: 12px;
      line-height: 1.4;
    }

    .slow .lane-step {
      border-color: color-mix(in srgb, var(--green) 25%, var(--line));
      background: var(--green-soft);
    }

    .warning-strip {
      margin-top: 21px;
      padding: 15px 17px;
      border-left: 4px solid var(--red);
      border-radius: 4px var(--radius-node) var(--radius-node) 4px;
      background: var(--red-soft);
      font-size: 14px;
    }

    .falsify-lab {
      --outcome-accent: var(--green);
      --outcome-soft: var(--green-soft);
      background:
        linear-gradient(rgba(24, 20, 17, .028) 1px, transparent 1px),
        linear-gradient(90deg, rgba(24, 20, 17, .028) 1px, transparent 1px),
        var(--paper-soft);
      background-size: 28px 28px;
    }

    .falsify-lab[data-outcome="flat"] {
      --outcome-accent: var(--gold);
      --outcome-soft: var(--gold-soft);
    }

    .falsify-lab[data-outcome="down"] {
      --outcome-accent: var(--red);
      --outcome-soft: var(--red-soft);
    }

    .outcome-switcher {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 9px;
      margin-bottom: 18px;
    }

    .outcome-button {
      display: grid;
      min-height: 92px;
      padding: 13px 15px;
      border: 1px solid var(--line);
      border-radius: var(--radius-node);
      color: var(--muted);
      background: color-mix(in srgb, var(--paper) 88%, transparent);
      text-align: left;
      cursor: pointer;
      transition:
        border-color 280ms ease,
        background-color 280ms ease,
        color 280ms ease,
        transform 280ms ease;
    }

    .outcome-button:hover { transform: translateY(-2px); }

    .outcome-button.is-active {
      border-color: color-mix(in srgb, var(--outcome-accent) 45%, var(--line));
      color: var(--ink);
      background: var(--outcome-soft);
    }

    .outcome-button span {
      color: var(--outcome-accent);
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: .12em;
    }

    .outcome-button b { margin: 5px 0 1px; font-size: 14px; }
    .outcome-button small { font-size: 11px; }

    .model-compare {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 13px;
    }

    .belief-model {
      position: relative;
      min-width: 0;
      padding: 20px;
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: var(--paper);
    }

    .belief-model::after {
      content: "";
      position: absolute;
      top: 0;
      right: 0;
      width: 5px;
      height: 100%;
      background: var(--red);
      opacity: .75;
    }

    .belief-model-open::after { background: var(--green); }

    .belief-model header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--line);
    }

    .belief-model header span {
      color: var(--muted);
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: .12em;
      text-transform: uppercase;
    }

    .belief-model header b { font-family: var(--serif); font-size: 19px; }

    .model-premise {
      min-height: 53px;
      margin: 14px 0;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.6;
    }

    .model-route {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 18px minmax(0, 1.15fr) 18px minmax(0, 1fr);
      align-items: stretch;
      gap: 4px;
    }

    .model-route span,
    .model-route strong {
      display: grid;
      min-height: 72px;
      padding: 8px;
      place-items: center;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: var(--paper-soft);
      text-align: center;
      font-size: 11px;
      line-height: 1.4;
    }

    .model-route span:first-child {
      border-color: color-mix(in srgb, var(--outcome-accent) 35%, var(--line));
      background: var(--outcome-soft);
    }

    .belief-model-closed .model-route strong {
      color: #f8f5ec;
      background: var(--red);
    }

    .belief-model-open .model-route strong {
      color: #f8f5ec;
      background: var(--green);
    }

    .model-route i {
      display: grid;
      place-items: center;
      color: var(--muted);
      font-style: normal;
      font-size: 11px;
    }

    .confidence-line {
      display: grid;
      grid-template-columns: auto auto 1fr;
      gap: 8px;
      align-items: center;
      margin-top: 13px;
      padding-top: 12px;
      border-top: 1px solid var(--line);
      font-size: 10px;
    }

    .confidence-line > span { color: var(--muted); }
    .confidence-line > b { color: var(--red); font-size: 19px; line-height: 1; }
    .belief-model-open .confidence-line > b { color: var(--green); }
    .confidence-line > small { color: var(--muted); text-align: right; }

    .difference-strip {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 18px;
      align-items: center;
      margin-top: 16px;
      padding: 16px 18px;
      border-left: 4px solid var(--gold);
      background: var(--gold-soft);
    }

    .difference-strip span {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .1em;
    }

    .difference-strip p { font-size: 13px; line-height: 1.65; }

    .immunity-block {
      background: color-mix(in srgb, var(--paper-soft) 74%, var(--green-soft));
    }

    .immunity-system {
      display: grid;
      grid-template-columns: .72fr 1.8fr .9fr;
      gap: 13px;
      align-items: stretch;
    }

    .evidence-input,
    .belief-core {
      display: flex;
      min-height: 250px;
      padding: 18px;
      flex-direction: column;
      justify-content: center;
      border: 1px solid var(--line);
      border-radius: 18px;
      text-align: center;
    }

    .evidence-input { background: var(--blue-soft); }

    .evidence-input span,
    .belief-core > span,
    .defense-layer-title span {
      color: var(--muted);
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: .12em;
      text-transform: uppercase;
    }

    .evidence-input b,
    .belief-core > b { margin: 8px 0; font-family: var(--serif); font-size: 18px; }
    .evidence-input small,
    .belief-core > small { color: var(--muted); font-size: 11px; line-height: 1.5; }

    .defense-layer {
      padding: 16px;
      border: 1px solid color-mix(in srgb, var(--gold) 35%, var(--line));
      border-radius: 18px;
      background: var(--gold-soft);
    }

    .defense-layer-title {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }

    .defense-layer-title b { font-family: var(--serif); font-size: 17px; }

    .defense-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
    }

    .defense-card {
      min-height: 96px;
      padding: 11px;
      border: 1px solid color-mix(in srgb, var(--gold) 23%, var(--line));
      border-radius: 11px;
      background: color-mix(in srgb, var(--paper) 80%, transparent);
    }

    .defense-card span {
      color: var(--red);
      font-family: var(--mono);
      font-size: 9px;
    }

    .defense-card b { display: block; margin: 3px 0; font-size: 12px; }
    .defense-card small { color: var(--muted); font-size: 10px; line-height: 1.45; }

    .belief-core {
      color: #f8f5ec;
      background:
        radial-gradient(circle at 50% 45%, rgba(255,255,255,.08), transparent 35%),
        linear-gradient(145deg, #181411, #315f55);
    }

    .belief-core > span,
    .belief-core > small { color: rgba(248,245,236,.66); }

    .belief-lock {
      position: relative;
      width: 42px;
      height: 36px;
      margin: 17px auto 3px;
      border: 2px solid var(--gold);
      border-radius: 8px;
    }

    .belief-lock::before {
      content: "";
      position: absolute;
      left: 8px;
      bottom: calc(100% - 3px);
      width: 22px;
      height: 20px;
      border: 2px solid var(--gold);
      border-bottom: 0;
      border-radius: 14px 14px 0 0;
    }

    .belief-lock i {
      position: absolute;
      top: 13px;
      left: 17px;
      width: 5px;
      height: 10px;
      border-radius: 4px;
      background: var(--gold);
    }

    .belief-payoffs {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 9px;
      margin-top: 13px;
    }

    .belief-payoffs > div {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 3px 9px;
      padding: 13px;
      border: 1px solid color-mix(in srgb, var(--violet) 22%, var(--line));
      border-radius: 12px;
      background: var(--violet-soft);
    }

    .belief-payoffs span {
      grid-row: span 2;
      color: var(--violet);
      font-family: var(--mono);
      font-size: 9px;
    }

    .belief-payoffs b { font-size: 12px; }
    .belief-payoffs small { color: var(--muted); font-size: 10px; line-height: 1.45; }

    .falsify-boundary {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 13px;
      margin: 40px 0;
    }

    .falsify-boundary article {
      padding: 23px;
      border: 1px solid color-mix(in srgb, var(--green) 28%, var(--line));
      border-radius: var(--radius-panel);
      background: var(--green-soft);
    }

    .falsify-boundary article + article {
      border-color: color-mix(in srgb, var(--red) 28%, var(--line));
      background: var(--red-soft);
    }

    .falsify-boundary span {
      display: inline-block;
      margin-bottom: 13px;
      color: var(--green);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .14em;
    }

    .falsify-boundary article + article span { color: var(--red); }
    .falsify-boundary b { display: block; font-family: var(--serif); font-size: 18px; line-height: 1.65; }
    .falsify-boundary p { margin-top: 12px; color: var(--muted); font-size: 12px; line-height: 1.65; }

    .sample-funnel {
      display: grid;
      grid-template-columns: 1fr 25px 1fr 25px 1fr;
      align-items: center;
      margin-top: 20px;
    }

    .sample-step {
      padding: 12px;
      border-radius: var(--radius-node);
      background: var(--paper);
      border: 1px solid var(--line);
      text-align: center;
      font-size: 12px;
      line-height: 1.45;
    }

    .market-grid {
      display: grid;
      grid-template-columns: 1fr 94px 1fr;
      gap: 8px 11px;
      align-items: stretch;
    }

    .market-head {
      padding-bottom: 8px;
      color: var(--muted);
      border-bottom: 1px solid var(--line);
      text-align: center;
      font-size: 12px;
    }

    .market-cell,
    .price-path {
      display: grid;
      min-height: 66px;
      padding: 10px;
      place-items: center;
      border-radius: var(--radius-node);
      text-align: center;
      font-size: 13px;
      line-height: 1.4;
    }

    .market-cell.bear {
      border: 1px solid color-mix(in srgb, var(--red) 25%, var(--line));
      background: var(--red-soft);
    }

    .market-cell.bull {
      border: 1px solid color-mix(in srgb, var(--green) 25%, var(--line));
      background: var(--green-soft);
    }

    .price-path {
      border: 1px solid color-mix(in srgb, var(--blue) 25%, var(--line));
      background: var(--blue-soft);
      font-weight: 700;
    }

    .market-lock {
      display: grid;
      grid-template-columns: 1fr 94px 1fr;
      gap: 11px;
      margin-top: 10px;
    }

    .lock-node {
      padding: 12px;
      border-radius: var(--radius-node);
      color: var(--red);
      background: color-mix(in srgb, var(--red-soft) 74%, var(--paper));
      text-align: center;
      font-size: 12px;
    }

    .test-bar {
      display: grid;
      grid-template-columns: repeat(7, minmax(0, 1fr));
      align-items: center;
      margin-top: 21px;
      padding-top: 19px;
      border-top: 1px solid var(--line);
    }

    .test-point {
      display: grid;
      min-height: 58px;
      padding: 8px;
      place-items: center;
      border-radius: 12px;
      background: var(--paper);
      border: 1px solid var(--line);
      text-align: center;
      font-size: 11px;
      line-height: 1.4;
    }

    .audit {
      display: grid;
      grid-template-columns: 190px 1fr;
      gap: 30px;
      align-items: center;
    }

    .gauge-wrap { display: grid; place-items: center; }

    .gauge {
      --score-angle: 0deg;
      position: relative;
      display: grid;
      width: 180px;
      aspect-ratio: 1;
      place-items: center;
      border-radius: 50%;
      background: conic-gradient(var(--green) var(--score-angle), var(--line) 0);
      transition: background .22s ease;
    }

    .gauge::before {
      content: "";
      position: absolute;
      inset: 18px;
      border-radius: inherit;
      background: var(--paper-soft);
    }

    .gauge-readout {
      position: relative;
      text-align: center;
    }

    .gauge-readout b {
      display: block;
      color: var(--green);
      font-family: var(--serif);
      font-size: 32px;
      line-height: 1.2;
    }

    .gauge-readout small { color: var(--muted); font-size: 11px; }

    .audit-list {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 9px;
      min-width: 0;
      margin: 0;
      padding: 0;
      border: 0;
    }

    .audit-item {
      display: flex;
      min-height: 58px;
      padding: 10px 12px;
      align-items: center;
      gap: 10px;
      border: 1px solid var(--line);
      border-radius: var(--radius-node);
      background: var(--paper);
      cursor: pointer;
      font-size: 12px;
      line-height: 1.45;
    }

    .audit-item input {
      width: 21px;
      height: 21px;
      flex: 0 0 auto;
      accent-color: var(--green);
    }

    .audit-status {
      margin-top: 20px;
      padding: 15px 17px;
      border-radius: var(--radius-node);
      color: var(--green);
      background: var(--green-soft);
      text-align: center;
      font-size: 14px;
    }

    .quote {
      margin: 40px 0;
      padding: 28px 31px;
      border: 1px solid color-mix(in srgb, var(--gold) 30%, var(--line));
      border-radius: var(--radius-panel);
      color: var(--green);
      background: var(--gold-soft);
      font-family: var(--serif);
      font-size: 22px;
      line-height: 1.7;
    }

    .closing {
      margin-top: 38px;
      padding: 40px;
      border: 1px solid color-mix(in srgb, var(--gold) 35%, var(--line));
      border-radius: var(--radius-panel);
      background: color-mix(in srgb, var(--gold-soft) 68%, var(--paper));
      text-align: center;
    }

    .closing small {
      display: block;
      margin-bottom: 13px;
      color: var(--red);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .18em;
      text-transform: uppercase;
    }

    .closing p {
      margin: 0;
      color: var(--green);
      font-family: var(--serif);
      font-size: 28px;
      line-height: 1.6;
    }

    .footer {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      padding: 28px 68px;
      color: rgba(255,255,255,.58);
      background: #181411;
      font-size: 10px;
      letter-spacing: .1em;
      text-transform: uppercase;
    }

    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0,0,0,0);
      white-space: nowrap;
      border: 0;
    }

    @media (max-width: 760px) {
      .fact-opinion-page {
        font-size: 16px;
        line-height: 1.86;
      }

      .shell {
        width: calc(100% - 20px);
        margin: 10px auto 28px;
      }

      .paper { border-radius: 24px; }

      .hero {
        min-height: 530px;
        padding: calc(18px + env(safe-area-inset-top)) 22px 48px;
      }

      .hero::before {
        width: 250px;
        height: 250px;
        right: -120px;
        top: -90px;
      }

      .hero::after {
        width: 120px;
