<script is:inline>
  (() => {
    const progress = document.getElementById('factProgress');
    const checks = [...document.querySelectorAll('.audit-list input[type="checkbox"]')];
    const gauge = document.getElementById('auditGauge');
    const score = document.getElementById('auditScore');
    const status = document.getElementById('auditStatus');
    const messages = [
      '目前更像一个标签：现实还没有可以反驳它的入口。',
      '开始接触事实，但判断仍然很容易吸收任何结果。',
      '已有局部结构；还需要替代解释和明确边界。',
      '模型开始成形，但尚未充分承担失败风险。',
      '已经可以检验；新的结果能够提高或降低可信度。',
      '模型高度开放，只剩更新规则需要提前固定。',
      '它终于允许现实说“不”：这才是可更新的观点。'
    ];

    const updateProgress = () => {
      if (!progress) return;
      const scrollable = document.documentElement.scrollHeight - window.innerHeight;
      const ratio = scrollable > 0 ? window.scrollY / scrollable : 0;
      progress.style.width = `${Math.min(100, Math.max(0, ratio * 100))}%`;
    };

    const updateAudit = () => {
      if (!gauge || !score || !status) return;
      const count = checks.filter((item) => item.checked).length;
      score.textContent = `${count} / 6`;
      status.textContent = messages[count];
      gauge.style.setProperty('--score-angle', `${count * 60}deg`);
      gauge.setAttribute('aria-label', `模型开放入口${count}项，共六项`);
    };

    window.addEventListener('scroll', updateProgress, { passive: true });
    checks.forEach((check) => check.addEventListener('change', updateAudit));
    updateProgress();
    updateAudit();
  })();
</script>

