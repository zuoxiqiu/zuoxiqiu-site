      .quote { padding: 23px 21px; border-radius: 18px; font-size: 20px; }
      .closing { padding: 31px 21px; border-radius: 18px; }
      .closing p { font-size: 24px; }
      .footer { padding: 24px 21px; flex-direction: column; }
    }

    @media (max-width: 370px) {
      .shell { width: calc(100% - 12px); margin-top: 6px; }
      .hero { padding-inline: 18px; }
      .content { padding-inline: 17px; }
      .chapter-nav { padding-inline: 10px; }
      .hero h1 { font-size: 40px; }
      .visual-block { margin-inline: -5px; padding-inline: 14px; }
    }

    @media print {
      .fact-opinion-page {
        --page: #fff;
        --paper: #fff;
        --paper-soft: #f8f6f0;
        --ink: #111;
        --muted: #555;
        --line: #ddd;
      }

      .fact-opinion-page { background: #fff; font-size: 11pt; }
      .fact-progress, .hero-tools, .chapter-nav { display: none; }
      .shell { width: 100%; margin: 0; }
      .paper { border: 0; border-radius: 0; box-shadow: none; }
      .hero { min-height: auto; padding: 45px; print-color-adjust: exact; -webkit-print-color-adjust: exact; }
      .kicker { margin: 20px 0 35px; }
      .content { padding: 10px 45px 40px; }
      .visual-block, .audit-budget, .self-audit, .quote, .closing { break-inside: avoid; }
      .footer { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
    }
  

  .fact-opinion-page {
    position: relative;
    margin-top: 0;
    background: transparent;
  }

  .fact-opinion-page .shell {
    margin-top: 0;
  }

  .fact-opinion-page .paper {
    border-top: 2px solid var(--ink);
  }

  .fact-opinion-page .chapter-nav {
    position: sticky;
    top: 0;
    z-index: 30;
    backdrop-filter: blur(16px);
  }

  .fact-opinion-page .hero {
    animation: fact-hero-in 900ms var(--ease-out) both;
  }

  .fact-opinion-page .hero h1,
  .fact-opinion-page .hero .deck,
  .fact-opinion-page .hero .kicker {
    animation: fact-copy-in 900ms var(--ease-out) both;
  }

  .fact-opinion-page .hero h1 {
    animation-delay: 120ms;
  }

  .fact-opinion-page .hero .deck {
    animation-delay: 220ms;
  }

  .fact-opinion-page .chapter {
    scroll-margin-top: 5.5rem;
  }

  @keyframes fact-hero-in {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
  }

  @keyframes fact-copy-in {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
  }

  @media (max-width: 760px) {
    .fact-opinion-page {
      margin-top: 0;
    }

    .fact-opinion-page .shell {
      width: 100%;
      margin-bottom: 2rem;
    }

    .fact-opinion-page .paper {
      border-inline: 0;
      border-radius: 0;
    }

    .fact-opinion-page .chapter-nav {
      top: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fact-opinion-page .hero,
    .fact-opinion-page .hero h1,
    .fact-opinion-page .hero .deck,
    .fact-opinion-page .hero .kicker {
      animation: none;
    }

    .fact-opinion-page.reveal-ready .reveal-target {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script is:inline>
  (() => {
    const progress = document.getElementById('factProgress');
    const auditInputs = [...document.querySelectorAll('.audit-choice input[type="radio"]')];
    const auditDimensions = [...document.querySelectorAll('[data-audit-dimension]')];
    const auditLab = document.querySelector('.audit-lab');
    const gauge = document.getElementById('auditGauge');
    const score = document.getElementById('auditScore');
    const status = document.getElementById('auditStatus');
    const auditVerdict = document.getElementById('auditVerdict');
    const auditAnswered = document.getElementById('auditAnswered');
    const auditWeakSpot = document.getElementById('auditWeakSpot');
    const auditRecapScore = document.getElementById('auditRecapScore');
    const auditRecapVerdict = document.getElementById('auditRecapVerdict');
    const auditRecapText = document.getElementById('auditRecapText');
    const auditSyncButtons = [...document.querySelectorAll('[data-audit-sync-dimension]')];
    const layerQuiz = document.querySelector('.layer-quiz');
    const layerQuizStage = document.getElementById('layerQuizStage');
    const layerQuizIndex = document.getElementById('layerQuizIndex');
    const layerQuizTrack = document.getElementById('layerQuizTrack');
    const layerQuizLabel = document.getElementById('layerQuizLabel');
    const layerQuizPrompt = document.getElementById('layerQuizPrompt');
    const layerQuizFeedback = document.getElementById('layerQuizFeedback');
    const layerQuizFeedbackKicker = document.getElementById('layerQuizFeedbackKicker');
    const layerQuizFeedbackTitle = document.getElementById('layerQuizFeedbackTitle');
    const layerQuizFeedbackText = document.getElementById('layerQuizFeedbackText');
    const layerQuizStatus = document.getElementById('layerQuizStatus');
    const layerQuizNext = document.getElementById('layerQuizNext');
    const layerChoiceButtons = [...document.querySelectorAll('[data-layer-choice]')];
    const marketMirrorLab = document.querySelector('.market-mirror-lab');
    const marketNarrativeCards = [...document.querySelectorAll('[data-narrative-id]')];
    const marketDropzones = [...document.querySelectorAll('[data-market-slot]')];
    const marketPuzzleCount = document.getElementById('marketPuzzleCount');
    const marketPuzzleReset = document.getElementById('marketPuzzleReset');
    const marketPuzzleStatus = document.getElementById('marketPuzzleStatus');
    const marketMirrorVerdict = document.getElementById('marketMirrorVerdict');
    const modelLab = document.querySelector('.model-lab');
    const modelEvidenceButtons = [...document.querySelectorAll('[data-model-evidence-choice]')];
    const productSupport = document.getElementById('productSupport');
    const productScore = document.getElementById('productScore');
    const productReading = document.getElementById('productReading');
    const marketingSupport = document.getElementById('marketingSupport');
    const marketingScore = document.getElementById('marketingScore');
    const marketingReading = document.getElementById('marketingReading');
    const contextSupport = document.getElementById('contextSupport');
    const contextScore = document.getElementById('contextScore');
    const contextReading = document.getElementById('contextReading');
    const modelEvidenceVerdict = document.getElementById('modelEvidenceVerdict');
    const thinkingLab = document.querySelector('.thinking-lab');
    const thinkingModeButtons = [...document.querySelectorAll('[data-thinking-mode-choice]')];
    const thinkingStoryLabel = document.getElementById('thinkingStoryLabel');
    const thinkingStory = document.getElementById('thinkingStory');
    const thinkingStoryNote = document.getElementById('thinkingStoryNote');
    const thinkingAuditGrid = document.getElementById('thinkingAuditGrid');
    const layerQuestions = [
      {
        prompt: '过去 30 天，已签收订单的退货率从 4% 升至 9%。',
        answer: 'fact',
        label: '事实',
        title: '事实：它只陈述可以核对的变化。',
        explanation: '时间、范围、口径和数值已经给出；它仍然没有解释为什么发生。',
      },
      {
        prompt: '退货率上升，是因为产品质量下降了。',
        answer: 'explanation',
        label: '解释',
        title: '解释：它为已经发生的变化补上原因。',
        explanation: '“因为”引入了因果机制；现在需要比较品控、渠道、用户结构等替代解释。',
      },
      {
        prompt: '这个产品已经不行了。',
        answer: 'evaluation',
        label: '评价',
        title: '评价：它把变化放进了一套好坏标准。',
        explanation: '“不行”不是观察记录。它必须说明与谁比较，以及什么指标和阈值才算“不行”。',
      },
      {
        prompt: '接下来两个季度，退货率还会继续上升。',
        answer: 'prediction',
        label: '预测',
        title: '预测：它开始承担未来失败的风险。',
        explanation: '时间窗口已经出现；还需要幅度阈值、作用机制，以及什么结果算预测落空。',
      },
      {
        prompt: '所以，现在不应该再买这个产品。',
        answer: 'action',
        label: '行动',
        title: '行动：它把判断连接到具体人的目标。',
        explanation: '同一事实面对不同预算、用途、替代选项和风险承受力，不必推出同一个行动。',
      },
    ];
    const layerLabels = {
      fact: '事实',
      explanation: '解释',
      evaluation: '评价',
      prediction: '预测',
      action: '行动',
    };
    const marketPathLabels = { up: '上涨', flat: '横盘', down: '下跌' };
    const marketSideLabels = { bear: '看空', bull: '看多' };
    const marketSlotPlaceholders = new Map(marketDropzones.map((zone) => [zone.dataset.marketSlot, zone.innerHTML]));
    const marketPlacements = new Map();
    let layerStep = 0;
    let layerAnswered = false;
    let layerQuizTimer;
    let selectedNarrativeId = null;
    let pointerDrag = null;
    let pointerDragGhost = null;
    let pointerDropzone = null;
    let suppressNarrativeClick = false;
    const modelEvidenceStates = {
      repeat: {
        product: [82, '较强', '新增证据只被 A 预先推出'],
        marketing: [28, '较弱', '与 R 相容，但未预告 E₁'],
        context: [24, '较弱', '与 R 相容，但未预告 E₁'],
        verdict: 'E₁ 是模型 A 的区分性预测，因此 A 获得更强支持；B 与 C 仍可能解释原结果 R，却没有同样准确地预告新增证据。',
      },
      ads: {
        product: [24, '较弱', 'A 没有推出 E₂'],
        marketing: [70, '较强', 'B 能够预告 E₂'],
        context: [70, '较强', 'C 也能够预告 E₂'],
        verdict: 'E₂ 同时符合 B 与 C，因此可以削弱 A，却还不足以在 B 和 C 之间作出选择；下一步需要寻找两者给出不同预期的证据。',
      },
      industry: {
        product: [50, '相同', 'A 与 E₃ 相容'],
        marketing: [50, '相同', 'B 与 E₃ 相容'],
        context: [50, '相同', 'C 与 E₃ 相容'],
        verdict: 'E₃ 与三个模型都相容，因此几乎没有区分力。材料增加了，但模型之间的相对位置没有改变；相容不等于得到独特支持。',
      },
    };
    const thinkingModes = {
      fast: {
        label: '自动生成的解释',
        story: 'L → 原因 I → “事情就是这样”',
        note: '自动补全隐藏了从观察到解释的中间步骤，连贯感因此看起来像事实感。',
      },
      slow: {
        label: '拆解后的暂时结构',
        story: '观察 L + 推断 I + 未知 U + 替代解释 I₁ / I₂',
        note: '观察仍被保留；自动生成的原因被重新标记为假设，并与未知条件和替代模型并列。',
      },
    };

    const updateProgress = () => {
      if (!progress) return;
      const scrollable = document.documentElement.scrollHeight - window.innerHeight;
      const ratio = scrollable > 0 ? window.scrollY / scrollable : 0;
      progress.style.width = `${Math.min(100, Math.max(0, ratio * 100))}%`;
    };

    const updateAudit = () => {
      if (!gauge || !score || !status || !auditLab) return;

      let total = 0;
      let answered = 0;
      let weakest = null;
      let updatePoints = null;
      const selections = new Map();

      auditDimensions.forEach((dimension) => {
        const selected = dimension.querySelector('input:checked');
        const points = selected ? Number(selected.value) : 0;
        const maximum = Number(dimension.dataset.max);
        const label = dimension.dataset.label;
        const dimensionScore = dimension.querySelector('legend b');

        total += points;
        if (dimensionScore) dimensionScore.textContent = `${points} / ${maximum}`;
        if (!selected) return;

        answered += 1;
        selections.set(dimension.dataset.auditDimension, selected.value);
        const ratio = points / maximum;
        if (!weakest || ratio < weakest.ratio) weakest = { label, ratio };
        if (dimension.dataset.auditDimension === 'update') updatePoints = points;
      });

      let verdict = '待审计';
      let message = '从每一行选择最接近原句的描述，圆环才会形成有意义的分数。';
      let color = 'var(--red)';
      let soft = 'var(--red-soft)';

      if (answered > 0 && answered < auditDimensions.length) {
        verdict = '评估中';
        message = `当前为 ${total} 分，还有 ${auditDimensions.length - answered} 个维度未判断；完整选择后再看结论。`;
        color = 'var(--blue)';
        soft = 'var(--blue-soft)';
      } else if (answered === auditDimensions.length) {
        if (updatePoints === 0) {
          verdict = '封闭判断';
          message = '没有失败条件：其他部分即使写得完整，现实仍然很难改变这个判断。';
        } else if (total < 35) {
          verdict = '封闭叙事';
          message = '它主要还是一个标签：事实、机制和预测都没有形成可核对的结构。';
        } else if (total < 60) {
          verdict = '证据薄弱';
          message = '它已经接触现实，但仍有较大空间用模糊期限或单一原因保护原结论。';
          color = 'var(--gold)';
          soft = 'var(--gold-soft)';
        } else if (total < 80) {
          verdict = '局部可检验';
          message = '多数结构已经出现；补齐最弱环节后，现实才能更明确地提高或降低置信度。';
          color = 'var(--blue)';
          soft = 'var(--blue-soft)';
        } else if (total < 95) {
          verdict = '开放模型';
          message = '判断已经承担较清楚的失败风险，但仍要按事前口径执行更新，而不是临场改规则。';
          color = 'var(--green)';
          soft = 'var(--green-soft)';
        } else {
          verdict = '高度开放';
          message = '事实、机制、预测和更新规则都已公开；新的证据真正有机会改变结论。';
          color = 'var(--green)';
          soft = 'var(--green-soft)';
        }
      }

      score.textContent = String(total);
      status.textContent = message;
      if (auditVerdict) auditVerdict.textContent = verdict;
      if (auditAnswered) auditAnswered.textContent = `${answered} / ${auditDimensions.length} 维已判断`;
      if (auditRecapScore) auditRecapScore.textContent = String(total);
      if (auditRecapVerdict) auditRecapVerdict.textContent = verdict;
      if (auditRecapText) {
        auditRecapText.textContent = answered === auditDimensions.length
          ? message
          : `你完成了 ${answered} / ${auditDimensions.length} 个维度。可以直接在这里补完或重新选择，结果会同步到开头。`;
      }
      auditSyncButtons.forEach((button) => {
        const active = selections.get(button.dataset.auditSyncDimension) === button.dataset.auditSyncValue;
        button.classList.toggle('is-active', active);
        button.setAttribute('aria-pressed', String(active));
      });
      if (auditWeakSpot) {
        auditWeakSpot.textContent = answered < auditDimensions.length
          ? `${auditDimensions.length - answered} 维待选择`
          : total === 100
            ? '无明显短板'
            : weakest?.label || '待选择';
      }
      auditLab.style.setProperty('--audit-color', color);
      auditLab.style.setProperty('--audit-soft', soft);
      gauge.style.setProperty('--score-angle', `${total * 3.6}deg`);
      gauge.setAttribute('aria-label', `观点开放度${total}分，共一百分；${verdict}`);
    };

    const renderLayerQuestion = () => {
      const question = layerQuestions[layerStep];
      if (!question || !layerQuiz) return;

      layerAnswered = false;
      layerQuiz.dataset.layerStep = String(layerStep);
      if (layerQuizIndex) layerQuizIndex.textContent = String(layerStep + 1).padStart(2, '0');
      if (layerQuizTrack) layerQuizTrack.style.width = `${((layerStep + 1) / layerQuestions.length) * 100}%`;
      if (layerQuizLabel) layerQuizLabel.textContent = '先判断';
      if (layerQuizPrompt) layerQuizPrompt.textContent = question.prompt;
      if (layerQuizFeedback) delete layerQuizFeedback.dataset.result;
      if (layerQuizFeedbackKicker) layerQuizFeedbackKicker.textContent = '选择后揭示';
      if (layerQuizFeedbackTitle) layerQuizFeedbackTitle.textContent = '先判断这句话受哪一种规则约束。';
      if (layerQuizFeedbackText) layerQuizFeedbackText.textContent = '这里不计算总分，只检查已经加工过的判断有没有被误当成事实。';
      if (layerQuizStatus) layerQuizStatus.textContent = `第 ${layerStep + 1} 句，共 ${layerQuestions.length} 句`;
      if (layerQuizNext) {
        layerQuizNext.disabled = true;
        layerQuizNext.innerHTML = '下一句 <i>→</i>';
      }

      layerChoiceButtons.forEach((button) => {
        button.disabled = false;
        button.classList.remove('is-correct', 'is-wrong', 'is-dim');
        button.setAttribute('aria-pressed', 'false');
      });
    };

    const answerLayerQuestion = (choice) => {
      const question = layerQuestions[layerStep];
      if (!question || layerAnswered) return;

      layerAnswered = true;
      const correct = choice === question.answer;
      layerChoiceButtons.forEach((button) => {
        const buttonChoice = button.dataset.layerChoice;
        const isAnswer = buttonChoice === question.answer;
        const isSelection = buttonChoice === choice;
        button.disabled = true;
        button.classList.toggle('is-correct', isAnswer);
        button.classList.toggle('is-wrong', isSelection && !correct);
        button.classList.toggle('is-dim', !isAnswer && !isSelection);
        button.setAttribute('aria-pressed', String(isSelection));
      });

      if (layerQuizLabel) layerQuizLabel.textContent = question.label;
      if (layerQuizFeedback) layerQuizFeedback.dataset.result = correct ? 'correct' : 'wrong';
      if (layerQuizFeedbackKicker) {
        layerQuizFeedbackKicker.textContent = correct ? '层级判断成立' : `你选择了${layerLabels[choice]}`;
      }
      if (layerQuizFeedbackTitle) layerQuizFeedbackTitle.textContent = question.title;
      if (layerQuizFeedbackText) {
        layerQuizFeedbackText.textContent = correct
          ? question.explanation
          : `正确层级是“${question.label}”。${question.explanation}`;
      }
      if (layerQuizStatus) layerQuizStatus.textContent = `已拆开第 ${layerStep + 1} 句`;
      if (layerQuizNext) {
        layerQuizNext.disabled = false;
        layerQuizNext.innerHTML = layerStep === layerQuestions.length - 1
          ? '重新开始 <i>↺</i>'
          : '下一句 <i>→</i>';
      }
    };

    const advanceLayerQuestion = () => {
      if (!layerAnswered || !layerQuizStage) return;
      window.clearTimeout(layerQuizTimer);
      layerQuizStage.classList.add('is-changing');
      layerQuizTimer = window.setTimeout(() => {
        layerStep = layerStep === layerQuestions.length - 1 ? 0 : layerStep + 1;
        renderLayerQuestion();
        layerQuizStage.classList.remove('is-changing');
      }, 150);
    };

    const setMarketPuzzleStatus = (message, state = '') => {
      if (!marketPuzzleStatus) return;
      marketPuzzleStatus.textContent = message;
      marketPuzzleStatus.classList.toggle('is-error', state === 'error');
      marketPuzzleStatus.classList.toggle('is-success', state === 'success');
    };

    const selectNarrativeCard = (narrativeId) => {
      selectedNarrativeId = selectedNarrativeId === narrativeId ? null : narrativeId;
      marketNarrativeCards.forEach((card) => {
        const active = card.dataset.narrativeId === selectedNarrativeId;
        card.classList.toggle('is-selected', active);
        card.setAttribute('aria-pressed', String(active));
      });

      if (!selectedNarrativeId) {
        setMarketPuzzleStatus('选择一张叙事卡，或直接把它拖到你认为对应的空位。');
        return;
      }

      const selectedCard = marketNarrativeCards.find((card) => card.dataset.narrativeId === selectedNarrativeId);
      const title = selectedCard?.querySelector('b')?.textContent || '这张卡';
      setMarketPuzzleStatus(`已选择“${title}”。现在点击对应的空位。`);
    };

    const updateMarketPuzzle = () => {
      const count = marketPlacements.size;
      const complete = count === marketNarrativeCards.length;
      if (marketPuzzleCount) marketPuzzleCount.textContent = `${count} / ${marketNarrativeCards.length}`;
      if (marketMirrorLab) marketMirrorLab.dataset.marketComplete = String(complete);

      if (!marketMirrorVerdict) return;
      if (complete) {
        marketMirrorVerdict.innerHTML = '<span>镜像发生在这里</span><b>上涨、横盘、下跌都能被看多与看空叙事分别吸收。对称的不是证据质量，而是只要没有失败条件，任何价格路径都能保护原来的立场。</b>';
      } else {
        marketMirrorVerdict.innerHTML = '<span>完成后揭示</span><b>当六个空位都被填满，再看真正对称的是什么。</b>';
      }
    };

    const removeMarketPlacement = (zone) => {
      const cardId = zone.dataset.cardId;
      if (!cardId) return;
      const card = marketNarrativeCards.find((item) => item.dataset.narrativeId === cardId);
      marketPlacements.delete(zone.dataset.marketSlot);
      delete zone.dataset.cardId;
      zone.classList.remove('is-filled');
      zone.innerHTML = marketSlotPlaceholders.get(zone.dataset.marketSlot) || '';
      if (card) {
        card.disabled = false;
        card.classList.remove('is-placed');
      }
      setMarketPuzzleStatus('这张卡已取回。可以重新选择它的位置。');
      updateMarketPuzzle();
    };

    const placeNarrativeCard = (narrativeId, zone) => {
      const card = marketNarrativeCards.find((item) => item.dataset.narrativeId === narrativeId);
      if (!card || card.classList.contains('is-placed')) return;

      if (narrativeId !== zone.dataset.marketSlot) {
        const [path, side] = narrativeId.split('-');
        zone.classList.remove('is-wrong');
        requestAnimationFrame(() => zone.classList.add('is-wrong'));
        setMarketPuzzleStatus(`“${card.querySelector('b')?.textContent}”是在用${marketPathLabels[path]}维护${marketSideLabels[side]}立场，不属于这个空位。`, 'error');
        return;
      }

      if (zone.dataset.cardId) removeMarketPlacement(zone);
      const title = card.querySelector('b')?.textContent || '';
      const explanation = card.querySelector('small')?.textContent || '';
      const [path, side] = narrativeId.split('-');
      zone.dataset.cardId = narrativeId;
      zone.classList.remove('is-over', 'is-wrong');
      zone.classList.add('is-filled');
      zone.innerHTML = `<span>${marketPathLabels[path]} × ${marketSideLabels[side]}</span><b>${title}</b><small>${explanation}</small>`;
      marketPlacements.set(zone.dataset.marketSlot, narrativeId);
      card.disabled = true;
      card.classList.remove('is-selected', 'is-dragging');
      card.classList.add('is-placed');
      card.setAttribute('aria-pressed', 'false');
      selectedNarrativeId = null;
      const remaining = marketNarrativeCards.length - marketPlacements.size;
      setMarketPuzzleStatus(
        remaining === 0 ? '六张卡已经归位。现在看这组镜像真正说明了什么。' : `“${title}”已归位，还剩 ${remaining} 张。`,
        remaining === 0 ? 'success' : '',
      );
      updateMarketPuzzle();
    };

    const clearMarketPointerDrag = () => {
      if (pointerDrag?.card) {
        pointerDrag.card.classList.remove('is-dragging');
      }
      pointerDragGhost?.remove();
      pointerDropzone?.classList.remove('is-over');
      pointerDrag = null;
      pointerDragGhost = null;
      pointerDropzone = null;
    };

    const moveMarketPointerDrag = (event) => {
      if (!pointerDrag || pointerDrag.pointerId !== event.pointerId) return;
      const distance = Math.hypot(event.clientX - pointerDrag.startX, event.clientY - pointerDrag.startY);
      if (!pointerDrag.active && distance < 8) return;
      event.preventDefault();

      if (!pointerDrag.active) {
        pointerDrag.active = true;
        pointerDrag.card.classList.add('is-dragging');
        pointerDragGhost = document.createElement('div');
        pointerDragGhost.className = 'market-drag-ghost';
        pointerDragGhost.innerHTML = pointerDrag.card.innerHTML;
        pointerDragGhost.style.width = `${pointerDrag.card.getBoundingClientRect().width}px`;
        (document.querySelector('.fact-opinion-page') || document.body).appendChild(pointerDragGhost);
      }

      pointerDragGhost.style.transform = `translate(${event.clientX + 14}px, ${event.clientY + 14}px) rotate(1.5deg)`;
      const nextDropzone = document.elementFromPoint(event.clientX, event.clientY)?.closest('[data-market-slot]');
      if (nextDropzone !== pointerDropzone) {
        pointerDropzone?.classList.remove('is-over');
        pointerDropzone = nextDropzone;
        pointerDropzone?.classList.add('is-over');
      }
    };

    const finishMarketPointerDrag = (event) => {
      if (!pointerDrag || pointerDrag.pointerId !== event.pointerId) return;
      const wasDragging = pointerDrag.active;
      const narrativeId = pointerDrag.narrativeId;
      const target = pointerDropzone;
      if (wasDragging) {
        event.preventDefault();
        suppressNarrativeClick = true;
      }
      clearMarketPointerDrag();
      if (wasDragging && target) placeNarrativeCard(narrativeId, target);
      if (wasDragging && !target) setMarketPuzzleStatus('没有放进空位，卡片已回到原处。');
      if (wasDragging) window.setTimeout(() => { suppressNarrativeClick = false; }, 0);
    };

    const resetMarketPuzzle = () => {
      clearMarketPointerDrag();
      marketPlacements.clear();
      selectedNarrativeId = null;
      marketNarrativeCards.forEach((card) => {
        card.disabled = false;
        card.classList.remove('is-selected', 'is-placed', 'is-dragging');
        card.setAttribute('aria-pressed', 'false');
      });
      marketDropzones.forEach((zone) => {
        delete zone.dataset.cardId;
        zone.classList.remove('is-filled', 'is-over', 'is-wrong');
        zone.innerHTML = marketSlotPlaceholders.get(zone.dataset.marketSlot) || '';
      });
      setMarketPuzzleStatus('选择一张叙事卡，或直接把它拖到你认为对应的空位。');
      updateMarketPuzzle();
    };

    const updateModelEvidence = (choice) => {
      const next = modelEvidenceStates[choice];
      if (!next || !modelLab) return;

      modelLab.dataset.modelEvidence = choice;
      modelEvidenceButtons.forEach((button) => {
        const active = button.dataset.modelEvidenceChoice === choice;
        button.classList.toggle('is-active', active);
        button.setAttribute('aria-pressed', String(active));
      });

      const updates = [
        [productSupport, productScore, productReading, next.product],
        [marketingSupport, marketingScore, marketingReading, next.marketing],
        [contextSupport, contextScore, contextReading, next.context],
      ];

      updates.forEach(([meter, scoreNode, readingNode, value]) => {
        if (meter) meter.style.width = `${value[0]}%`;
        if (scoreNode) scoreNode.textContent = value[1];
        if (readingNode) readingNode.textContent = value[2];
      });

      if (modelEvidenceVerdict) modelEvidenceVerdict.textContent = next.verdict;
    };

    const updateThinkingMode = (mode) => {
      const next = thinkingModes[mode];
      if (!next || !thinkingLab) return;

      thinkingLab.dataset.thinkingMode = mode;
      thinkingModeButtons.forEach((button) => {
        const active = button.dataset.thinkingModeChoice === mode;
        button.classList.toggle('is-active', active);
        button.setAttribute('aria-pressed', String(active));
      });

      if (thinkingStoryLabel) thinkingStoryLabel.textContent = next.label;
      if (thinkingStory) thinkingStory.textContent = next.story;
      if (thinkingStoryNote) thinkingStoryNote.textContent = next.note;
      if (thinkingAuditGrid) thinkingAuditGrid.setAttribute('aria-hidden', String(mode === 'fast'));
    };

    const setupReveals = () => {
      const page = document.querySelector('.fact-opinion-page');
      const targets = [...document.querySelectorAll('.hero, .visual-block, .theory-boundary, .falsify-boundary, .audit-budget, .self-audit, .quote, .closing')];
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!page || reduceMotion || !('IntersectionObserver' in window)) return;

      targets.forEach((target) => target.classList.add('reveal-target'));
      page.classList.add('reveal-ready');

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      }, { rootMargin: '0px 0px -10% 0px', threshold: 0.08 });

      targets.forEach((target) => observer.observe(target));
    };

    window.addEventListener('scroll', updateProgress, { passive: true });
    auditInputs.forEach((input) => input.addEventListener('change', updateAudit));
    auditSyncButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const dimension = auditDimensions.find((item) => item.dataset.auditDimension === button.dataset.auditSyncDimension);
        const input = dimension?.querySelector(`input[value="${button.dataset.auditSyncValue}"]`);
        if (!input) return;
        input.checked = true;
        updateAudit();
      });
    });
    layerChoiceButtons.forEach((button) => {
      button.addEventListener('click', () => answerLayerQuestion(button.dataset.layerChoice));
    });
    layerQuizNext?.addEventListener('click', advanceLayerQuestion);
    marketNarrativeCards.forEach((card) => {
      card.addEventListener('click', (event) => {
        if (suppressNarrativeClick) {
          event.preventDefault();
          return;
        }
        selectNarrativeCard(card.dataset.narrativeId);
      });
      card.addEventListener('pointerdown', (event) => {
        if (event.pointerType === 'touch' || event.button !== 0 || card.classList.contains('is-placed')) return;
        pointerDrag = {
          card,
          narrativeId: card.dataset.narrativeId,
          pointerId: event.pointerId,
          startX: event.clientX,
          startY: event.clientY,
          active: false,
        };
      });
    });
    document.addEventListener('pointermove', moveMarketPointerDrag, { passive: false });
    document.addEventListener('pointerup', finishMarketPointerDrag);
    document.addEventListener('pointercancel', clearMarketPointerDrag);
    marketDropzones.forEach((zone) => {
      zone.addEventListener('click', () => {
        if (selectedNarrativeId) {
          placeNarrativeCard(selectedNarrativeId, zone);
        } else if (zone.dataset.cardId) {
          removeMarketPlacement(zone);
        } else {
          setMarketPuzzleStatus('先从上方选择一张叙事卡，再点击这个空位。');
        }
      });
    });
    marketPuzzleReset?.addEventListener('click', resetMarketPuzzle);
    modelEvidenceButtons.forEach((button) => {
      button.addEventListener('click', () => updateModelEvidence(button.dataset.modelEvidenceChoice));
    });
    thinkingModeButtons.forEach((button) => {
      button.addEventListener('click', () => updateThinkingMode(button.dataset.thinkingModeChoice));
    });
    updateProgress();
    renderLayerQuestion();
    resetMarketPuzzle();
    updateModelEvidence('repeat');
    updateThinkingMode('fast');
    updateAudit();
    setupReveals();
  })();
</script>
</body>
</html>
