---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const thoughts = await getCollection('thinking');
  return thoughts.map((t) => ({
    params: { slug: t.id },
    props: { t },
  }));
}

const { t } = Astro.props;
const { Content } = await render(t);
---

<Layout title={t.data.title}>
  <article class="article-wrap">
    <div class="article-meta">
      <div class="article-tags">
        {t.data.tags.map((tag: string) => (
          <span class="tag">#{tag}</span>
        ))}
      </div>
    </div>

    <h1 class="article-title">{t.data.title}</h1>

    <time class="article-date">{t.data.date.toISOString().slice(0, 10)}</time>

    <div class="divider"><div class="divider-dot"></div></div>

    <div class="prose article-content">
      <Content />
    </div>

    <div class="article-back">
      <a href="/thinking">← 思考</a>
    </div>
  </article>
</Layout>

<style>
  .article-wrap {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 2rem 8rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .article-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
  }

  .article-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0.02em;
    color: var(--ink);
  }

  .article-date {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    color: var(--faint);
    letter-spacing: 0.2em;
    display: block;
    margin-top: 1.5rem;
  }

  .article-content {
    margin-top: 3rem;
  }

  .article-back {
    margin-top: 4rem;
  }

  .article-back a {
    font-size: 0.85rem;
    color: var(--muted);
  }

  .article-back a:hover {
    color: var(--accent);
  }
</style>
