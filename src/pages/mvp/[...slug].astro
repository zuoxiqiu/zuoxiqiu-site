---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { getExcerpt, getReadingMinutes } from '../../utils/content';

export async function getStaticPaths() {
  const mvps = await getCollection('mvp');
  return mvps.map((mvp) => ({
    params: { slug: mvp.id.replace(/.md$/, '') },
    props: { mvp },
  }));
}

const { mvp } = Astro.props;
const { Content } = await render(mvp);

const formatDate = (date: Date) => date.toISOString().slice(0, 10);
const description = getExcerpt(mvp.body, 120);
const readingMinutes = getReadingMinutes(mvp.body);

const statusLabels: Record<string, string> = {
  testing: '验证中',
  done: '已实现',
  abandoned: '已放弃',
};
---

<Layout
  title={mvp.data.title}
  description={description}
  pageType="article"
  publishedTime={mvp.data.date.toISOString()}
>
  <article class="article-wrap">
    <header class="article-shell">
      <div class="article-shell-top">
        <div class="article-tags">
          <span class="status-badge">MVP</span>
          <span class="status-badge">{statusLabels[mvp.data.status]}</span>
          <span class="article-read-time">约 {readingMinutes} 分钟阅读</span>
        </div>
        <span class="tag">{formatDate(mvp.data.date)}</span>
      </div>

      <h1 class="article-title">{mvp.data.title}</h1>

      <p class="article-submeta">
        {mvp.data.tags.map((tag: string) => `#${tag}`).join(' · ')}
      </p>
    </header>

    <div class="article-content">
      <div class="article-prose prose">
        <Content />
      </div>
    </div>

    <div class="article-back">
      <a href="/mvp" class="back-link">返回实验列表</a>
    </div>
  </article>
</Layout>
