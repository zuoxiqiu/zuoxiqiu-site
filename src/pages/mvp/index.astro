---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const mvps = await getCollection('mvp');

const statusLabels = {
  testing: { text: "🧪 验证中", color: "bg-green-100 text-green-700" },
  done: { text: "✅ 已实现", color: "bg-purple-100 text-purple-700" },
  abandoned: { text: "❌ 已放弃", color: "bg-red-100 text-red-700" }
};

// Sort by date desc
mvps.sort((a, b) => new Date(b.data.date) - new Date(a.data.date));

// Count by status
const counts = {
  testing: mvps.filter(m => m.data.status === 'testing').length,
  done: mvps.filter(m => m.data.status === 'done').length,
  abandoned: mvps.filter(m => m.data.status === 'abandoned').length
};
---

<Layout title="实验场">
  <div class="max-w-4xl mx-auto">
    <div class="mb-12">
      <h1 class="text-3xl md:text-4xl font-bold mb-3 text-gray-900">实验场</h1>
      <p class="text-lg text-gray-600">从想法到验证，记录完整的实验过程</p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-3 gap-6 mb-12">
      <div class="bg-white p-6 rounded-2xl shadow-sm text-center hover:shadow-md transition">
        <div class="text-3xl mb-2">🧪</div>
        <div class="text-2xl font-bold text-gray-900">{counts.testing}</div>
        <div class="text-sm text-gray-500 mt-1">验证中</div>
      </div>
      <div class="bg-white p-6 rounded-2xl shadow-sm text-center hover:shadow-md transition">
        <div class="text-3xl mb-2">✅</div>
        <div class="text-2xl font-bold text-gray-900">{counts.done}</div>
        <div class="text-sm text-gray-500 mt-1">已实现</div>
      </div>
      <div class="bg-white p-6 rounded-2xl shadow-sm text-center hover:shadow-md transition">
        <div class="text-3xl mb-2">❌</div>
        <div class="text-2xl font-bold text-gray-900">{counts.abandoned}</div>
        <div class="text-sm text-gray-500 mt-1">已放弃</div>
      </div>
    </div>

    <!-- MVP List -->
    <div class="space-y-6">
      {mvps.map((mvp) => (
        <article class="bg-white p-8 shadow-sm hover:shadow-lg transition-all duration-300 rounded-2xl border border-gray-100">
          <div class="flex items-start justify-between mb-4">
            <div class="flex gap-2 flex-wrap">
              {mvp.data.tags.map((tag) => (
                <span class="px-3 py-1 bg-gray-100 text-gray-600 text-sm font-medium rounded-full">
                  #{tag}
                </span>
              ))}
            </div>
            <span class={`px-3 py-1.5 rounded-full text-sm font-medium ${statusLabels[mvp.data.status].color}`}>
              {statusLabels[mvp.data.status].text}
            </span>
          </div>
          
          <h2 class="text-2xl font-semibold mb-3 text-gray-900 hover:text-blue-600 cursor-pointer transition">
            {mvp.data.title}
          </h2>
          
          <div class="text-gray-600 leading-relaxed mb-6 prose prose-sm max-w-none" set:html={mvp.rendered?.html?.split('</h2>')[0] || ''} />
          
          <div class="flex items-center justify-between pt-4 border-t border-gray-100">
            <time class="text-sm text-gray-500">{mvp.data.date.toISOString().split('T')[0]}</time>
            <a href={`/mvp/${mvp.id}`} class="text-blue-500 hover:text-blue-600 text-sm font-medium cursor-pointer">查看完整记录 →</a>
          </div>
        </article>
      ))}
    </div>

    {/* Empty State */}
    {mvps.length === 0 && (
      <div class="text-center py-24">
        <div class="text-8xl mb-8 opacity-20">🧪</div>
        <h3 class="text-2xl font-semibold mb-2 text-gray-900">还没有实验</h3>
        <p class="text-gray-600 mb-6">把一个想法变成 MVP，开始验证吧</p>
        <div class="inline-block bg-gray-100 px-6 py-4 rounded-lg font-mono text-sm text-gray-500">
          src/content/mvp/your-mvp.md
        </div>
      </div>
    )}

    <!-- Add New Button -->
    <div class="mt-16 text-center">
      <button class="px-8 py-4 bg-gradient-to-r from-blue-500 to-purple-500 text-white rounded-full font-medium shadow-md hover:shadow-lg transition-all duration-300 hover:-translate-y-0.5">
        <span>➕ 开始新实验</span>
      </button>
    </div>
  </div>
</Layout>
