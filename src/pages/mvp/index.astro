---
import Layout from '../../layouts/Layout.astro';

// 示例 MVP 数据
const mvps = [
  {
    title: "个人网站 zuoxiqiu.com",
    date: "2026-03-13",
    status: "testing",
    tags: ["产品", "网站"],
    summary: "搭建个人想法展示网站，验证静态网站 + Vercel 方案"
  }
];

const statusLabels = {
  testing: { text: "🧪 验证中", color: "bg-blue-100 text-blue-700" },
  done: { text: "✅ 已实现", color: "bg-green-100 text-green-700" },
  abandoned: { text: "❌ 已放弃", color: "bg-red-100 text-red-700" }
};
---

<Layout title="实验场">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">实验场</h1>
    <p class="text-gray-600">从想法到验证，记录完整的实验过程</p>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-3 gap-4 mb-8">
    <div class="bg-white p-4 rounded-lg shadow-sm text-center">
      <div class="text-2xl font-bold text-blue-600">🧪</div>
      <div class="text-sm text-gray-600 mt-1">验证中</div>
    </div>
    <div class="bg-white p-4 rounded-lg shadow-sm text-center">
      <div class="text-2xl font-bold text-green-600">✅</div>
      <div class="text-sm text-gray-600 mt-1">已实现</div>
    </div>
    <div class="bg-white p-4 rounded-lg shadow-sm text-center">
      <div class="text-2xl font-bold text-red-600">❌</div>
      <div class="text-sm text-gray-600 mt-1">已放弃</div>
    </div>
  </div>

  <!-- MVP List -->
  <div class="space-y-4">
    {mvps.map((mvp) => (
      <article class="bg-white rounded-lg shadow-sm p-6 hover:shadow-md transition border-l-4 border-blue-500">
        <div class="flex items-start justify-between mb-3">
          <div class="flex gap-2">
            {mvp.tags.map((tag) => (
              <span class="px-2 py-1 bg-gray-100 text-gray-600 rounded text-xs">{tag}</span>
            ))}
          </div>
          <span class={`px-2 py-1 rounded text-xs ${statusLabels[mvp.status].color}`}>
            {statusLabels[mvp.status].text}
          </span>
        </div>
        <h2 class="text-xl font-semibold text-gray-900 mb-2 hover:text-blue-600 cursor-pointer">
          {mvp.title}
        </h2>
        <p class="text-gray-600 mb-3">{mvp.summary}</p>
        <div class="flex items-center gap-4 text-sm text-gray-400">
          <time>{mvp.date}</time>
          <span>→ 查看完整记录</span>
        </div>
      </article>
    ))}
  </div>

  <!-- Empty State -->
  {mvps.length === 0 && (
    <div class="text-center py-16">
      <div class="text-6xl mb-4">🧪</div>
      <h3 class="text-lg font-semibold text-gray-900 mb-2">还没有实验</h3>
      <p class="text-gray-600 mb-4">把一个想法变成 MVP，开始验证吧</p>
      <code class="bg-gray-100 px-3 py-2 rounded text-sm">
        src/content/mvp/your-mvp.md
      </code>
    </div>
  )}
</Layout>
