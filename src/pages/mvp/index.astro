---
import Layout from '../../layouts/Layout.astro';

const mvps = [
  {
    title: "个人网站 zuoxiqiu.com",
    date: "2026-03-13",
    status: "testing",
    tags: ["产品", "网站"],
    summary: "搭建个人想法展示网站，验证静态网站 + Vercel 方案",
    progress: 85
  }
];

const statusLabels = {
  testing: { text: "验证中", class: "bg-green-500/20 text-green-300 border border-green-500/30" },
  done: { text: "已实现", class: "bg-gray-800 text-white border border-gray-700" },
  abandoned: { text: "已放弃", class: "bg-transparent border border-gray-700 text-gray-500" }
};
---

<Layout title="实验场">
  <div class="max-w-4xl mx-auto">
    <div class="mb-16">
      <h1 class="text-4xl font-bold mb-4 bg-gradient-to-r from-white to-gray-400 bg-clip-text text-transparent">实验场</h1>
      <p class="text-gray-400 leading-relaxed text-lg">
        从想法到验证，记录完整的实验过程。<br>
        每一个 MVP 都是一次大胆的尝试，无论成败都是资产。
      </p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-3 gap-6 mb-16">
      <div class="bg-surface p-6 shadow-card text-center" style="border: 1px solid rgba(255,255,255,0.06); border-radius: 12px;">
        <div class="text-3xl mb-2">🧪</div>
        <div class="text-2xl font-bold text-gray-100">1</div>
        <div class="text-sm text-gray-500 font-sans mt-1">验证中</div>
      </div>
      <div class="bg-surface p-6 shadow-card text-center" style="border: 1px solid rgba(255,255,255,0.06); border-radius: 12px;">
        <div class="text-3xl mb-2">✅</div>
        <div class="text-2xl font-bold text-gray-100">0</div>
        <div class="text-sm text-gray-500 font-sans mt-1">已实现</div>
      </div>
      <div class="bg-surface p-6 shadow-card text-center" style="border: 1px solid rgba(255,255,255,0.06); border-radius: 12px;">
        <div class="text-3xl mb-2">❌</div>
        <div class="text-2xl font-bold text-gray-100">0</div>
        <div class="text-sm text-gray-500 font-sans mt-1">已放弃</div>
      </div>
    </div>

    <!-- MVP List -->
    <div class="space-y-8">
      {mvps.map((mvp) => (
        <article class="bg-surface p-8 shadow-card group hover:shadow-glow transition-all duration-300" style="border: 1px solid rgba(255,255,255,0.06); border-radius: 16px;">
          <!-- Header -->
          <div class="flex items-start justify-between mb-5">
            <div class="flex gap-2 flex-wrap">
              {mvp.tags.map((tag) => (
                <span class="px-3 py-1 bg-charcoal text-gray-400 text-xs font-medium rounded-full border border-gray-800">
                  #{tag}
                </span>
              ))}
            </div>
            <span class={`px-4 py-2 rounded-full text-sm font-medium ${statusLabels[mvp.status].class}`}>
              {statusLabels[mvp.status].text}
            </span>
          </div>
          
          <!-- Title & Summary -->
          <h2 class="text-2xl font-semibold mb-3 group-hover:underline cursor-pointer text-white">
            {mvp.title}
          </h2>
          
          <p class="text-gray-400 leading-relaxed mb-6">
            {mvp.summary}
          </p>
          
          <!-- Progress bar for testing -->
          {mvp.status === 'testing' && (
            <div class="mb-6">
              <div class="flex justify-between text-sm text-gray-500 font-sans mb-2">
                <span>实验进度</span>
                <span class="font-semibold text-gray-200">{mvp.progress}%</span>
              </div>
              <div class="w-full bg-charcoal h-1.5 rounded-full overflow-hidden">
                <div class="bg-gradient-to-r from-blue-500 to-purple-500 h-full transition-all duration-500" style="width: {mvp.progress}%;"></div>
              </div>
            </div>
          )}
          
          <!-- Footer -->
          <div class="flex items-center justify-between pt-4 border-t border-gray-800">
            <time class="text-sm text-gray-500 font-sans">{mvp.date}</time>
            <button class="text-sm font-medium text-blue-300 hover:text-blue-200 transition">查看完整记录 →</button>
          </div>
        </article>
      ))}
    </div>

    {/* Empty State */}
    {mvps.length === 0 && (
      <div class="text-center py-24">
        <div class="text-8xl mb-8 opacity-20">🛠️</div>
        <h3 class="text-2xl font-semibold mb-2 text-white">还没有实验</h3>
        <p class="text-gray-400 mb-6 font-sans">把一个想法变成 MVP，开始验证吧</p>
        <div class="inline-block bg-charcoal px-6 py-4 rounded-lg font-mono text-sm text-gray-500 border border-gray-800">
          src/content/mvp/your-mvp.md
        </div>
      </div>
    )}

    <!-- Add New Button -->
    <div class="mt-16 text-center">
      <button class="btn-primary">
        <span>➕ 开始新实验</span>
      </button>
    </div>
  </div>
</Layout>
