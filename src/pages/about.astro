---
import Layout from '../layouts/Layout.astro';
---

<Layout title="关于">
  <div class="max-w-2xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <div class="relative inline-block mb-6">
        <span class="text-8xl animate-bounce" style="animation-duration: 3s; text-shadow: 4px 4px 0 #000;">🦞</span>
        <div class="absolute -top-4 -right-4 text-2xl" style="transform: rotate(15deg);">✨</div>
      </div>
      <h1 class="text-5xl font-handwriting font-bold text-pencil mb-4">关于 zuoxiqiu</h1>
      <p class="text-xl text-gray-600 font-sketch">
        一个好奇者的 <span class="text-marker-blue">数字花园</span>
      </p>
    </div>

    <!-- What is this? -->
    <div class="hand-border bg-paper p-8 mb-10 relative overflow-hidden" style="transform: rotate(-0.3deg);">
      <div class="absolute top-0 right-0 w-12 h-12 bg-marker-pink opacity-10" style="clip-path: polygon(100% 0, 0 0, 100% 100%);"></div>
      
      <h2 class="text-2xl font-handwriting font-bold text-pencil mb-6 flex items-center gap-2">
        <span>🌱</span> 这个网站是什么？
      </h2>
      
      <p class="text-gray-700 font-sketch text-lg leading-loose mb-4">
        这是我的 <strong class="text-marker-blue">数字花园</strong> —— 一个用来种想法、养实验、收知识的地方。
      </p>
      
      <p class="text-gray-700 font-sketch text-lg leading-loose mb-6">
        不追求完美，只求真实。每一个粗糙的想法，都可能长出意想不到的花。
      </p>
      
      <blockquote class="sticky-note max-w-md mx-auto my-8">
        <p class="text-lg font-handwriting text-gray-800 leading-relaxed">
          "小小的想法改变世界，世界总需要更多好奇心的人。"
        </p>
        <div class="mt-4 text-right text-sm font-handwriting text-gray-500">
          — zuoxiqiu
        </div>
      </blockquote>
      
      <p class="text-gray-600 font-sketch">
        💡 <strong>突发奇想</strong> - 随手记录，不筛选，不加工<br>
        🧪 <strong>MVP实验</strong> - 有潜力的想法进入验证阶段<br>
        ✅ <strong>已实现</strong> - 验证成功，形成项目或产品
      </p>
    </div>

    <!-- Tech Stack -->
    <div class="hand-border bg-paper p-8 mb-10 relative overflow-hidden" style="transform: rotate(0.3deg); margin-top: 1rem;">
      <div class="absolute top-0 right-0 w-12 h-12 bg-marker-green opacity-10" style="clip-path: polygon(100% 0, 0 0, 100% 100%);"></div>
      
      <h2 class="text-2xl font-handwriting font-bold text-pencil mb-6 flex items-center gap-2">
        <span>🔧</span> 技术栈
      </h2>
      
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white p-5 rounded-xl shadow-sm border-l-4 border-marker-blue">
          <h3 class="font-handwriting font-bold text-pencil mb-2">Astro</h3>
          <p class="text-gray-600 font-sketch">静态网站生成器，快如闪电</p>
        </div>
        <div class="bg-white p-5 rounded-xl shadow-sm border-l-4 border-marker-pink">
          <h3 class="font-handwriting font-bold text-pencil mb-2">Tailwind CSS</h3>
          <p class="text-gray-600 font-sketch">原子化 CSS，手写样式</p>
        </div>
        <div class="bg-white p-5 rounded-xl shadow-sm border-l-4 border-marker-green">
          <h3 class="font-handwriting font-bold text-pencil mb-2">Netlify</h3>
          <p class="text-gray-600 font-sketch">免费托管，自动部署</p>
        </div>
        <div class="bg-white p-5 rounded-xl shadow-sm border-l-4 border-marker-yellow">
          <h3 class="font-handwriting font-bold text-pencil mb-2">Markdown</h3>
          <p class="text-gray-600 font-sketch">内容用 Markdown 管理</p>
        </div>
      </div>
    </div>

    <!-- Contact -->
    <div class="hand-border bg-paper p-8 text-center relative overflow-hidden">
      <div class="absolute top-0 right-0 w-12 h-12 bg-marker-yellow opacity-10" style="clip-path: polygon(100% 0, 0 0, 100% 100%);"></div>
      
      <h2 class="text-2xl font-handwriting font-bold text-pencil mb-6 flex items-center justify-center gap-2">
        <span>✉️</span> 联系方式
      </h2>
      
      <p class="text-gray-600 font-sketch mb-6">
        有问题或合作意向？欢迎联系
      </p>
      
      <div class="flex justify-center gap-8 text-lg">
        <a href="https://github.com/zuoxiqiu" class="text-gray-700 hover:text-marker-blue transition font-sketch flex items-center gap-2">
          <span>🐙</span> GitHub
        </a>
        <a href="mailto:2658828897@qq.com" class="text-gray-700 hover:text-marker-pink transition font-sketch flex items-center gap-2">
          <span>📧</span> Email
        </a>
      </div>
    </div>
  </div>
</Layout>
