---
import Layout from '../layouts/Layout.astro';
---

<Layout title="关于">
  <div class="max-w-3xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-20">
      <h1 class="text-5xl font-semibold mb-4 bg-gradient-to-r from-white to-gray-400 bg-clip-text text-transparent">关于 zuoxiqiu</h1>
      <p class="text-xl text-gray-400 font-light">
        一个好奇者的 <strong class="text-blue-300">数字花园</strong>
      </p>
    </div>

    <!-- What -->
    <div class="bg-surface p-10 md:p-12 mb-12 shadow-card" style="border: 1px solid rgba(255,255,255,0.06); border-radius: 16px;">
      <h2 class="text-2xl font-semibold mb-6">这个网站是什么？</h2>
      <p class="text-gray-300 leading-loose mb-4">
        这是我的 <strong class="text-blue-300">数字花园</strong> —— 一个用来种想法、养实验、收知识的地方。
      </p>
      <p class="text-gray-300 leading-loose mb-8">
        不追求完美，只求真实。每一个粗糙的想法，都可能长出意想不到的花。
      </p>
      <blockquote class="border-l-2 border-purple-500 pl-6 py-2 my-8 italic text-gray-400 text-xl">
        "小小的想法改变世界，世界总需要更多好奇心的人。"
        <footer class="mt-3 text-sm text-gray-500">— zuoxiqiu</footer>
      </blockquote>
      <div class="space-y-3 text-gray-400">
        <p><strong>💡 突发奇想</strong> — 随手记录，不筛选，不加工</p>
        <p><strong>🧪 MVP实验</strong> — 有潜力的想法进入验证阶段</p>
        <p><strong>✅ 已实现</strong> — 验证成功，形成项目或产品</p>
      </div>
    </div>

    <!-- Tech -->
    <div class="bg-surface p-10 md:p-12 mb-12 shadow-card" style="border: 1px solid rgba(255,255,255,0.06); border-radius: 16px;">
      <h2 class="text-2xl font-semibold mb-6">技术栈</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-5 bg-charcoal" style="border-radius: 12px; border: 1px solid rgba(255,255,255,0.04);">
          <h3 class="font-semibold mb-2 text-white">Astro</h3>
          <p class="text-gray-400 text-sm">静态网站生成器，快如闪电</p>
        </div>
        <div class="p-5 bg-charcoal" style="border-radius: 12px; border: 1px solid rgba(255,255,255,0.04);">
          <h3 class="font-semibold mb-2 text-white">Tailwind CSS</h3>
          <p class="text-gray-400 text-sm">原子化 CSS，精准控制样式</p>
        </div>
        <div class="p-5 bg-charcoal" style="border-radius: 12px; border: 1px solid rgba(255,255,255,0.04);">
          <h3 class="font-semibold mb-2 text-white">Netlify</h3>
          <p class="text-gray-400 text-sm">免费托管，自动部署，全球 CDN</p>
        </div>
        <div class="p-5 bg-charcoal" style="border-radius: 12px; border: 1px solid rgba(255,255,255,0.04);">
          <h3 class="font-semibold mb-2 text-white">Markdown</h3>
          <p class="text-gray-400 text-sm">内容用 Markdown 管理，版本可控</p>
        </div>
      </div>
    </div>

    <!-- Contact -->
    <div class="bg-gradient-to-r from-blue-900/20 to-purple-900/20 p-10 md:p-12 text-center shadow-card" style="border: 1px solid rgba(255,255,255,0.06); border-radius: 16px;">
      <h2 class="text-2xl font-semibold mb-6">联系方式</h2>
      <p class="text-gray-300 mb-8">有问题或合作意向？欢迎联系</p>
      <div class="flex justify-center gap-10 text-lg">
        <a href="https://github.com/zuoxiqiu" class="text-white hover:text-blue-300 transition flex items-center gap-2">
          <span>🐙</span> GitHub
        </a>
        <a href="mailto:2658828897@qq.com" class="text-white hover:text-purple-300 transition flex items-center gap-2">
          <span>✉️</span> Email
        </a>
      </div>
    </div>
  </div>
</Layout>
