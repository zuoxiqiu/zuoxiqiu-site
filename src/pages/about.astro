---
import Layout from '../layouts/Layout.astro';
---

<Layout title="关于">
  <div class="max-w-2xl mx-auto">
    <div class="text-center mb-12">
      <div class="text-6xl mb-4">🦞</div>
      <h1 class="text-3xl font-bold text-gray-900 mb-2">关于 zuoxiqiu</h1>
      <p class="text-gray-600">一个好奇者的数字花园</p>
    </div>

    <div class="bg-white rounded-lg shadow-sm p-8 mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">这个网站是什么？</h2>
      <p class="text-gray-600 mb-4">
        这是我的<strong>数字花园</strong>（Digital Garden）。
      </p>
      <p class="text-gray-600 mb-4">
        在这里，我记录<strong>突发奇想</strong>（Raw Ideas）和<strong>MVP实验</strong>（验证中的项目）。
        不追求完美，只追求真实和持续迭代。
      </p>
      <blockquote class="border-l-4 border-blue-500 pl-4 py-2 my-6 bg-gray-50">
        <p class="text-gray-700 italic">
          "小小的想法改变世界，世界总需要更多好奇心的人。"
        </p>
      </blockquote>
    </div>

    <div class="bg-white rounded-lg shadow-sm p-8 mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">内容流转</h2>
      <div class="space-y-4">
        <div class="flex items-center gap-4">
          <div class="w-8 h-8 bg-gray-100 rounded-full flex items-center justify-center text-lg">💡</div>
          <div>
            <h3 class="font-medium text-gray-900">突发奇想</h3>
            <p class="text-sm text-gray-600">随手记录，不筛选，不加工</p>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center text-lg">🧪</div>
          <div>
            <h3 class="font-medium text-gray-900">MVP实验</h3>
            <p class="text-sm text-gray-600">有潜力的想法进入验证阶段</p>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center text-lg">✅</div>
          <div>
            <h3 class="font-medium text-gray-900">已实现</h3>
            <p class="text-sm text-gray-600">验证成功，形成项目或产品</p>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm p-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4">联系方式</h2>
      <div class="flex gap-4">
        <a href="https://github.com/zuoxiye" class="text-gray-600 hover:text-gray-900 transition">
          GitHub
        </a>
        <a href="mailto:zuoxiye@gmail.com" class="text-gray-600 hover:text-gray-900 transition">
          Email
        </a>
      </div>
    </div>
  </div>
</Layout>
