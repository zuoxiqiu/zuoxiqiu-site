---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "捕捉昨日的灵感，沉淀今日的思考" } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} · zuoxiqiu.com</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body>
    <header>
      <nav id="nav">
        <a href="/" class="nav-logo">昨夕秋</a>
        <ul class="nav-links">
          <li><a href="/ideas">想法</a></li>
          <li><a href="/thinking">思考</a></li>
          <li><a href="/mvp">实验</a></li>
          <li><a href="/about">关于</a></li>
        </ul>
      </nav>
    </header>
    
    <main>
      <slot />
    </main>
    
    <footer>
      <div class="divider">
        <div class="divider-dot"></div>
      </div>
      <div class="footer-content">
        <p class="footer-pinyin">昨 · 夕 · 秋</p>
      </div>
    </footer>

    <script>
      const nav = document.getElementById('nav');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          nav?.classList.add('scrolled');
        } else {
          nav?.classList.remove('scrolled');
        }
      });
    </script>
  </body>
</html>

<style>
  main {
    padding-top: 80px;
  }

  footer {
    padding: 0 2rem 4rem;
    text-align: center;
  }

  .footer-content {
    margin-top: 2rem;
  }

  .footer-pinyin {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.5em;
    color: var(--faint);
    margin-right: -0.5em;
  }
</style>
