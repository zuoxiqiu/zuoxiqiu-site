---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "小小的想法改变世界，世界总需要更多好奇心的人" } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | zuoxiqiu.com</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-paper min-h-screen">
    <header class="py-6 px-4 mb-8" style="background: linear-gradient(180deg, #fff 0%, #f7f3e8 100%); border-bottom: 3px dashed #cbd5e0;">
      <nav class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
        <a href="/" class="text-2xl font-handwriting font-bold text-pencil hover:text-marker-blue transition transform hover:scale-105">
          🦞 zuoxiqiu
        </a>
        <div class="flex gap-6 text-lg font-sketch">
          <a href="/ideas" class="text-gray-700 hover:text-marker-pink transition">📝 想法流</a>
          <a href="/mvp" class="text-gray-700 hover:text-marker-green transition">🧪 实验场</a>
          <a href="/about" class="text-gray-700 hover:text-marker-blue transition">👋 关于</a>
        </div>
      </nav>
    </header>
    
    <main class="max-w-4xl mx-auto px-4 pb-16">
      <slot />
    </main>
    
    <footer class="mt-20 py-8 border-t-4 border-dashed border-gray-300 bg-white/50">
      <div class="max-w-4xl mx-auto px-4 text-center text-gray-600 font-sketch">
        <p class="text-lg">🦞 小小的想法改变世界</p>
        <p class="text-sm mt-2">© 2026 zuoxiqiu.com · <span class="doodle-star"></span> 数字花园</p>
      </div>
    </footer>
  </body>
</html>
