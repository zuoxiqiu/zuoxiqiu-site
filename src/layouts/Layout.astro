---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "小小的想法改变世界，世界总需要更多好奇心的人" } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | zuoxiqiu.com</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen">
    <header class="py-6 px-4 mb-8" style="background: rgba(255,255,255,0.9); backdrop-filter: blur(10px); position: sticky; top: 0; z-index: 50; border-bottom: 1px solid #f3f4f6;">
      <nav class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
        <a href="/" class="text-xl font-bold text-gray-900 hover:text-blue-600 transition">
          🦞 昨夕秋
        </a>
        <div class="flex gap-6 text-sm">
          <a href="/ideas" class="text-gray-600 hover:text-blue-600 transition">想法流</a>
          <a href="/mvp" class="text-gray-600 hover:text-blue-600 transition">实验场</a>
          <a href="/about" class="text-gray-600 hover:text-blue-600 transition">关于</a>
        </div>
      </nav>
    </header>
    
    <main class="max-w-4xl mx-auto px-4 pb-16">
      <slot />
    </main>
    
    <footer class="py-8 px-4 border-t border-gray-100 mt-16">
      <div class="max-w-4xl mx-auto text-center text-sm text-gray-500">
        <p>© 2026 zuoxiqiu.com · 小小的想法改变世界</p>
      </div>
    </footer>
  </body>
</html>
